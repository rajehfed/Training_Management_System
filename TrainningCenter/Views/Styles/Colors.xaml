<!--
═══════════════════════════════════════════════════════════════════════════════
    COLOR PALETTE - Training Center Application
    
    This resource dictionary contains the complete color system for
    the application, ensuring consistency across all components.
    
    COLOR CATEGORIES:
    - Primary Colors (Brand colors)
    - Semantic Colors (Success, Warning, Error, Info)
    - Neutral Colors (Grays, Blacks)
    - Background Colors
    - Text Colors
    - Gradient Brushes
    
    Author: Training Center Team "Fedili Rajeh"
    Version: 1.0
═══════════════════════════════════════════════════════════════════════════════
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ═══════════════════════════════════════════════════════════════════════════
        PRIMARY BRAND COLORS
    ═══════════════════════════════════════════════════════════════════════════
    -->
    <!-- Main Brand Purple -->
    <Color x:Key="PrimaryColor">#8147E7</Color>
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>

    <!-- Light Purple (Hover state) -->
    <Color x:Key="PrimaryLightColor">#9A5FF0</Color>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>

    <!-- Dark Purple (Active/Pressed state) -->
    <Color x:Key="PrimaryDarkColor">#6F3DC0</Color>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>

    <!-- Very Light Purple (Backgrounds) -->
    <Color x:Key="PrimaryPaleColor">#F0EDFF</Color>
    <SolidColorBrush x:Key="PrimaryPaleBrush" Color="{StaticResource PrimaryPaleColor}"/>

    <!-- Ultra Light Purple -->
    <Color x:Key="PrimaryUltraLightColor">#E0DAFF</Color>
    <SolidColorBrush x:Key="PrimaryUltraLightBrush" Color="{StaticResource PrimaryUltraLightColor}"/>

    <!--
    ═══════════════════════════════════════════════════════════════════════════
        SEMANTIC COLORS
    ═══════════════════════════════════════════════════════════════════════════
    -->

    <!-- Success/Active Green -->
    <Color x:Key="SuccessColor">#28A745</Color>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <Color x:Key="SuccessLightColor">#E7F6EC</Color>
    <SolidColorBrush x:Key="SuccessLightBrush" Color="{StaticResource SuccessLightColor}"/>

    <!-- Error/Danger Red -->
    <Color x:Key="DangerColor">#DC3545</Color>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <Color x:Key="DangerLightColor">#FFE5E5</Color>
    <SolidColorBrush x:Key="DangerLightBrush" Color="{StaticResource DangerLightColor}"/>

    <!-- Warning Orange -->
    <Color x:Key="WarningColor">#FF9800</Color>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <Color x:Key="WarningLightColor">#FFF3E0</Color>
    <SolidColorBrush x:Key="WarningLightBrush" Color="{StaticResource WarningLightColor}"/>

    <!-- Info Blue -->
    <Color x:Key="InfoColor">#2196F3</Color>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    <Color x:Key="InfoLightColor">#E3F2FD</Color>
    <SolidColorBrush x:Key="InfoLightBrush" Color="{StaticResource InfoLightColor}"/>

    <!--
    ═══════════════════════════════════════════════════════════════════════════
        NEUTRAL COLORS (Grays)
    ═══════════════════════════════════════════════════════════════════════════
    -->

    <!-- Text Colors -->
    <Color x:Key="TextPrimaryColor">#202020</Color>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>

    <Color x:Key="TextSecondaryColor">#666666</Color>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>

    <Color x:Key="TextTertiaryColor">#999999</Color>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}"/>

    <Color x:Key="TextDisabledColor">#AAAAAA</Color>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>

    <!-- Border Colors -->
    <Color x:Key="BorderColor">#E0E0E0</Color>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <Color x:Key="BorderLightColor">#F0F0F0</Color>
    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderLightColor}"/>

    <Color x:Key="SeparatorColor">#E8E8E8</Color>
    <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource SeparatorColor}"/>

    <!--
    ═══════════════════════════════════════════════════════════════════════════
        BACKGROUND COLORS
    ═══════════════════════════════════════════════════════════════════════════
    -->
    <!-- Page Background -->
    <Color x:Key="PageBackgroundColor">#F5F7FA</Color>
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="{StaticResource PageBackgroundColor}"/>

    <!-- Card Background (White) -->
    <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>

    <!-- Input Background -->
    <Color x:Key="InputBackgroundColor">#F8F9FA</Color>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource InputBackgroundColor}"/>

    <!-- Hover Background -->
    <Color x:Key="HoverBackgroundColor">#F5F5F5</Color>
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="{StaticResource HoverBackgroundColor}"/>

    <!-- Selected Background -->
    <Color x:Key="SelectedBackgroundColor">#E5E5E5</Color>
    <SolidColorBrush x:Key="SelectedBackgroundBrush" Color="{StaticResource SelectedBackgroundColor}"/>

    <!-- Disabled Background -->
    <Color x:Key="DisabledBackgroundColor">#FAFAFA</Color>
    <SolidColorBrush x:Key="DisabledBackgroundBrush" Color="{StaticResource DisabledBackgroundColor}"/>

    <!--
    ═══════════════════════════════════════════════════════════════════════════
        GRADIENT BRUSHES
    ═══════════════════════════════════════════════════════════════════════════
    -->

    <!-- Primary Gradient (Purple) -->
    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#8147E7" Offset="0"/>
        <GradientStop Color="#A980F5" Offset="1"/>
    </LinearGradientBrush>

    <!-- Success Gradient (Green) -->
    <LinearGradientBrush x:Key="SuccessGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#28A745" Offset="0"/>
        <GradientStop Color="#5BC67D" Offset="1"/>
    </LinearGradientBrush>

    <!-- Warning Gradient (Orange) -->
    <LinearGradientBrush x:Key="WarningGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF9800" Offset="0"/>
        <GradientStop Color="#FFB74D" Offset="1"/>
    </LinearGradientBrush>

    <!-- Info Gradient (Blue) -->
    <LinearGradientBrush x:Key="InfoGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#2196F3" Offset="0"/>
        <GradientStop Color="#64B5F6" Offset="1"/>
    </LinearGradientBrush>

    <!-- Danger Gradient (Red) -->
    <LinearGradientBrush x:Key="DangerGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#DC3545" Offset="0"/>
        <GradientStop Color="#E57373" Offset="1"/>
    </LinearGradientBrush>

    <!--
    ═══════════════════════════════════════════════════════════════════════════
        SHADOW COLORS (for DropShadowEffect)
    ═══════════════════════════════════════════════════════════════════════════
    -->

    <Color x:Key="ShadowColor">#000000</Color>
    <Color x:Key="PrimaryShadowColor">#8147E7</Color>

    <!--
    ═══════════════════════════════════════════════════════════════════════════
        ADDITIONAL COLORS
    ═══════════════════════════════════════════════════════════════════════════
    -->
    <!-- Teal (Alternative Accent) -->
    <Color x:Key="TealColor">#009688</Color>
    <SolidColorBrush x:Key="TealBrush" Color="{StaticResource TealColor}"/>

    <!-- Pink (Alternative Accent) -->
    <Color x:Key="PinkColor">#E91E63</Color>
    <SolidColorBrush x:Key="PinkBrush" Color="{StaticResource PinkColor}"/>

    <!-- Indigo (Alternative Accent) -->
    <Color x:Key="IndigoColor">#3F51B5</Color>
    <SolidColorBrush x:Key="IndigoBrush" Color="{StaticResource IndigoColor}"/>


</ResourceDictionary>