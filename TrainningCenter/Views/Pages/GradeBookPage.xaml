<Page x:Class="TrainningCenter.Views.Pages.GradeBookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TrainningCenter.Views.Pages"
      xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
      xmlns:UC="clr-namespace:TrainningCenter.UserControles.Groups"
      xmlns:vm="clr-namespace:TrainningCenter.ViewModel"
      mc:Ignorable="d"
      Background="{StaticResource PageBackgroundBrush}"
      d:DesignHeight="800" d:DesignWidth="1600"
      Title="Gradebook">

    <Page.Resources>
        <!-- Status Color Converter -->
        <Style x:Key="StatusIndicator" TargetType="Border">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <!-- Grade Badge Style -->
        <Style x:Key="GradeBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="48"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER SECTION -->
        <Border Grid.Row="0" 
                Background="White" 
                Padding="32,24" 
                BorderBrush="{StaticResource BorderLightBrush}" 
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <Icons:PackIconMaterial Kind="SchoolOutline" 
                                                Height="32" Width="32"
                                                Foreground="{StaticResource PrimaryBrush}"
                                                VerticalAlignment="Center"
                                                Margin="0,0,12,0"/>
                        <TextBlock Text="Gradebook"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Quick inline editing for fast data entry"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Center">
                    <Button x:Name="btnExport"
                            Click="btnExport_Click"
                            Style="{StaticResource SecondaryButton}"
                            Padding="20,12"
                            Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <Icons:PackIconMaterial Kind="Download" 
                                                    Width="18" Height="18"
                                                    Margin="0,0,8,0"/>
                            <TextBlock Text="Export"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnSaveChanges"
                            Click="btnSaveChanges_Click"
                            Style="{StaticResource PrimaryButton}"
                            Padding="24,12">
                        <StackPanel Orientation="Horizontal">
                            <Icons:PackIconMaterial Kind="ContentSave" 
                                                    Width="20" Height="20"
                                                    Margin="0,0,8,0"/>
                            <TextBlock Text="Save All Changes"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- FILTERS SECTION -->
        <Border Grid.Row="1" 
                Background="White" 
                Padding="32,20"
                BorderBrush="{StaticResource BorderLightBrush}" 
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Assessment Filter -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="Assessment" 
                               FontSize="14" 
                               FontWeight="Bold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding AvailableAssessments}"
                              Style="{StaticResource ModernComboBox}"
                              SelectedValue="{Binding SelectedAssessmentId}"
                              SelectedValuePath="AssessmentID"
                              FontSize="14"
                              Padding="12,10">
                        <!-- ADD THIS TEMPLATE -->
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding AssessmentName}" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Padding" Value="12,8"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                </StackPanel>

                <!-- Group Filter -->
                <StackPanel Grid.Column="1" Margin="0,0,16,0">
                    <TextBlock Text="Group/Class" 
                               FontSize="14" 
                               FontWeight="Bold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding AvailableGroups}"
                              SelectedValue="{Binding SelectedGroupId}"
                              Style="{StaticResource ModernComboBox}"
                              SelectedValuePath="GroupID"
                              FontSize="14"
                              Padding="12,10">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding GroupName}" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Padding" Value="12,8"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                </StackPanel>

                <!-- Status Filter -->
                <StackPanel Grid.Column="2" Margin="0,0,16,0">
                    <TextBlock Text="Status" 
                               FontSize="14" 
                               FontWeight="Bold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatus}"
                              Style="{StaticResource ModernComboBox}"
                              FontSize="14"
                              Padding="12,10">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Padding" Value="12,8"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                </StackPanel>

                <!-- Reset Filters Button -->
                <Button Grid.Column="3"
                        Name="btnResetFilters"
                        Click="btnResetFilters_Click"
                        Style="{StaticResource IconButton}"
                        ToolTip="Reset all filters"
                        VerticalAlignment="Bottom"
                        Padding="12"
                        Margin="0,0,0,2">
                    <Icons:PackIconMaterial Kind="FilterRemove" 
                                            Width="20" Height="20"
                                            Foreground="{StaticResource TextSecondaryBrush}"/>
                </Button>
            </Grid>
        </Border>

        <!-- STATISTICS PANEL -->
        <Border Grid.Row="2" Background="#F8F9FA" Padding="32,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Students -->
                <StackPanel Grid.Column="0" Margin="0,0,24,0">
                    <TextBlock Text="TOTAL STUDENTS" 
                               FontSize="13" 
                               FontWeight="Bold"
                               Foreground="{StaticResource TextTertiaryBrush}"/>
                    <TextBlock Text="{Binding TotalStudents}" 
                               FontSize="28" 
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Average Marks -->
                <StackPanel Grid.Column="1" Margin="0,0,24,0">
                    <TextBlock Text="AVERAGE MARKS" 
                               FontSize="11" 
                               FontWeight="Bold"
                               Foreground="{StaticResource TextTertiaryBrush}"/>
                    <TextBlock Text="{Binding AverageMarks, StringFormat='{}{0:F1}'}" 
                               FontSize="28" 
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Pass Rate -->
                <StackPanel Grid.Column="2" Margin="0,0,24,0">
                    <TextBlock Text="PASS RATE" 
                               FontSize="11" 
                               FontWeight="Bold"
                               Foreground="{StaticResource TextTertiaryBrush}"/>
                    <TextBlock Text="{Binding PassRate, StringFormat='{}{0:F1}%'}" 
                               FontSize="28" 
                               FontWeight="Bold"
                               Foreground="{StaticResource SuccessBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Passed Count -->
                <StackPanel Grid.Column="3" Margin="0,0,24,0">
                    <TextBlock Text="PASSED" 
                               FontSize="11" 
                               FontWeight="Bold"
                               Foreground="{StaticResource TextTertiaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding PassedCount}" 
                                   FontSize="28" 
                                   FontWeight="Bold"
                                   Foreground="{StaticResource SuccessBrush}"/>
                        <Icons:PackIconMaterial Kind="CheckCircle" 
                                                Width="20" Height="20"
                                                Foreground="{StaticResource SuccessBrush}"
                                                VerticalAlignment="Center"
                                                Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Failed Count -->
                <StackPanel Grid.Column="4">
                    <TextBlock Text="FAILED" 
                               FontSize="11" 
                               FontWeight="Bold"
                               Foreground="{StaticResource TextTertiaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding FailedCount}" 
                                   FontSize="28" 
                                   FontWeight="Bold"
                                   Foreground="#DC3545"/>
                        <Icons:PackIconMaterial Kind="CloseCircle" 
                                                Width="20" Height="20"
                                                Foreground="#DC3545"
                                                VerticalAlignment="Center"
                                                Margin="8,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- GRADEBOOK DATA GRID -->
        <Border Grid.Row="3" Background="White" Margin="32,24,32,32" 
                CornerRadius="16" Padding="0">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.08"/>
            </Border.Effect>

            <DataGrid x:Name="dgGradebook" 
                      ItemsSource="{Binding ResultsView}"
                      SelectedItem="{Binding SelectedResult}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      RowHeight="64"
                      Background="Transparent"
                      BorderThickness="0"
                      HorizontalGridLinesBrush="#F0F0F0">
                
                <DataGrid.Columns>
                    <!-- Status Indicator -->
                    <DataGridTemplateColumn Width="20" 
                                            IsReadOnly="True" 
                                            HeaderStyle="{StaticResource ModernDataGridColumnHeader}" 
                                            CellStyle="{StaticResource ModernDataGridCell}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource StatusIndicator}"
                                        Background="{Binding StatusColor}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Student Info -->
                    <DataGridTemplateColumn Header="Student" 
                                            Width="2*" 
                                            IsReadOnly="True"
                                            CellStyle="{StaticResource ModernDataGridCell}"
                                            HeaderStyle="{StaticResource ModernDataGridColumnHeader}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Margin="8,4">
                                    <TextBlock Text="{Binding StudentName}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding StudentNumber}"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Assessment Name -->
                    <DataGridTextColumn Header="Assessment" 
                                        Binding="{Binding AssessmentName}"
                                        HeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                        CellStyle="{StaticResource ModernDataGridCell}"
                                        Width="1.5*"
                                        IsReadOnly="True"
                                        FontSize="13"/>

                    <!-- Marks Obtained (EDITABLE) -->
                    <DataGridTemplateColumn Header="Marks Obtained" Width="140"
                                            HeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                            CellStyle="{StaticResource ModernDataGridCell}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock FontSize="16" FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MarksObtained}" Value="{x:Null}">
                                                        <Setter Property="Text" Value="—"/>
                                                        <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                        <Run Text="{Binding MarksObtained, StringFormat='{}{0:F1}', Mode=OneWay}"/>
                                        <Run Text="/" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <Run Text="{Binding TotalMarks}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding MarksObtained, UpdateSourceTrigger=LostFocus}"
                                         FontSize="16"
                                         FontWeight="Bold"
                                         TextAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         BorderThickness="2"
                                         BorderBrush="{StaticResource PrimaryBrush}"
                                         Background="#FFFEF7"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Percentage -->
                    <DataGridTemplateColumn Header="Percentage" 
                                            Width="110" 
                                            IsReadOnly="True"
                                            HeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                            CellStyle="{StaticResource ModernDataGridCell}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Percentage}" 
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Grade -->
                    <DataGridTemplateColumn Header="Grade" 
                                            Width="80" 
                                            IsReadOnly="True"
                                            HeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                            CellStyle="{StaticResource ModernDataGridCell}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource GradeBadge}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Grade}" Value="A+">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Grade}" Value="A">
                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Grade}" Value="B+">
                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Grade}" Value="B">
                                                    <Setter Property="Background" Value="#E3F2FD"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Grade}" Value="C+">
                                                    <Setter Property="Background" Value="#FFF9C4"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Grade}" Value="C">
                                                    <Setter Property="Background" Value="#FFF9C4"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Grade}" Value="D">
                                                    <Setter Property="Background" Value="#FFE0B2"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Grade}" Value="F">
                                                    <Setter Property="Background" Value="#FFEBEE"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Grade}" 
                                               FontSize="14"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Grade}" Value="A+">
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Grade}" Value="A">
                                                        <Setter Property="Foreground" Value="#388E3C"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Grade}" Value="B+">
                                                        <Setter Property="Foreground" Value="#1565C0"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Grade}" Value="B">
                                                        <Setter Property="Foreground" Value="#1976D2"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Grade}" Value="C+">
                                                        <Setter Property="Foreground" Value="#F57F17"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Grade}" Value="C">
                                                        <Setter Property="Foreground" Value="#F9A825"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Grade}" Value="D">
                                                        <Setter Property="Foreground" Value="#EF6C00"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Grade}" Value="F">
                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Status (EDITABLE DROPDOWN) -->
                    <DataGridComboBoxColumn Header="Status" 
                                            HeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                            CellStyle="{StaticResource ModernDataGridCell}"
                                            Width="140"
                                            SelectedItemBinding="{Binding Status}">
                        <DataGridComboBoxColumn.ElementStyle>
                            <Style TargetType="ComboBox">
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="Passed">
                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                        <Setter Property="Foreground" Value="#DC3545"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Pending">
                                        <Setter Property="Foreground" Value="#FFA500"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="Absent">
                                        <Setter Property="Foreground" Value="#6C757D"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridComboBoxColumn.ElementStyle>
                        <DataGridComboBoxColumn.EditingElementStyle>
                            <Style TargetType="ComboBox">
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridComboBoxColumn.EditingElementStyle>
                    </DataGridComboBoxColumn>

                    <!-- Feedback (EDITABLE) -->
                    <DataGridTemplateColumn Header="Feedback" HeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                                            CellStyle="{StaticResource ModernDataGridCell}" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Feedback}" 
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           Margin="8,0"
                                           TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Feedback, UpdateSourceTrigger=LostFocus}"
                                         FontSize="12"
                                         VerticalContentAlignment="Center"
                                         BorderThickness="2"
                                         BorderBrush="{StaticResource PrimaryBrush}"
                                         Background="#FFFEF7"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Date -->
                    <DataGridTemplateColumn Header="Date" HeaderStyle="{StaticResource ModernDataGridColumnHeader}" CellStyle="{StaticResource ModernDataGridCell}" Width="120" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding AssessmentDate, StringFormat='{}{0:MMM dd, yyyy}'}" 
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                
            </DataGrid>
        </Border>
    </Grid>
</Page>
