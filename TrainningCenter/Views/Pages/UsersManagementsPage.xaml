<Page x:Class="TrainningCenter.Pages.UsersManagementsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TrainningCenter.Pages"
      xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
      mc:Ignorable="d" 
      d:DesignHeight="690" d:DesignWidth="1030" 
      Background="#F5F7FA"
      Title="UsersManagementsPage">

    <Page.Resources>
        <!--Card Style-->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="0" Opacity=".08" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#8147E7" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="20 12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#9A5FF0"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#6F3DC0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#F0EDFF"/>
            <Setter Property="Foreground" Value="#8147E7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0DAFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Icon Button Style -->
        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Delete Button Style -->
        <Style x:Key="DeleteButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFE5E5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        Margin="{TemplateBinding Padding}"
                                        VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#8147E7"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#B8A3E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Modern ComboBox Style -->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                    Content="{TemplateBinding SelectionBoxItem}"
                                                    Margin="{TemplateBinding Padding}"
                                                    VerticalAlignment="Center"/>
                                    <ToggleButton Grid.Column="1"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Width="30"
                                                Focusable="False"
                                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                ClickMode="Press">
                                        <Icons:PackIconMaterial Kind="ChevronDown" 
                                                              Width="18" 
                                                              Height="18"
                                                              Foreground="#666666"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True">
                                <Border Background="White"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Margin="0,5,0,0"
                                        Style="{StaticResource CardStyle}">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#8147E7"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#B8A3E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Badge Styles -->
        <Style x:Key="ActiveBadge" TargetType="Border">
            <Setter Property="Background" Value="#E7F6EC"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>
        <Style x:Key="InactiveBadge" TargetType="Border">
            <Setter Property="Background" Value="#FFE5E5"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>
        <Style x:Key="RoleBadge" TargetType="Border">
            <Setter Property="Background" Value="#F0EDFF"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,4"/>
        </Style>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!--HEADER SECTION-->
        <Grid Grid.Row="0" Margin="0, 0, 0, 25">
            <StackPanel>
                <TextBlock Text="Users Management"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#202020"/>
                <TextBlock Text="Manage system users, roles and permissions"
                           FontSize="14"
                           Foreground="#666"
                           Margin="0, 5, 0, 0"/>
            </StackPanel>

            <Button Style="{StaticResource PrimaryButton}"
                    HorizontalAlignment="Right"
                    x:Name="btnAddUser"
                    Click="btnAddUser_Click">
                <StackPanel Orientation="Horizontal">
                    <Icons:PackIconMaterial Kind="AccountPlus"
                                            Width="18" Height="18"
                                            Margin="0, 0, 8, 0"/>
                    <TextBlock Text="Add New User" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>
        
        <!--SEARCH AND FILTER SECTION-->
        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}"
                Margin="0, 0, 0, 20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!--SEARCH BOX-->
                <Border Grid.Column="0"
                        Background="#F8F9FA"
                        CornerRadius="8"
                        Margin="0, 0, 15, 0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Icons:PackIconMaterial Kind="Magnify"
                                                Grid.Column="0"
                                                Width="20"
                                                Height="20"
                                                Foreground="#999"
                                                Margin="12, 0, 0, 0"
                                                VerticalAlignment="Center"/>

                        <TextBox Grid.Column="1"
                                 Name="txtSearch"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="10 10"
                                 FontSize="14"
                                 VerticalContentAlignment="Center"
                                 TextChanged="txtSearch_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Foreground" Value="#202020"/>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None" AlignmentX="Left">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="Search users..." 
                                                                     Foreground="#999999" 
                                                                     FontSize="14"
                                                                     Margin="5,0,0,0"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </Border>
                
                <!--ROLE FILTER-->
                <ComboBox Grid.Column="1"
                          x:Name="cmbRoleFilter"
                          Style="{StaticResource ModernComboBox}"
                          Margin="0, 0, 15, 0"
                          SelectionChanged="cmbRoleFilter_SelectionChanged">

                    <ComboBoxItem Content="Student" IsSelected="True"/>
                    <ComboBoxItem Content="Admin"/>
                    <ComboBoxItem Content="Trainer"/>
                    <ComboBoxItem Content="Receptionist"/>
                    <ComboBoxItem Content="Manager"/>
                </ComboBox>
                
                <!--STATUS FILTER-->
                <ComboBox Grid.Column="2"
                          x:Name="cmbStatusFilter"
                          Style="{StaticResource ModernComboBox}"
                          Margin="0, 0, 15, 0"
                          SelectionChanged="cmbStatusFilter_SelectionChanged">

                    <ComboBoxItem Content="Active" IsSelected="True"/>
                    <ComboBoxItem Content="Inactive"/>
                </ComboBox>
                
                <!--REFRESH BUTTON-->
                <Button Grid.Column="3"
                        Style="{StaticResource SecondaryButton}"
                        Padding="12"
                        Name="btnRefresh"
                        Click="btnRefresh_Click">
                    <Icons:PackIconMaterial Kind="Refresh"
                                            Width="20"
                                            Height="20"/>
                </Button>
            </Grid>
        </Border>
        
        <!--USERS DATA GRID SECTION-->
        <Border Grid.Row="2"
                Style="{StaticResource CardStyle}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <DataGrid x:Name="dgUsers"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          SelectionMode="Single"
                          Background="Transparent"
                          BorderThickness="0"
                          RowHeight="70"
                          FontSize="14">
                    <DataGrid.Resources>
                        <!--HEADER STYLE-->
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8F9FA"/>
                            <Setter Property="Foreground" Value="#666666"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="15,12"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        </Style>
                        
                        <!--ROW STYLE-->
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#F0F0F0"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F8F9FA"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#F0EDFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>

                        <!--CELL STYLE-->
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="15,0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="{TemplateBinding Background}" 
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#202020"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <!--USER INFO COLUMN-->
                        <DataGridTemplateColumn Header="User" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="44" Height="44"
                                                CornerRadius="10"
                                                BorderThickness="2"
                                                BorderBrush="#8147E7">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0, 0" EndPoint="1, 1">
                                                    <GradientStop Color="#8147E7" Offset="0" />
                                                    <GradientStop Color="#A980F5" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="{Binding Initials}"
                                                       Foreground="White"
                                                       FontWeight="Bold"
                                                       FontSize="16"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Margin="12, 0, 0, 0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Username}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       Foreground="#202020"/>
                                            <TextBlock Text="{Binding Phone}"
                                                       FontSize="12" 
                                                       Foreground="#999"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <!--ROLE COLUMN-->
                        <DataGridTemplateColumn Header="Role" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource RoleBadge}">
                                        <StackPanel Orientation="Horizontal">
                                            <Icons:PackIconMaterial Kind="ShieldAccount"
                                                                    Width="14"
                                                                    Height="14"
                                                                    Foreground="#8147E7"
                                                                    Margin="0,0,6,0"
                                                                    VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding RoleName}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12"
                                                       Foreground="#8147E7"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <!--STATUS COLUMN-->
                        <DataGridTemplateColumn Header="Status" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="#E7F6EC"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                        <Setter Property="Background" Value="#FFE5E5"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                                <Setter Property="CornerRadius" Value="12"/>
                                                <Setter Property="Padding" Value="10,4"/>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Fill" Value="#28A745"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                <Setter Property="Fill" Value="#DC3545"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Text" Value="Active"/>
                                                                <Setter Property="Foreground" Value="#28A745"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                <Setter Property="Text" Value="Inactive"/>
                                                                <Setter Property="Foreground" Value="#DC3545"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <!--CREATED DATE COLUMN-->
                        <DataGridTemplateColumn Header="Created" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:MMM dd, yyyy}'}" 
                                               Foreground="#999999" 
                                               FontSize="13"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <!--ACTIONS COLUMN-->
                        <DataGridTemplateColumn Header="Actions" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Style="{StaticResource IconButton}"
                                                Margin="0,0,5,0"
                                                Name="btnEdit"
                                                Click="btnEdit_Click"
                                                Tag="{Binding UserId}">
                                            <Icons:PackIconMaterial Kind="Pencil"
                                                                    Width="18"
                                                                    Height="18"
                                                                    Foreground="#8147E7"/>
                                        </Button>

                                        <Button x:Name="btnDelete"
                                                Style="{StaticResource DeleteButton}"
                                                Tag="{Binding UserId}"
                                                Click="btnDelete_Click">
                                            <Icons:PackIconMaterial Kind="Delete" 
                                                                  Width="18" 
                                                                  Height="18" 
                                                                  Foreground="#DC3545"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
