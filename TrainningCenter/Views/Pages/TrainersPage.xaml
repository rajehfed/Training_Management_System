<Page x:Class="TrainningCenter.Views.Pages.TrainersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TrainningCenter.Views.Pages"
      xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
      xmlns:UC="clr-namespace:TrainningCenter.UserControles.Groups"
      xmlns:UC1="clr-namespace:TrainningCenter.UserControles"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1400"
      Title="TrainersPage"
      Background="{StaticResource PageBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--
        ═══════════════════════════════════════════════════════════════════════════
            HEADER SECTION
                Title, Subtitle
                Action Button
        ═══════════════════════════════════════════════════════════════════════════
        -->
        <Border Grid.Row="0"
                Background="{StaticResource CardBackgroundBrush}"
                Padding="32,24"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0 0 0 1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!--TITLE-->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Trainers Management"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Manage instructor profiles, specializations, and schedules"
                               FontSize="14"
                               Margin="0 6 0 0"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <!--ACTION BUTTONS-->
                <StackPanel Orientation="Horizontal"
                            Grid.Column="1"
                            VerticalAlignment="Center">
                    <Button x:Name="btnRefresh"
                            Click="btnRefresh_Click"
                            ToolTip="Refresh Trainers"
                            Style="{StaticResource RefreshButton}"
                            Margin="0 0 12 0">
                        <Icons:PackIconMaterial Kind="Refresh" 
                                                Width="18" 
                                                Height="18"
                                                Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>

                    <Button Style="{StaticResource OutlineButton}"
                            Content="Export"
                            Name="btnExport"
                            Click="btnExport_Click"
                            Padding="20 11"
                            Margin="0 0 12 0">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Kind="Download" 
                                                            Width="16" 
                                                            Height="16"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,8,0"/>
                                    <TextBlock Text="Export" 
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>

                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Add New Trainer"
                            Name="btnAddTrainer"
                            Click="btnAddTrainer_Click"
                            Padding="24,13">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Kind="AccountPlus" 
                                                            Width="16" 
                                                            Height="16"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,8,0"/>
                                    <TextBlock Text="Add New Trainer" 
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--
        ═══════════════════════════════════════════════════════════════════════════
            STATISTICS CARDS
                Total Trainers, 
                Active Trainers, 
                Available Today,
                On Leave
        ═══════════════════════════════════════════════════════════════════════════
        -->
        <Grid Grid.Row="1" Margin="32 24 32 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!--TOTAL TRAINERS-->
            <UC:StatCard Label="Total Trainers"
                         Value="{Binding TotalTrainers}" 
                         IconKind="AccountTie"
                         IconBrush="{StaticResource PrimaryBrush}"
                         BackgroudBrush="{StaticResource PrimaryUltraLightBrush}"
                         Margin="0 0 12 0"/>

            <!--ACTIVE TRAINERS-->
            <UC:StatCard Grid.Column="1" 
                         Label="Active Trainers"
                         Value="{Binding ActiveTrainers}" 
                         IconKind="CheckCircle"
                         IconBrush="{StaticResource SuccessBrush}"
                         BackgroudBrush="{StaticResource SuccessLightBrush}"
                         Margin="0 0 12 0"/>

            <!--AVAILABLE TODAY-->
            <UC:StatCard Grid.Column="2" 
                         Label="Available Today"
                         Value="{Binding AvailableToday}" 
                         IconKind="CalendarCheck"
                         IconBrush="{StaticResource InfoBrush}"
                         BackgroudBrush="{StaticResource InfoLightBrush}"
                         Margin="0 0 12 0"/>

            <!--ON LEAVE-->
            <UC:StatCard Grid.Column="3" 
                         Label="On Leave"
                         Value="{Binding OnLeave}" 
                         IconKind="ClockAlert"
                         IconBrush="{StaticResource WarningBrush}"
                         BackgroudBrush="{StaticResource WarningLightBrush}"
                         Margin="0 0 12 0"/>
        </Grid>

        <!--
        ═══════════════════════════════════════════════════════════════════════════
            MAIN CONTENT - FILTERS & DATA GRID
        ═══════════════════════════════════════════════════════════════════════════
        -->
        <Border Grid.Row="2"
                Style="{StaticResource CardStyle}"
                Margin="32,24,32,32">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!--EMPTY OVERLAY-->
                <UC1:ctrlEmptyStateOverlay x:Name="ctrlEmpltyOverlay" 
                                           Grid.Row="1" 
                                           Visibility="Collapsed" />

                <!--FILTERS & SEARCH BAR-->
                <Grid Grid.Row="0" Margin="0 0 0 20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!--SEARCH BOX-->
                    <Border Grid.Column="0"
                            Background="{StaticResource InputBackgroundBrush}"
                            CornerRadius="10"
                            MaxHeight="400"
                            HorizontalAlignment="Left">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Icons:PackIconMaterial Grid.Column="0"
                                                    Kind="Magnify"
                                                    Width="18"
                                                    Height="18"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    VerticalAlignment="Center"
                                                    Margin="16,0,0,0"/>
                            <TextBox x:Name="txtSearchBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SearchTextBox}"
                                     TextChanged="txtSearchBox_TextChanged"
                                     Tag="Search by name, email, or specialization..."
                                     MinWidth="300"/>
                        </Grid>
                    </Border>

                    <!--STATUS FILTER-->
                    <ComboBox Name="cmbStatusFilter"
                              Grid.Column="1"
                              Style="{StaticResource ModernComboBox}"
                              Width="180"
                              Margin="12 0 0 0"
                              SelectionChanged="cmbStatusFilter_SelectionChanged">
                        <ComboBoxItem Content="All Status" Style="{StaticResource ModernComboBoxItem}"/>
                        <ComboBoxItem Content="Active" Style="{StaticResource ModernComboBoxItem}"/>
                        <ComboBoxItem Content="On Leave" Style="{StaticResource ModernComboBoxItem}"/>
                        <ComboBoxItem Content="Inactive" Style="{StaticResource ModernComboBoxItem}"/>
                    </ComboBox>

                    <!--SPECIALIZATION FILTER-->
                    <ComboBox x:Name="cmbSpecializationFilter"
                              Grid.Column="2"
                              Style="{StaticResource ModernComboBox}"
                              Width="180"
                              Margin="12 0 0 0"
                              SelectionChanged="cmbSpecializationFilter_SelectionChanged">
                        <ComboBoxItem Content="All Specializations" Style="{StaticResource ModernComboBoxItem}"/>
                    </ComboBox>

                    <!--SORT BY-->
                    <ComboBox Name="cmbSortBy"
                              Grid.Column="3"
                              Style="{StaticResource ModernComboBox}"
                              Width="180"
                              Margin="12 0 0 0"
                              SelectionChanged="cmbSortBy_SelectionChanged">
                        <ComboBoxItem Content="Sort by Name" Style="{StaticResource ModernComboBoxItem}"/>
                        <ComboBoxItem Content="Sort by Experience" Style="{StaticResource ModernComboBoxItem}"/>
                        <ComboBoxItem Content="Sort by Rating" Style="{StaticResource ModernComboBoxItem}"/>
                        <ComboBoxItem Content="Sort by Hire Date" Style="{StaticResource ModernComboBoxItem}"/>
                    </ComboBox>
                </Grid>

                <!--DATA GRID-->
                <DataGrid x:Name="dgTrainers"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          Background="Transparent"
                          BorderThickness="0"
                          RowStyle="{StaticResource ModernDataGridRow}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                          CellStyle="{StaticResource ModernDataGridCell}">
                    <DataGrid.Columns>
                        <!--TRAINER INFO (Avatar + Name + Specialization)-->
                        <DataGridTemplateColumn Header="TRAINER" Width="2*" MinWidth="280">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <!--AVATAR-->
                                        <Border Width="40" Height="40"
                                                CornerRadius="20"
                                                Background="{StaticResource InfoLightBrush}"
                                                Margin="0 0 12 0">
                                            <TextBlock Text="{Binding Initials}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource InfoBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!--NAME & SPECIALIZATION-->
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FullName}"
                                                       Style="{StaticResource DataGridTextBold}"/>
                                            <TextBlock Text="{Binding Specialization}"
                                                       Style="{StaticResource DataGridTextMuted}"
                                                       Margin="0 2 0 0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--EMAIL-->
                        <DataGridTemplateColumn Header="EMAIL" Width="*" MinWidth="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Email}"
                                               Style="{StaticResource DataGridTextRegular}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--PHONE-->
                        <DataGridTemplateColumn Header="PHONE" Width="*" MinWidth="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Phone}"
                                               Style="{StaticResource DataGridTextRegular}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--GROUPS COUNT-->
                        <DataGridTemplateColumn Header="GROUPS" Width="Auto" MinWidth="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="{StaticResource PrimaryPaleBrush}"
                                                CornerRadius="8"
                                                Padding="8,4">
                                            <TextBlock FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryBrush}">
                                                <Run Text="{Binding GroupsCount}"/>
                                                <Run Text="Groups"/>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--HIRE DATE-->
                        <DataGridTemplateColumn Header="HIRED" Width="*" MinWidth="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding HireDate, StringFormat='{}{0:dd MMM yyyy}'}"
                                               Style="{StaticResource DataGridTextMuted}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--STATUS-->
                        <DataGridTemplateColumn Header="STATUS" Width="*" MinWidth="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12"
                                            Padding="10,5"
                                            HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DisplayStatus}" Value="Active">
                                                        <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DisplayStatus}" Value="On Leave">
                                                        <Setter Property="Background" Value="{StaticResource WarningLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DisplayStatus}" Value="Inactive">
                                                        <Setter Property="Background" Value="{StaticResource DangerLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <TextBlock FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding DisplayStatus, Converter={StaticResource UpperCaseConverter}}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DisplayStatus}" Value="Active">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DisplayStatus}" Value="On Leave">
                                                            <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding DisplayStatus}" Value="Inactive">
                                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--ACTIONS-->
                        <DataGridTemplateColumn Header="ACTIONS" Width="Auto" MinWidth="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <!--VIEW BUTTON-->
                                        <Button Style="{StaticResource IconButton}"
                                                ToolTip="View Details"
                                                Name="btnViewInfo"
                                                Click="btnViewInfo_Click"
                                                Tag="{Binding TrainerID}"
                                                Margin="0 0 4 0">
                                            <Icons:PackIconMaterial Kind="Eye"
                                                                    Width="16"
                                                                    Height="16"
                                                                    Foreground="{StaticResource InfoBrush}"/>
                                        </Button>

                                        <!--EDIT BUTTON-->
                                        <Button Style="{StaticResource IconButtonEdit}"
                                                ToolTip="Edit Trainers"
                                                Name="btnEdit"
                                                Click="btnEdit_Click"
                                                Tag="{Binding TrainerID}"
                                                Margin="0 0 4 0">
                                            <Icons:PackIconMaterial Kind="Pencil"
                                                                    Width="16"
                                                                    Height="16"
                                                                    Foreground="{StaticResource PrimaryBrush}"/>
                                        </Button>

                                        <!--DELETE BUTTON-->
                                        <Button x:Name="btnDelete"
                                                Style="{StaticResource IconButtonDelete}"
                                                ToolTip="Delete Trainer"
                                                Click="btnDelete_Click"
                                                Tag="{Binding TrainerID}">
                                            <Icons:PackIconMaterial Kind="Delete"
                                                                    Width="16"
                                                                    Height="16"
                                                                    Foreground="{StaticResource DangerBrush}"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!--PAGINATION-->
                <Grid Grid.Row="2" Margin="0 20 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!--RESULTS INFO-->
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center">
                        <Run Text="Showing"/>
                        <Run Text="{Binding ElementName=dgTrainers, Path=Items.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text="of"/>
                        <Run x:Name="runTotalCount" Text="24" FontWeight="SemiBold"/>
                        <Run Text="trainers"/>
                    </TextBlock>

                    <!--PAGINATION CONTROLS-->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource SecondaryButton}"
                                Content="Previous"
                                Name="btnPrevious"
                                Click="btnPrevious_Click"
                                Padding="16,10"
                                MinWidth="100"
                                Margin="0 0 8 0" />
                        <Border Background="{StaticResource InputBackgroundBrush}"
                                    CornerRadius="10"
                                    Padding="16,10"
                                    Margin="0 0 8 0">
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="Page"/>
                                <Run x:Name="runCurrentPage" Text="1" FontWeight="SemiBold"/>
                                <Run Text="of"/>
                                <Run x:Name="runTotalPages" Text="1" FontWeight="SemiBold"/>
                            </TextBlock>
                        </Border>
                        
                        <Button Content="Next"
                                Style="{StaticResource SecondaryButton}"
                                Name="btnNext"
                                Click="btnNext_Click"
                                Padding="16,10"
                                MinWidth="100"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
