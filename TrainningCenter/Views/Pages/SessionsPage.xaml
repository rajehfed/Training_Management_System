<Page x:Class="TrainningCenter.Views.Pages.SessionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TrainningCenter.Views.Pages"
      xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
      xmlns:UC="clr-namespace:TrainningCenter.UserControles.Groups"
      mc:Ignorable="d"
      Background="{StaticResource PageBackgroundBrush}"
      d:DesignHeight="800" d:DesignWidth="1400"
      Title="Sessions">

    <Page.Resources>
        <!-- Session Card Style -->
        <Style x:Key="SessionCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#8147E7"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#8147E7" BlurRadius="20" ShadowDepth="0" Opacity="0.2"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Quick Action Button -->
        <Style x:Key="QuickActionButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0EDFF"/>
                    <Setter Property="BorderBrush" Value="#8147E7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32">
            <Grid MaxWidth="1400">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER SECTION -->
                <Grid Grid.Row="0" Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Title & Breadcrumb -->
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Icons:PackIconMaterial Kind="BookmarkBoxMultiple" 
                                                    VerticalAlignment="Center"
                                                    Height="32" Width="32"
                                                    Margin="0 0 10 0"/>
                            <TextBlock Text="Sessions | Attendance"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <TextBlock Text="Manage training sessions and track student attendance"
                                   FontSize="15"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="btnRefresh"
                                Style="{StaticResource RefreshButton}"
                                Click="btnRefresh_Click"
                                Margin="0,0,12,0"
                                ToolTip="Refresh Data">
                            <Icons:PackIconMaterial Kind="Refresh"
                                                    Width="20" Height="20"
                                                    Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Button>

                        <Button x:Name="btnNewSession"
                                Style="{StaticResource PrimaryButton}"
                                Click="btnNewSession_Click"
                                Padding="24,12"
                                FontSize="14">
                            <StackPanel Orientation="Horizontal">
                                <Icons:PackIconMaterial Kind="Plus" 
                                                        Width="20" 
                                                        Height="20" 
                                                        Margin="0,0,10,0"/>
                                <TextBlock Text="New Session" 
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- STATS CARDS -->
                <Grid Grid.Row="1" Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Today's Sessions -->
                    <UC:StatCard BackgroudBrush="{StaticResource PrimaryUltraLightBrush}"
                                 IconKind="CalendarToday"
                                 IconBrush="{StaticResource PrimaryBrush}"
                                 Label="Today's Sessions"
                                 Value="{Binding TodaySessions, Mode=OneWay}"
                                 Margin="0 0 16 0"/>
                    <!-- Total Attendance -->
                    <UC:StatCard Grid.Column="1" 
                                 BackgroudBrush="{StaticResource SuccessLightBrush}"
                                 IconKind="AccountCheck"
                                 IconBrush="{StaticResource SuccessBrush}"
                                 Label="Attendace Rate"
                                 Value="{Binding AttendanceRate, Mode=OneWay}"
                                 Margin="0 0 16 0"/>
                    <!-- Completed Sessions -->
                    <UC:StatCard Grid.Column="2" 
                                 BackgroudBrush="{StaticResource InfoLightBrush}"
                                 IconKind="CheckCircle"
                                 IconBrush="{StaticResource InfoBrush}"
                                 Label="Completed"
                                 Value="{Binding CompletedSessions, Mode=OneWay}"
                                 Margin="0 0 16 0"/>
                    <!-- Upcoming Sessions -->
                    <UC:StatCard Grid.Column="3" 
                                 BackgroudBrush="{StaticResource WarningLightBrush}"
                                 IconKind="ClockOutline"
                                 IconBrush="{StaticResource WarningBrush}"
                                 Label="Upcoming"
                                 Value="{Binding UpcomingSessions, Mode=OneWay}"
                                 Margin="0 0 16 0"/>
                </Grid>

                <!-- FILTERS & SEARCH -->
                <Grid Grid.Row="2" Margin="0 0 0 24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search Box -->
                    <Border Grid.Column="0"
                            Padding="10"
                            Background="White"
                            CornerRadius="12"
                            Margin="0 0 16 0">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="0" Opacity="0.06"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Icons:PackIconMaterial Grid.Column="0"
                                                    Kind="Magnify"
                                                    Width="20" Height="20"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Margin="16,0,12,0"
                                                    VerticalAlignment="Center"/>

                            <TextBox x:Name="txtSearch"
                                     Margin="0 0 18 0"
                                     Grid.Column="1"
                                     Style="{StaticResource ModernTextBox}"
                                     Tag="Search sessions by group, trainer, topic..."
                                     TextChanged="txtSearch_TextChanged"/>

                            <Button x:Name="btnClearSearch"
                                    Click="btnClearSearch_Click"
                                    Grid.Column="2"
                                    Style="{StaticResource IconButton}"
                                    Visibility="Collapsed"
                                    Margin="0 0 8 0">
                                <Icons:PackIconMaterial Kind="Close"
                                                        Width="18" Height="18"
                                                        Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Filter Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <!-- Date Filter -->
                        <Border Background="White"
                                MouseLeftButtonDown="btnDateFilter_MouseLeftButtonDown"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="2"
                                CornerRadius="12"
                                Padding="16,12"
                                Margin="0,0,12,0"
                                Cursor="Hand"
                                x:Name="btnDateFilter">
                            <StackPanel Orientation="Horizontal">
                                <Icons:PackIconMaterial Kind="CalendarRange"
                                                        Width="18" Height="18"
                                                        Foreground="{StaticResource TextSecondaryBrush}"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0"/>
                                <TextBlock x:Name="tbDateFilter"
                                           Text="Today"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Status Filter -->
                        <Border Background="White"
                                MouseLeftButtonDown="btnStatusFilter_MouseLeftButtonDown"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="2"
                                CornerRadius="12"
                                Padding="16,12"
                                Cursor="Hand"
                                x:Name="btnStatusFilter">
                            <StackPanel Orientation="Horizontal">
                                <Icons:PackIconMaterial Kind="FilterVariant"
                                                        Width="18" Height="18"
                                                        Foreground="{StaticResource TextSecondaryBrush}"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0"/>
                                <TextBlock x:Name="tbStatusFilter"
                                           Text="All Status"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- SESSIONS LIST -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Sessions Cards -->
                    <ScrollViewer Grid.Column="0"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="0,0,16,0">
                        <ItemsControl x:Name="sessionsListControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource SessionCard}"
                                            Name="SessionCard"
                                            MouseLeftButtonDown="SessionCard_MouseLeftButtonDown"
                                            Tag="{Binding SessionID}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Time Badge -->
                                            <Border Grid.Column="0"
                                                    CornerRadius="14"
                                                    Padding="20,16"
                                                    Margin="0 0 20 0"
                                                    Width="100"
                                                    VerticalAlignment="Top">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#8147E7" Offset="0"/>
                                                        <GradientStop Color="#A980F5" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>

                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="{Binding SessionDate, StringFormat='{}{0:MMM}'}"
                                                               FontSize="12"
                                                               FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               Opacity="0.9"/>
                                                    <TextBlock Text="{Binding SessionDate, StringFormat='{}{0:dd}'}"
                                                               FontSize="28"
                                                               FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,4,0,0"/>
                                                    <TextBlock Text="{Binding StartTime, StringFormat='{}{0:HH:mm}'}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               Opacity="0.9"
                                                               Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Session Info -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <!-- Topic -->
                                                <TextBlock Text="{Binding Topic}"
                                                           FontSize="18"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <!-- Group Name -->
                                                <Border Background="{StaticResource PrimaryPaleBrush}"
                                                        CornerRadius="6"
                                                        Padding="10,6"
                                                        HorizontalAlignment="Left"
                                                        Margin="0 8 0 0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Icons:PackIconMaterial Kind="AccountGroup"
                                                                                Width="14" Height="14"
                                                                                Foreground="{StaticResource PrimaryBrush}"
                                                                                VerticalAlignment="Center"
                                                                                Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding GroupName}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource PrimaryBrush}"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Details -->
                                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                                    <!-- Trainer -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                                                        <Icons:PackIconMaterial Kind="AccountTie"
                                                                                Width="16" Height="16"
                                                                                Foreground="{StaticResource TextTertiaryBrush}"
                                                                                VerticalAlignment="Center"
                                                                                Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding TrainerName}"
                                                                   FontSize="13"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>

                                                    <!-- Duration -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,24,0">
                                                        <Icons:PackIconMaterial Kind="ClockOutline"
                                                                                Width="16" Height="16"
                                                                                Foreground="{StaticResource TextTertiaryBrush}"
                                                                                VerticalAlignment="Center"
                                                                                Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding Duration}"
                                                                   FontSize="13"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>

                                                    <!-- Location -->
                                                    <StackPanel Orientation="Horizontal">
                                                        <Icons:PackIconMaterial Kind="MapMarker"
                                                                                Width="16" Height="16"
                                                                                Foreground="{StaticResource TextTertiaryBrush}"
                                                                                VerticalAlignment="Center"
                                                                                Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding Location}"
                                                                   FontSize="13"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Status & Actions -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="20,0,0,0">
                                                <!-- Attendance Progress -->
                                                <Border Background="{StaticResource PageBackgroundBrush}"
                                                        CornerRadius="12"
                                                        Padding="16 12"
                                                        Margin="0 0 0 12">
                                                    <StackPanel>
                                                        <TextBlock Text="ATTENDANCE"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Foreground="{StaticResource TextTertiaryBrush}"
                                                                   HorizontalAlignment="Center"/>
                                                        <TextBlock FontSize="22"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"
                                                                   Margin="0,6,0,0">
                                                            <Run Text="{Binding PresentCount}" Foreground="{StaticResource SuccessBrush}"/>
                                                            <Run Text="/" Foreground="{StaticResource TextTertiaryBrush}"/>
                                                            <Run Text="{Binding TotalStudents}" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Status Badge -->
                                                <Border Background="{Binding StatusColor}"
                                                        CornerRadius="8"
                                                        Padding="12,8"
                                                        Opacity="0.15"
                                                        Margin="0,0,0,12">
                                                    <TextBlock Text="{Binding Status}"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               Foreground="{Binding StatusColor}"
                                                               HorizontalAlignment="Center"/>
                                                </Border>

                                                <!-- Take Attendance Button -->
                                                <Button Style="{StaticResource PrimaryButton}"
                                                        Padding="16,10"
                                                        FontSize="13"
                                                        x:Name="btnTakeAttendance"
                                                        Click="btnTakeAttendance_Click"
                                                        Tag="{Binding SessionID}">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <Icons:PackIconMaterial Kind="NotebookEdit" 
                                                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                Width="22" Height="22"
                                                                                Foreground="{StaticResource PrimaryPaleBrush}"/>
                                                        <TextBlock Margin="5 0 0 0" Text="Attendance"
                                                                   Foreground="{StaticResource PrimaryPaleBrush}"
                                                                   FontSize="14"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>


                    <Border x:Name="emptyState"
                            Grid.Column="0"
                            Background="White"
                            CornerRadius="16"
                            Padding="60"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center" MaxWidth="400">
                            <Icons:PackIconMaterial Kind="CalendarBlank"
                                                    Width="120" Height="120"
                                                    Foreground="{StaticResource TextTertiaryBrush}"
                                                    HorizontalAlignment="Center"
                                                    Opacity="0.5"
                                                    Margin="0,0,0,24"/>
                            <TextBlock Text="No Sessions Found"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Create your first training session to get started"
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Margin="0,12,0,24"
                                       TextWrapping="Wrap"/>
                            <Button Content="➕ Create First Session"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="btnNewSession_Click"
                                    Padding="32,16"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Right: Quick Actions Panel -->
                    <Border Grid.Column="1"
                            Background="White"
                            CornerRadius="16"
                            Padding="24"
                            VerticalAlignment="Top">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.08"/>
                        </Border.Effect>

                        <StackPanel>
                            <TextBlock Text="⚡ Quick Actions"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,20"/>

                            <!-- Quick Stats -->
                            <Border Background="{StaticResource PageBackgroundBrush}"
                                    CornerRadius="12"
                                    Padding="16"
                                    Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="TODAY'S OVERVIEW"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               Margin="0,0,0,12"/>

                                    <Grid Margin="0 0 0 8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="Active Sessions"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ActiveSession, Mode=OneWay}"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryBrush}"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Completed"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding CompletedSessions, Mode=OneWay}"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource SuccessBrush}"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Pending"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding PendingSessions, Mode=OneWay}"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource WarningBrush}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Action Buttons -->
                            <Button x:Name="btnViewCalendar"
                                    Style="{StaticResource QuickActionButton}"
                                    Click="btnViewCalendar_Click"
                                    Margin="0 0 0 12">
                                <StackPanel>
                                    <Icons:PackIconMaterial Kind="CalendarMonth"
                                                            Width="32" Height="32"
                                                            Foreground="{StaticResource PrimaryBrush}"
                                                            HorizontalAlignment="Center"/>
                                    <TextBlock Text="Calendar View"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="btnExportData"
                                    Style="{StaticResource QuickActionButton}"
                                    Click="btnExportData_Click">
                                <StackPanel>
                                    <Icons:PackIconMaterial Kind="Download"
                                                            Width="32" Height="32"
                                                            Foreground="{StaticResource SuccessBrush}"
                                                            HorizontalAlignment="Center"/>
                                    <TextBlock Text="Export Data"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Button>

                            <!-- Tips Section -->
                            <Border Background="{StaticResource InfoLightBrush}"
                                    CornerRadius="12"
                                    Padding="16"
                                    Margin="0,24,0,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Icons:PackIconMaterial Kind="LightbulbOn"
                                                                Width="18" Height="18"
                                                                Foreground="{StaticResource InfoBrush}"
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,8,0"/>
                                        <TextBlock Text="Pro Tip"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource InfoBrush}"/>
                                    </StackPanel>
                                    <TextBlock Text="Click on any session card to view detailed attendance and manage students"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
