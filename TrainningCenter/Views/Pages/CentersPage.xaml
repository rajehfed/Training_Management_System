<Page x:Class="TrainningCenter.Views.Pages.CentersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TrainningCenter.Views.Pages"
      xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
      xmlns:ucCenters ="clr-namespace:TrainningCenter.UserControles.Centers"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1400"
      Title="CentersPage"
      Background="{StaticResource PageBackgroundBrush}">

    <Page.Resources>
        <!-- 1. Grid View "Blueprint" -->
        <DataTemplate x:Key="GridViewTemplate">
            <ucCenters:CenterCard EditClicked="CenterCard_EditClicked" 
                                  DeleteClicked="CenterCard_DeleteClicked"
                                  CardClicked="CenterCard_CardClicked"/>
        </DataTemplate>

        <!-- 2. List View "Blueprint" -->
        <DataTemplate x:Key="ListViewTemplate">
            <ucCenters:CenterListItem EditClicked="CenterListItem_EditClicked"
                                      DeleteClicked="CenterListItem_DeleteClicked"/>
        </DataTemplate>

        <!-- 3. Grid Panel "Layout" -->
        <ItemsPanelTemplate x:Key="GridPanelTemplate">
            <WrapPanel Orientation="Horizontal"/>
        </ItemsPanelTemplate>

        <!-- 4. List Panel "Layout" -->
        <ItemsPanelTemplate x:Key="ListPanelTemplate">
            <StackPanel Orientation="Vertical"/>
        </ItemsPanelTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--
        ═══════════════════════════════════════════════════════════════════════════
            HEADER SECTION
                Page Title & Subtitle
                Actions Buttons (Add New + Refresh)
        ═══════════════════════════════════════════════════════════════════════════
        -->
        <Border Grid.Row="0"
                Background="{StaticResource CardBackgroundBrush}"
                Padding="32,24"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0 0 0 1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!--PAGE TITLE-->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Training Centers" 
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Manage your training center locations and facilities"
                               FontSize="14"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>

                <!--ACTION BUTTONS-->
                <StackPanel Orientation="Horizontal"
                            Grid.Column="1"
                            VerticalAlignment="Center">
                    <Button x:Name="btnRefresh"
                            Style="{StaticResource RefreshButton}"
                            ToolTip="Refresh Centers"
                            Click="btnRefresh_Click"
                            Margin="0 0 12 0">
                        <Icons:PackIconMaterial Kind="Refresh" 
                                                Width="18" 
                                                Height="18"
                                                Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>

                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Add New Center"
                            Name="btnAddNewCenter"
                            Click="btnAddNewCenter_Click"
                            Padding="24,13">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Kind="OfficeBuildingPlus" 
                                                            Width="16" 
                                                            Height="16"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,8,0"/>
                                    <TextBlock Text="Add New Center" 
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--
        ═══════════════════════════════════════════════════════════════════════════
            MAIN CONTENT - CARDS GRID
        ═══════════════════════════════════════════════════════════════════════════
        -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="32,24,32,32">
            <StackPanel>
                <!--SEARCH & FILTER-->
                <Grid Margin="0 0 0 24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!--SEARCH BOX-->
                    <Border Grid.Column="0"
                            Style="{StaticResource ModalCard}"
                            Background="{StaticResource InputBackgroundBrush}"
                            CornerRadius="10"
                            MaxWidth="400"
                            HorizontalAlignment="Left">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Icons:PackIconMaterial Grid.Column="0"
                                                    Kind="Magnify"
                                                    Width="18"
                                                    Height="18"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    VerticalAlignment="Center"
                                                    Margin="16,0,0,0"/>
                            <TextBox x:Name="txtSearchBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SearchTextBox}"
                                     TextChanged="txtSearchBox_TextChanged"
                                     Tag="Search centers by name or city..."
                                     MinWidth="300"/>
                        </Grid>
                    </Border>

                    <!--VIEW TOGGLE-->
                    <Border Grid.Column="1"
                            Background="White"
                            CornerRadius="10"
                            BorderThickness="2"
                            BorderBrush="{StaticResource BorderBrush}"
                            Margin="12 0 0 0">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="btnGridView"
                                    Style="{StaticResource IconButton}"
                                    Click="btnGridView_Click"
                                    ToolTip="Grid View"
                                    Margin="4">
                                <Icons:PackIconMaterial Kind="ViewGrid"
                                                        x:Name="gridIcon"
                                                        Width="18"
                                                        Height="18"
                                                        Foreground="{StaticResource PrimaryBrush}"/>
                            </Button>
                            <Button x:Name="btnListView"
                                    Style="{StaticResource IconButton}"
                                    Click="btnListView_Click"
                                    ToolTip="List View"
                                    Margin="4">
                                <Icons:PackIconMaterial Kind="ViewList"
                                                        x:Name="listIcon"
                                                        Width="18"
                                                        Height="18"
                                                        Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!--STATUS FILTER-->
                    <ComboBox Name="cmbStatusFilter"
                              Grid.Column="2"
                              Style="{StaticResource ModernComboBox}"
                              Width="180"
                              Margin="12 0 0 0"
                              SelectionChanged="cmbStatusFilter_SelectionChanged">
                        <ComboBoxItem Content="All Centers" Style="{StaticResource ModernComboBoxItem}"/>
                        <ComboBoxItem Content="Active" Style="{StaticResource ModernComboBoxItem}"/>
                        <ComboBoxItem Content="Inactive" Style="{StaticResource ModernComboBoxItem}"/>
                    </ComboBox>
                </Grid>

                <!--CENTERS CARDS CONTAINER-->
                <ItemsControl x:Name="centersItemsControl">
                    <!--<ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ucCenters:CenterCard EditClicked="CenterCard_EditClicked" 
                                                  DeleteClicked="CenterCard_DeleteClicked"
                                                  CardClicked="CenterCard_CardClicked"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>-->
                </ItemsControl>

                <Border x:Name="EmptyState"
                        Visibility="Collapsed"
                        Background="White"
                        CornerRadius="16"
                        Padding="60"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <Icons:PackIconMaterial Kind="OfficeBuildingOutline"
                                                Width="80"
                                                Height="80"
                                                Foreground="{StaticResource TextTertiaryBrush}"
                                                HorizontalAlignment="Center"/>
                        <TextBlock Text="No Centers Found"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,20,0,0"/>
                        <TextBlock Text="Start by adding your first training center"
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                        <Button Content="Add Center"
                                Style="{StaticResource PrimaryButton}"
                                Click="btnAddNewCenter_Click"
                                Margin="0,24,0,0"
                                HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
