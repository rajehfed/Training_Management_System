<Page x:Class="TrainningCenter.Views.Pages.GroupsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TrainningCenter.Views.Pages"
      xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
      xmlns:uc="clr-namespace:TrainningCenter.UserControles"
      xmlns:uc1="clr-namespace:TrainningCenter.UserControles.Groups"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1400"
      Title="GroupsPage"
      Background="{StaticResource PageBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!--
        ═══════════════════════════════════════════════════════════════════════════
            HEADER SECTION
            Title + Add New Button
        ═══════════════════════════════════════════════════════════════════════════
        -->
        <Border Grid.Row="0"
                Background="{StaticResource CardBackgroundBrush}"
                Padding="32,24"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0 0 0 1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!--PAGE TITLE & DESCRIPTION-->
                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Groups Management" 
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Manage and organize your training groups"
                               FontSize="14"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
                
                <!--ACTIONS BUTTONS-->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource RefreshButton}"
                            ToolTip="Refresh Groups"
                            Name="btnRefresh"
                            Click="btnRefresh_Click"
                            Margin="0 0 12 0">
                        <Icons:PackIconMaterial Kind="Refresh" 
                                                Width="18" 
                                                Height="18"
                                                Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>

                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Add New Group"
                            Name="btnAddNewGroup"
                            Click="btnAddNewGroup_Click"
                            Padding="24,13">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Kind="Plus" 
                                                            Width="16" 
                                                            Height="16"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,8,0"/>
                                    <TextBlock Text="Add New Group" 
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--
        ═══════════════════════════════════════════════════════════════════════════
            MAIN SECTION
            - Left Panel (Search textbox, Filter Combo-box, Groups-List
            - Right Panel
        ═══════════════════════════════════════════════════════════════════════════
        -->
        <Grid Grid.Row="1"
              Margin="32,24,32,32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- LEFT PANEL - GROUPS LIST -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Column="0"
                    Style="{StaticResource CardStyle}"
                    Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!--SEARCH BOX-->
                    <Border Grid.Row="0"
                            Background="{StaticResource InputBackgroundBrush}"
                            CornerRadius="10"
                            Margin="20,20,20,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Icons:PackIconMaterial Grid.Column="0"
                                                    Kind="Magnify"
                                                    Width="18"
                                                    Height="18"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    VerticalAlignment="Center"
                                                    Margin="16,0,0,0"/>

                            <TextBox x:Name="txtSearchQueryTextBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SearchTextBox}"
                                     TextChanged="txtSearchQueryTextBox_TextChanged"
                                     Tag="Search Groups..."/>
                        </Grid>
                    </Border>
                    
                    <!--FILTER LABLE-->
                    <TextBlock Grid.Row="1"
                               Text="FITLER BY"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               Margin="20,20,20,8"/>
                    
                    <!--FILTER COMBO BOX-->
                    <ComboBox x:Name="cmbSelectedFilterComboBox"
                              Grid.Row="2"
                              Style="{StaticResource ModernComboBox}"
                              SelectionChanged="cmbSelectedFilterComboBox_SelectionChanged"
                              Margin="20,0,20,16">
                        <ComboBoxItem Content="All Groups" Style="{StaticResource ModernComboBoxItem}"/>
                        <ComboBoxItem Content="Active Groups" Style="{StaticResource ModernComboBoxItem}"/>
                        <ComboBoxItem Content="Archived Groups" Style="{StaticResource ModernComboBoxItem}"/>
                        <ComboBoxItem Content="My Groups" Style="{StaticResource ModernComboBoxItem}"/>
                    </ComboBox>
                    
                    <!--GROUPS LIST-->
                    <ScrollViewer Grid.Row="3"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="20,0,12,16">
                        <ItemsControl x:Name="GroupsItemsControl"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════ -->
            <!-- RIGHT PANEL - GROUPS LIST -->
            <!-- ═══════════════════════════════════════════════════════════ -->
            <Border x:Name="DetailsPanel"
                    Grid.Column="2"
                    Style="{StaticResource CardStyle}"
                    Padding="0"
                    Visibility="Visible">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="32,28,32,32">
                        <!--GROUP HEADER-->
                        <Grid Margin="0 0 0 24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock x:Name="tbSelectedGroupName"
                                           Text="AI Group"
                                           FontSize="26"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="tbSelectedGroupDescription"
                                           Text="Learn AI with TenserFlow"
                                           FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0 8 0 0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Top">
                                <Button Style="{StaticResource IconButtonEdit}"
                                        ToolTip="Edit Group"
                                        Name="btnEditGroup"
                                        Click="btnEditGroup_Click"
                                        Margin="0 0 8 0">
                                    <Icons:PackIconMaterial Kind="Pencil"
                                                            Width="16"
                                                            Height="16"
                                                            Foreground="{StaticResource PrimaryBrush}"/>
                                </Button>
                                <Button x:Name="btnDeleteGroup"
                                        Style="{StaticResource IconButtonDelete}"
                                        ToolTip="Delete Group"
                                        Click="btnDeleteGroup_Click">
                                    <Icons:PackIconMaterial Kind="Delete"
                                                          Width="16"
                                                          Height="16"
                                                          Foreground="{StaticResource DangerBrush}"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                        
                        <!--STATS CARDS-->
                        <Grid Margin="0 0 0 28">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Total Members -->
                            <uc1:StatCard Value="{Binding MaxTrainees}" 
                                          IconKind="AccountMultiple" 
                                          Label="Total Trainees" 
                                          BackgroudBrush="{StaticResource PrimaryPaleBrush}" 
                                          IconBrush="{StaticResource PrimaryBrush}" 
                                          Margin="0 0 10 0" />
                            <!--ACTIVE MEMBERS-->
                            <uc1:StatCard Grid.Column="1"
                                          IconKind="CheckCircle"
                                          IconBrush="{StaticResource SuccessBrush}"
                                          BackgroudBrush="{StaticResource SuccessLightBrush}"
                                          Label="Active Today"
                                          Value="{Binding StudentCount}"
                                          Margin="0 0 10 0"/>
                            <!--CREATED DATE-->
                            <uc1:StatCard Grid.Column="2"
                                          BackgroudBrush="{StaticResource InfoLightBrush}"
                                          IconKind="Calendar"
                                          IconBrush="{StaticResource InfoBrush}"
                                          Value="{Binding CreatedAt}"
                                          Label="Created"/>
                        </Grid>

                        <!-- Members Section -->
                        <StackPanel Margin="0 0 0 28">
                            <!-- Section Header -->
                            <Grid Margin="0 0 0 16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                            Text="Members"
                                            FontSize="20"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <!-- Search Members -->
                                    <Border Background="{StaticResource InputBackgroundBrush}"
                                            CornerRadius="10"
                                            Width="220"
                                            Margin="0 0 12 0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Icons:PackIconMaterial Grid.Column="0"
                                                                    Kind="Magnify"
                                                                    Width="16"
                                                                    Height="16"
                                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                                    VerticalAlignment="Center"
                                                                    Margin="14,0,0,0"/>
                                            <TextBox x:Name="MemberSearchQueryTextBox"
                                                     Grid.Column="1"
                                                     Style="{StaticResource SearchTextBox}"
                                                     TextChanged="MemberSearchQueryTextBox_TextChanged"
                                                     Tag="Search members..."
                                                     Height="38"
                                                     Padding="8,0"/>
                                        </Grid>
                                    </Border>

                                    <Button x:Name="btnAddMemberButton"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="btnAddMemberButton_Click"
                                            Padding="20, 10"
                                            Height="38">
                                        <StackPanel Orientation="Horizontal">
                                            <Icons:PackIconMaterial Kind="Plus"
                                                                  Width="14"
                                                                  Height="14"
                                                                  VerticalAlignment="Center"
                                                                  Margin="0,0,6,0"/>
                                            <TextBlock Text="Add Member"
                                                      VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                            
                            <!--MEMBERS LIST-->
                            <ItemsControl x:Name="MembersItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <uc1:MemberCard Member="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Recent Activity"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0 0 0 16"/>

                            <ItemsControl x:Name="RecentActivityItemsControl">
                                 <!--THIS IS THE FIX: Tell the ItemsControl HOW to arrange its children--> 
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                         <!--A StackPanel will arrange the ActivityCards vertically--> 
                                        <StackPanel Orientation="Vertical"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- Your DataTemplate is perfect. No changes needed here. -->
                                        <!-- We add a Margin to create space between the cards. -->
                                        <uc1:ActivityCard Activity="{Binding}" Margin="0,0,0,12"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Empty State Overlay (when no group selected) -->
        <uc:ctrlEmptyStateOverlay x:Name="EmptyStateOverlay"
                                  Grid.Row="1"
                                  IconKind="AccountGroupOutline"
                                  Title="No Group Selected"
                                  Message="Please select a group from the left panel to view its details."
                                  Visibility="Collapsed"/>
    </Grid>
</Page>
