<Page x:Class="TrainningCenter.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TrainningCenter.Views.Pages"
      xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
      xmlns:vm="clr-namespace:TrainningCenter.ViewModel"
      xmlns:UC="clr-namespace:TrainningCenter.UserControles"
      mc:Ignorable="d"
      Background="Transparent"
      d:DesignHeight="900" d:DesignWidth="1600"
      Title="Dashboard">

    <Page.DataContext>
        <vm:DashboardViewModel />
    </Page.DataContext>

    <Page.Resources>
        <!-- Stat Card Style -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#8147E7" BlurRadius="25" ShadowDepth="0" Opacity="0.25"/>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <TranslateTransform Y="-4"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Quick Action Button -->
        <Style x:Key="QuickActionCard" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#8147E7" Offset="0"/>
                        <GradientStop Color="#A980F5" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24,20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#8147E7" BlurRadius="30" ShadowDepth="0" Opacity="0.5"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Activity Item Style -->
        <Style x:Key="ActivityItem" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#F0F0F0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAFAFA"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Border CornerRadius="20" Background="{StaticResource PageBackgroundBrush}" ClipToBounds="True">
        <ScrollViewer>
            <Grid MaxWidth="1600" Margin="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- WELCOME HEADER -->
                <Border Grid.Row="0" 
                    CornerRadius="24"
                    Padding="40,32"
                    Margin="0,0,0,32">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#8147E7" Offset="0"/>
                            <GradientStop Color="#A980F5" Offset="0.5"/>
                            <GradientStop Color="#8147E7" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect RenderingBias="Performance" Color="#8147E7" BlurRadius="40" ShadowDepth="0" Opacity="0.4"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Welcome Text -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👋 Welcome back, "
                                       FontSize="36"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                                <TextBlock x:Name="tbUserName"
                                       Text="{Binding UserName}"
                                       FontSize="36"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="tbWelcomeMessage"
                                   Text="{Binding WelcomeMessage}"
                                   FontSize="16"
                                   Foreground="White"
                                   Opacity="0.95"
                                   Margin="0,12,0,0"/>
                        </StackPanel>

                        <!-- Today's Date & Time -->
                        <Border Grid.Column="1"
                            Background="White"
                            CornerRadius="16"
                            Padding="24,20"
                            Opacity="0.15">
                            <StackPanel>
                                <TextBlock x:Name="tbCurrentTime"
                                       Text="12:45 PM"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                                <TextBlock x:Name="tbCurrentDate"
                                       Text="Monday, Dec 25, 2024"
                                       FontSize="14"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Actual Time Display (Visible) -->
                        <StackPanel Grid.Column="1" 
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                            <TextBlock x:Name="tbTime"
                                   Text="12:45 PM"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                            <TextBlock x:Name="tbDate"
                                   Text="Monday, Dec 25, 2024"
                                   FontSize="14"
                                   Foreground="White"
                                   Opacity="0.9"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- STATISTICS CARDS ROW -->
                <Grid Grid.Row="1" Margin="0 0 0 32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total Students -->
                    <UC:ctrlExplicitStatCard Title="TOTAL STUDENTS"
                                         Value="{Binding TotalStudents}"
                                         StatusText="{Binding StudentGrowth}"
                                         StatusKind="TrendingUp"
                                         IconKind="AccountGroup"
                                         AccentBrush="{StaticResource PrimaryUltraLightBrush}"
                                         IconForeground="{StaticResource PrimaryBrush}"
                                         StatusBrush="{StaticResource SuccessBrush}"
                                         AdditionalText="this month"
                                         CardCommand="{Binding NavigateCommand}"
                                         Margin="0 0 12 0"/>

                    <!-- Active Groups -->
                    <UC:ctrlExplicitStatCard Title="ACTIVE GROUPS"
                                         Grid.Column="1"
                                         Value="{Binding ActiveGroups}"
                                         StatusText="{Binding SessionsToday}"
                                         StatusKind="BookOpenPageVariant"
                                         IconKind="GoogleClassroom"
                                         AccentBrush="{StaticResource SuccessLightBrush}"
                                         IconForeground="{StaticResource SuccessBrush}"
                                         StatusBrush="{StaticResource InfoBrush}"
                                         AdditionalText="sessions today"
                                         CardCommand="{Binding NavigateCommand}"
                                         Margin="0 0 12 0"/>

                    <!-- Revenue This Month -->
                    <UC:ctrlExplicitStatCard Title="REVENUE THIS MONTH"
                                         Grid.Column="2"
                                         Value="{Binding Revenue}"
                                         StatusText="{Binding RevenueGrowth}"
                                         StatusKind="TrendingUp"
                                         IconKind="CurrencyUsd"
                                         AccentBrush="{StaticResource WarningLightBrush}"
                                         IconForeground="{StaticResource WarningBrush}"
                                         StatusBrush="{StaticResource SuccessBrush}"
                                         AdditionalText="from last month"
                                         CardCommand="{Binding NavigateCommand}"
                                         Margin="0 0 12 0"/>

                    <!-- Attendance Rate -->
                    <UC:ctrlExplicitStatCard Title="ATTENDANCE RATE"
                                         Grid.Column="3"
                                         Value="{Binding AttendanceRate}"
                                         StatusText="{Binding AttendanceRate}"
                                         StatusKind="ThumbUp"
                                         IconKind="CheckCircle"
                                         AccentBrush="#E3F2FD"
                                         IconForeground="#1976D2"
                                         StatusBrush="{StaticResource SuccessBrush}"
                                         AdditionalText="above target"
                                         CardCommand="{Binding NavigateCommand}"
                                         Margin="0 0 12 0"/>


                </Grid>

                <!-- QUICK ACTIONS & TODAY'S SCHEDULE -->
                <Grid Grid.Row="2" Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Quick Actions -->
                    <Border Grid.Column="0" 
                        Background="White"
                        CornerRadius="20"
                        Padding="32"
                        Margin="0,0,16,0">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.08"/>
                        </Border.Effect>

                        <StackPanel>
                            <TextBlock Text="⚡ Quick Actions"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,24"/>

                            <UniformGrid Columns="3" Rows="2">
                                <!-- Add Student - Purple -->
                                <UC:QuickActionCard Title="Add Student"
                                                Description="Enroll new student"
                                                IconKind="AccountPlus"
                                                GradientStartColor="#8147E7"
                                                GradientEndColor="#A980F5"
                                                CardCommand="{Binding AddStudentCommand}"
                                                Margin="0,0,12,12"/>

                                <!-- Create Group - Green -->
                                <UC:QuickActionCard Title="Create Group"
                                                Description="Start a new class"
                                                IconKind="GoogleClassroom"
                                                GradientStartColor="#28A745"
                                                GradientEndColor="#48C774"
                                                CardCommand="{Binding CreateGroupCommand}"
                                                Margin="0,0,12,12"/>

                                <!-- Schedule Session - Orange -->
                                <UC:QuickActionCard Title="Schedule Session"
                                                Description="Plan new session"
                                                IconKind="CalendarPlus"
                                                GradientStartColor="#FF9800"
                                                GradientEndColor="#FFB74D"
                                                CardCommand="{Binding ScheduleSessionCommand}"
                                                Margin="0,0,0,12"/>

                                <!-- Take Attendance - Blue -->
                                <UC:QuickActionCard Title="Attendance"
                                                Description="Mark attendance"
                                                IconKind="ClipboardCheck"
                                                GradientStartColor="#1976D2"
                                                GradientEndColor="#42A5F5"
                                                CardCommand="{Binding TakeAttendanceCommand}"
                                                Margin="0,0,12,0"/>

                                <!-- Create Assessment - Pink -->
                                <UC:QuickActionCard Title="Assessment"
                                                Description="Create quiz/exam"
                                                IconKind="ClipboardPlusOutline"
                                                GradientStartColor="#E91E63"
                                                GradientEndColor="#F06292"
                                                CardCommand="{Binding CreateAssessmentCommand}"
                                                Margin="0,0,12,0"/>

                                <!-- View Reports - Deep Purple -->
                                <UC:QuickActionCard Title="Reports"
                                                Description="View analytics"
                                                IconKind="ChartLine"
                                                GradientStartColor="#7B1FA2"
                                                GradientEndColor="#AB47BC"
                                                CardCommand="{Binding ViewReportsCommand}"
                                                Margin="0,0,0,0"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- Today's Schedule -->
                    <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="20"
                        Padding="28"
                        CacheMode="BitmapCache">
                        <Border.Effect>
                            <DropShadowEffect RenderingBias="Performance" Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.08"/>
                        </Border.Effect>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Icons:PackIconMaterial Kind="CalendarToday"
                                                    Width="24" Height="24"
                                                    Foreground="{StaticResource PrimaryBrush}"
                                                    Margin="0,0,12,0"/>
                                <TextBlock Text="Today's Schedule"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>

                            <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto">
                                <ListBox BorderThickness="0" x:Name="todayScheduleList">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource PageBackgroundBrush}"
                                                CornerRadius="12"
                                                Padding="16"
                                                Margin="0,0,0,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Time -->
                                                    <Border Grid.Column="0"
                                                        Background="{StaticResource PrimaryBrush}"
                                                        CornerRadius="8"
                                                        Padding="12,8"
                                                        Margin="0,0,12,0">
                                                        <TextBlock Text="{Binding Time}"
                                                               FontSize="13"
                                                               FontWeight="Bold"
                                                               Foreground="White"
                                                               TextAlignment="Center"/>
                                                    </Border>

                                                    <!-- Session Info -->
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Title}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="{Binding Group}"
                                                               FontSize="12"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- RECENT ACTIVITY & UPCOMING EVENTS -->
                <Grid Grid.Row="3" Margin="0,0,0,32">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Recent Activity -->
                    <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="20"
                        Padding="32"
                        Margin="0,0,16,0"
                        CacheMode="BitmapCache">
                        <Border.Effect>
                            <DropShadowEffect RenderingBias="Performance" Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.08"/>
                        </Border.Effect>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <Icons:PackIconMaterial Kind="BellRing"
                                                    Width="24" Height="24"
                                                    Foreground="{StaticResource PrimaryBrush}"
                                                    Margin="0,0,12,0"/>
                                <TextBlock Text="Recent Activity"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>

                            <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <ListBox BorderThickness="0" ItemsSource="{Binding RecentActivities}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <!-- Activity Item 1 -->
                                                <UC:ctrlActivityItem Title="{Binding Title}"
                                                                 Description="{Binding Description}"
                                                                 TimeAgo="{Binding TimeAgo}"
                                                                 IconKind="{Binding Icon}"
                                                                 IconForeground="{StaticResource SuccessBrush}"
                                                                 IconBackground="{StaticResource SuccessLightBrush}"/>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <!-- Upcoming Events -->
                    <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="20"
                        Padding="32" 
                        CacheMode="BitmapCache">
                        <Border.Effect>
                            <DropShadowEffect RenderingBias="Performance" Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.08"/>
                        </Border.Effect>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                <Icons:PackIconMaterial Kind="CalendarClock"
                                                    Width="24" Height="24"
                                                    Foreground="{StaticResource PrimaryBrush}"
                                                    Margin="0,0,12,0"/>
                                <TextBlock Text="Upcoming Events"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            </StackPanel>

                            <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <ListBox BorderThickness="0" ItemsSource="{Binding UpcomingEvents}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <!-- Event 1 -->
                                                <UC:ctrlEventItem EventTitle="{Binding Title}"
                                                              EventDate="{Binding DateRange}"
                                                              EventSubtitle="{Binding Subtitle}"
                                                              BackgroundColor="{Binding BgColor}"
                                                              AccentColor="{Binding MainColor}" />
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- BOTTOM INSPIRATIONAL QUOTE -->
                <Border Grid.Row="4"
                    CornerRadius="20"
                    Padding="32,28"
                    Margin="0,0,0,0"
                    CacheMode="BitmapCache">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#667EEA" Offset="0"/>
                            <GradientStop Color="#764BA2" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>

                    <Border.Effect>
                        <DropShadowEffect RenderingBias="Performance" Color="#667EEA" BlurRadius="30" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Icons:PackIconMaterial Grid.Column="0"
                                            Kind="FormatQuoteOpen"
                                            Width="48" Height="48"
                                            Foreground="White"
                                            Opacity="0.5"
                                            Margin="0,0,24,0"/>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="'Education is the most powerful weapon which you can use to change the world.'"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   FontStyle="Italic"
                                   Foreground="White"
                                   TextWrapping="Wrap"
                                   LineHeight="32"/>
                            <TextBlock Text="— Nelson Mandela"
                                   FontSize="15"
                                   Foreground="White"
                                   Opacity="0.9"
                                   Margin="0,12,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Border>
</Page>
