<Page x:Class="TrainningCenter.Views.Pages.StudentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TrainningCenter.Views.Pages"
      xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
      xmlns:UC="clr-namespace:TrainningCenter.UserControles.Groups"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1400"
      Title="StudentsPage"
      Background="{StaticResource PageBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--
        ═══════════════════════════════════════════════════════════════════════════
            HEADER SECTION
            Content: 
                Page Title "Student Management"
                Action Buttons: Export + Add New Student + Refresh
        ═══════════════════════════════════════════════════════════════════════════
        -->

        <Border Grid.Row="0"
                Background="{StaticResource CardBackgroundBrush}"
                Padding="32, 24"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0 0 0 1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!--PAGE TITLE-->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Students Management"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Manage student records, enrollments, and academic information"
                               FontSize="14"
                               Margin="0 6 0 0"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
                
                <!--ACTION BUTTONS-->
                <StackPanel Orientation="Horizontal" 
                            Grid.Column="1"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource RefreshButton}"
                            ToolTip="Refresh Student"
                            Name="btnRefresh"
                            Click="btnRefresh_Click"
                            Margin="0 0 12 0">
                        <Icons:PackIconMaterial Kind="Refresh" 
                                                Width="18" 
                                                Height="18"
                                                Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>
                    <Button Style="{StaticResource OutlineButton}"
                            Content="Export"
                            Name="btnExport"
                            Click="btnExport_Click"
                            Padding="20,11"
                            Margin="0 0 12 0">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Kind="Download" 
                                                            Width="16" 
                                                            Height="16"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,8,0"/>
                                    <TextBlock Text="Export" 
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Add New Student"
                            x:Name="btnAddNewStudent"
                            Click="btnAddNewStudent_Click"
                            Padding="24,13">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Kind="AccountPlus" 
                                                            Width="16" 
                                                            Height="16"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,8,0"/>
                                    <TextBlock Text="Add New Student" 
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!--
        ═══════════════════════════════════════════════════════════════════════════
            STATISTICS CARDS
            Content: 
                Total Students
                Active Students
                New Enrolements Students
                Inactive Students
        ═══════════════════════════════════════════════════════════════════════════
        -->
        <Grid Grid.Row="1" Margin="32,24,32,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <UC:StatCard Value="{Binding totalStudents}"
                         IconKind="AccountGroup"
                         Label="Total Students"
                         BackgroudBrush="{StaticResource PrimaryPaleBrush}"
                         Foreground="{StaticResource InfoBrush}"
                         IconBrush="{StaticResource PrimaryBrush}"
                         Margin="0 0 10 0"/>
            <UC:StatCard Grid.Column="1" 
                         Value="{Binding active}"
                         IconKind="CheckCircle"
                         Label="Active Students"
                         BackgroudBrush="{StaticResource SuccessLightBrush}"
                         Foreground="{StaticResource InfoBrush}"
                         IconBrush="{StaticResource SuccessBrush}"
                         Margin="0 0 10 0"/>
            <UC:StatCard Grid.Column="2" 
                         Value="{Binding NewEnrolements}"
                         IconKind="AccountPlus"
                         Label="New This Month"
                         BackgroudBrush="{StaticResource InfoLightBrush}"
                         IconBrush="{StaticResource InfoBrush}"
                         Margin="0 0 10 0"/>
            <UC:StatCard Grid.Column="3" 
                         Value="{Binding inactive}"
                         IconKind="AlertCircle"
                         Label="Inactive Students"
                         BackgroudBrush="{StaticResource WarningLightBrush}"
                         IconBrush="{StaticResource WarningBrush}"
                         Margin="0 0 10 0"/>
        </Grid>

        <!--
        ═══════════════════════════════════════════════════════════════════════════
            MAIN CONTENT - FILTERS & DATA GRID
        ═══════════════════════════════════════════════════════════════════════════
        -->
        <Border Grid.Row="2"
                Style="{StaticResource CardStyle}"
                Margin="32 24 32 32">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!--FILTER & STUDENTS SEARCH-->
                <Grid Grid.Row="0" Margin="0 0 0 20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!--SEARCH BOX-->
                    <Border Grid.Column="0"
                            Background="{StaticResource InputBackgroundBrush}"
                            CornerRadius="10"
                            MaxWidth="400"
                            HorizontalAlignment="Left">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Icons:PackIconMaterial Grid.Column="0"
                                                    Kind="Magnify"
                                                    Width="18"
                                                    Height="18"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    VerticalAlignment="Center"
                                                    Margin="16,0,0,0"/>

                            <TextBox x:Name="txtSearchBox"
                                     Grid.Column="1"
                                     Style="{StaticResource SearchTextBox}"
                                     TextChanged="txtSearchBox_TextChanged"
                                     Tag="Search by name, number, or email..."
                                     MinWidth="300"/>
                        </Grid>
                    </Border>

                    <!--STATUS FILTER-->
                    <ComboBox x:Name="cmbStatusFilter"
                              Grid.Column="1"
                              Style="{StaticResource ModernComboBox}"
                              Width="180"
                              Margin="12 0 0 0"
                              SelectionChanged="cmbStatusFilter_SelectionChanged">
                        <ComboBoxItem Content="All Status" Style="{StaticResource ModernComboBoxItem}"/>
                        <ComboBoxItem Content="Active" Style="{StaticResource ModernComboBoxItem}"/>
                        <ComboBoxItem Content="Inactive" Style="{StaticResource ModernComboBoxItem}"/>
                        <ComboBoxItem Content="Suspended" Style="{StaticResource ModernComboBoxItem}"/>
                        <ComboBoxItem Content="Graduated" Style="{StaticResource ModernComboBoxItem}"/>
                    </ComboBox>

                    <!--GROUP FILTER-->
                    <ComboBox Name="cmbGroupFilter"
                              Grid.Column="2"
                              Style="{StaticResource ModernComboBox}"
                              Width="180"
                              Margin="12 0 0 0"
                              SelectionChanged="cmbGroupFilter_SelectionChanged">
                        <ComboBoxItem Content="All Groups" Style="{StaticResource ModernComboBoxItem}"/>
                    </ComboBox>
                    
                    <!--SORT BY-->
                    <ComboBox Name="cmbSortBy"
                              Grid.Column="3"
                              Style="{StaticResource ModernComboBox}"
                              Width="180"
                              Margin="12 0 0 0"
                              SelectionChanged="cmbSortBy_SelectionChanged">
                        <ComboBoxItem Content="Sort by Name" Style="{StaticResource ModernComboBoxItem}"/>
                        <ComboBoxItem Content="Sort by Date" Style="{StaticResource ModernComboBoxItem}"/>
                        <ComboBoxItem Content="Sort by Status" Style="{StaticResource ModernComboBoxItem}"/>
                        <ComboBoxItem Content="Sort by Number" Style="{StaticResource ModernComboBoxItem}"/>
                    </ComboBox>
                </Grid>

                <DataGrid x:Name="dgStudents"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          Background="Transparent"
                          BorderThickness="0"
                          RowStyle="{StaticResource ModernDataGridRow}"
                          ColumnHeaderStyle="{StaticResource ModernDataGridColumnHeader}"
                          CellStyle="{StaticResource ModernDataGridCell}">
                    <DataGrid.Columns>
                        <!--STUDENT INFO (Avatar + Name + Number)-->
                        <DataGridTemplateColumn Header="STUDENT" Width="2*" MinWidth="250">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <!--AVATAR-->
                                        <Border Width="40" Height="40"
                                                CornerRadius="20"
                                                Background="{StaticResource PrimaryPaleBrush}"
                                                Margin="0 0 12 0">
                                            <TextBlock Text="{Binding Initials}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource PrimaryBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!--NAME & NUMBER-->
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FullName}"
                                                       Style="{StaticResource DataGridTextBold}"/>
                                            <TextBlock Text="{Binding StudentNumber}"
                                                       Style="{StaticResource DataGridTextMuted}"
                                                       Margin="0 2 0 0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--EMAIL-->
                        <DataGridTemplateColumn Header="EMAIL" Width="*" MinWidth="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Email}"
                                               Style="{StaticResource DataGridTextRegular}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--PHONE-->
                        <DataGridTemplateColumn Header="PHONE" Width="*" MinWidth="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Phone}"
                                               Style="{StaticResource DataGridTextRegular}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--ENROLLMENT DATE-->
                        <DataGridTemplateColumn Header="ENROLLED" Width="*" MinWidth="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding AdmissionDate, StringFormat='{}{0:dd MMM yyyy}'}"
                                               Style="{StaticResource DataGridTextMuted}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        
                        <!--STATUS-->
                        <DataGridTemplateColumn Header="STATUS" Width="*" MinWidth="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12"
                                            Padding="10 5"
                                            HorizontalAlignment="Left">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StudentStatus}" Value="Active">
                                                        <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StudentStatus}" Value="Inactive">
                                                        <Setter Property="Background" Value="{StaticResource DangerLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StudentStatus}" Value="Suspended">
                                                        <Setter Property="Background" Value="{StaticResource WarningLightBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StudentStatus}" Value="Graduated">
                                                        <Setter Property="Background" Value="{StaticResource InfoLightBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <TextBlock FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding StudentStatus, Converter={StaticResource UpperCaseConverter}}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding StudentStatus}" Value="Active">
                                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StudentStatus}" Value="Inactive">
                                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StudentStatus}" Value="Suspended">
                                                            <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding StudentStatus}" Value="Graduated">
                                                            <Setter Property="Foreground" Value="{StaticResource InfoBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!--ACTIONS-->
                        <DataGridTemplateColumn>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <!--VIEW BUTTON-->
                                        <Button Style="{StaticResource IconButton}"
                                                ToolTip="View Details"
                                                Name="btnView"
                                                Click="btnView_Click"
                                                Tag="{Binding StudentID}"
                                                Margin="0 0 4 0">
                                            <Icons:PackIconMaterial Kind="Eye"
                                                                    Width="16"
                                                                    Height="16"
                                                                    Foreground="{StaticResource InfoBrush}"/>
                                        </Button>
                                        
                                        <!--EDIT BUTTON-->
                                        <Button Style="{StaticResource IconButtonEdit}"
                                                ToolTip="Edit Student"
                                                Name="btnEdit"
                                                Click="btnEdit_Click"
                                                Tag="{Binding StudentID}"
                                                Margin="0 0 4 0">
                                            <Icons:PackIconMaterial Kind="Pencil"
                                                                    Width="16"
                                                                    Height="16"
                                                                    Foreground="{StaticResource PrimaryBrush}"/>
                                        </Button>
                                        
                                        <!--DELETE BUTTON-->
                                        <Button Style="{StaticResource IconButtonDelete}"
                                                ToolTip="Delete Student"
                                                Name="btnDelete"
                                                Click="btnDelete_Click"
                                                Tag="{Binding StudentID}">
                                            <Icons:PackIconMaterial Kind="Delete"
                                                                    Width="16"
                                                                    Height="16"
                                                                    Foreground="{StaticResource DangerBrush}"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!--PAGINATION-->
                <Grid Grid.Row="2" Margin="0 20 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!--RESULTS INFO-->
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center">
                        <Run Text="Showing"/>
                        <Run Text="{Binding ElementName=dgStudents, Path=Items.Count, Mode=OneWay}" FontWeight="SemiBold"/>
                        <Run Text="of"/>
                        <Run x:Name="runTotalCount" Text="245" FontWeight="SemiBold"/>
                        <Run Text="students"/>
                    </TextBlock>

                    <!--PAGINATION CONTROLS-->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Previous"
                                Style="{StaticResource SecondaryButton}"
                                Name="btnPrevious"
                                Click="btnPrevious_Click"
                                Padding="16,10"
                                MinWidth="100"
                                Margin="0 0 8 0"/>

                        <Border Background="{StaticResource InputBackgroundBrush}"
                                CornerRadius="10"
                                Padding="16,10"
                                Margin="0 0 8 0">
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="Page"/>
                                <Run x:Name="runCurrentPage" Text="1" FontWeight="SemiBold"/>
                                <Run Text="of"/>
                                <Run x:Name="runTotalPages" Text="10" FontWeight="SemiBold"/>
                            </TextBlock>
                        </Border>

                        <Button Content="Next"
                                Style="{StaticResource SecondaryButton}"
                                Name="btnNext"
                                Click="btnNext_Click"
                                Padding="16,10"
                                MinWidth="100"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
