<Window x:Class="TrainningCenter.Views.Windows.AddEditUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrainningCenter.Views.Windows"
        xmlns:uc="clr-namespace:TrainningCenter.UserControles"
        xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        Title="User Management"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Height="650" Width="450">

    <Window.Resources>
        <!-- Boolean to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!--CARD STYLE-->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
        </Style>

        <!--PRIMARY BUTTON-->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#8147E7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#9A5FF0"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--SECONDARY BUTTON-->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--MODERN TEXT BOX-->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="12,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <Icons:PackIconMaterial Kind="{Binding Path=Tag, RelativeSource={RelativeSource TemplatedParent}}" 
                                                        Width="18" 
                                                        Height="18"
                                                        Foreground="#999999"
                                                        Margin="14,0,0,0"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Left"
                                                        IsHitTestVisible="False"/>
                                <ScrollViewer x:Name="PART_ContentHost" 
                                              Margin="{TemplateBinding Margin}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#8147E7"/>
                    <Setter Property="Background" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#B8A3E8"/>
                </Trigger>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="#F0F0F0"/>
                    <Setter Property="Foreground" Value="#999999"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--MODERN PASSWORD BOX-->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="12,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <Icons:PackIconMaterial Kind="{Binding Path=Tag, RelativeSource={RelativeSource TemplatedParent}}" 
                                                          Width="18" 
                                                          Height="18"
                                                          Foreground="#999999"
                                                          Margin="14,0,0,0"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left"
                                                          IsHitTestVisible="False"/>
                                <ScrollViewer x:Name="PART_ContentHost" 
                                            Margin="{TemplateBinding Margin}"
                                            VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#8147E7"/>
                    <Setter Property="Background" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#B8A3E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--MODERN COMBOX-->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="12,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                    Content="{TemplateBinding SelectionBoxItem}"
                                                    Margin="{TemplateBinding Padding}"
                                                    VerticalAlignment="Center"/>
                                    <ToggleButton Grid.Column="1"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Width="30"
                                                Focusable="False"
                                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                ClickMode="Press">
                                        <Icons:PackIconMaterial Kind="ChevronDown" 
                                                              Width="18" 
                                                              Height="18"
                                                              Foreground="#666666"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True">
                                <Border Background="White"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Margin="0,5,0,0"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="0" Opacity="0.1"/>
                                    </Border.Effect>
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#8147E7"/>
                    <Setter Property="Background" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#B8A3E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--CHECK BOX STYLE-->
        <Style x:Key="ModernCheckBox" TargetType="CheckBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#202020"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <!-- Use a BulletDecorator to handle the click logic correctly -->
                        <BulletDecorator Background="Transparent" VerticalAlignment="Center">
                            <BulletDecorator.Bullet>
                                <!-- This Border is the "Bullet" -->
                                <Border x:Name="CheckBorder"
                                Width="22" Height="22"
                                BorderThickness="2"
                                BorderBrush="#E0E0E0"
                                CornerRadius="6"
                                Background="White">

                                    <!-- The check mark icon -->
                                    <Icons:PackIconMaterial Kind="Check"
                                                    Width="14" Height="14"
                                                    Foreground="White"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Visibility="Collapsed"/>
                                    <!-- Start hidden -->
                                </Border>
                            </BulletDecorator.Bullet>

                            <!-- This ContentPresenter is the "Child" (the label) -->
                            <ContentPresenter Margin="10,0,0,0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Left"
                                      RecognizesAccessKey="True"/>
                        </BulletDecorator>

                        <!-- Visual triggers -->
                        <ControlTemplate.Triggers>
                            <!-- When IsChecked is true, show the icon and change colors -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#8147E7"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#8147E7"/>
                                <Setter TargetName="CheckBorder" Property="Visibility" Value="Visible"/>
                            </Trigger>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#8147E7"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <!--LINK BUTTON STYLE-->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8147E7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#9A5FF0"/>
                    <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Style="{StaticResource CardStyle}"
            BorderThickness="1"
            BorderBrush="#8147E7"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!--HEADER-->
            <Border Grid.Row="0"
                    Name="Header"
                    Background="#8147E7"
                    CornerRadius="15,15,0,0"
                    Padding="15,10"
                    MouseDown="Header_MouseDown">
                <Grid>
                    <StackPanel>
                        <TextBlock x:Name="tbModalTitle"
                                   Text="Add New User"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Fill in the details below"
                                   FontSize="8"
                                   Foreground="#E0DAFF"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <Button HorizontalAlignment="Right"
                            Name="btnClose"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Width="25"
                            Height="25"
                            Cursor="Hand"
                            Click="btnClose_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#9A5FF0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Icons:PackIconMaterial Kind="Close" 
                                              Width="15" 
                                              Height="15" 
                                              Foreground="White"/>
                    </Button>
                </Grid>
            </Border>

            <!--FORM CONTENT-->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="25,20">
                <StackPanel>
                    <!--PERSON SELECTION-->
                    <uc:PersonSelector x:Name="personSelector"
                                       Margin="0,0,0,18"/>

                    <Separator Height="1" Background="#E0E0E0" Margin="0,0,0,18"/>

                    <!--USERNAME-->
                    <StackPanel Margin="0,0,0,18">

                        <TextBlock x:Name="tbUserName"
                                   Text="Username"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="#202020"
                                   Margin="0 0 0 8"/>
                        <TextBox x:Name="txtUsername"
                                 Style="{StaticResource ModernTextBox}"
                                 Padding="42, 12, 12, 12"
                                 Tag="Account"/>

                    </StackPanel>

                    <!--PASSWORD-->
                    <StackPanel Margin="0 0 0 18">
                        <TextBlock Text="Password"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="#202020"
                                   Margin="0 0 0 8"/>

                        <PasswordBox x:Name="txtPassword"
                                     Style="{StaticResource ModernPasswordBox}"
                                     Padding="42,12,12,12"
                                     Tag="Lock"/>
                        <TextBlock x:Name="txtPasswordHint"
                                   Text="Leave empty to keep current password"
                                   FontSize="11"
                                   Foreground="#999999"
                                   Margin="4,6,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>

                    <!--ROLE-->
                    <StackPanel Margin="0,0,0,18">
                        <TextBlock Text="Role" 
                                   FontWeight="SemiBold" 
                                   FontSize="13"
                                   Foreground="#202020" 
                                   Margin="0,0,0,8"/>
                        <ComboBox x:Name="cmbRole" 
                                  Style="{StaticResource ModernComboBox}">
                            <ComboBoxItem Content="Admin" Tag="Admin"/>
                            <ComboBoxItem Content="Trainer" Tag="Trainer"/>
                            <ComboBoxItem Content="Student" Tag="Student"/>
                            <ComboBoxItem Content="Receptionist" Tag="Receptionist"/>
                            <ComboBoxItem Content="Manager" Tag="Manager"/>
                        </ComboBox>
                    </StackPanel>

                    <!--ACTIVE STATUS-->
                    <StackPanel Margin="0,5,0,0">
                        <CheckBox x:Name="chkIsActive" 
                                  Content="Active User" 
                                  Style="{StaticResource ModernCheckBox}"
                                  Panel.ZIndex="1"
                                  IsChecked="True"/>
                        <TextBlock Text="Inactive users cannot log into the system" 
                                   FontSize="11" 
                                   Foreground="#999999" 
                                   Margin="32,4,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!--FOOTER BUTTONS-->
            <Border Grid.Row="2"
                    Background="#F8F9FA"
                    CornerRadius="0 0 15 15"
                    Padding="25 12"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0 1 0 0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="Cancel"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0 0 8 0"
                            Click="btnClose_Click"/>

                    <Button Grid.Column="1" 
                            x:Name="btnSave"
                            Content="Save User" 
                            Style="{StaticResource PrimaryButton}"
                            Margin="8,0,0,0"
                            Click="btnSave_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
