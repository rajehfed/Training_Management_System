<Window x:Class="TrainningCenter.Views.Windows.Groups.AddMemberToGroupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrainningCenter.Views.Windows.Groups"
        xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:SelectroUC="clr-namespace:TrainningCenter.UserControles.Students"
        mc:Ignorable="d"
        Title="Add Member to Group"
        Height="613"
        Width="900"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="StepIndicator" TargetType="Border">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="Background" Value="#28A745"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="#8147E7"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlanCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,16,0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#8147E7"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#8147E7" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="White"
            Margin="15"
            CornerRadius="19"
            BorderBrush="{StaticResource PrimaryBrush}"
            BorderThickness="2">

        <!-- 3. Add the Shadow Effect -->
        <Border.Effect>
            <DropShadowEffect Color="Black"
                              Direction="270"
                              BlurRadius="20"
                              ShadowDepth="0"
                              Opacity="0.4"/>
        </Border.Effect>


        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!--HEADER-->
            <Border Grid.Row="0"
                    CornerRadius="18,18,0,0"
                    Padding="20,12">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#8147E7" Offset="0"/>
                        <GradientStop Color="#A980F5" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!--ICON-->
                    <Border Grid.Column="0"
                            Width="50" Height="50"
                            CornerRadius="35"
                            Background="White"
                            Margin="0,0,15,0">
                        <Icons:PackIconMaterial Kind="AccountPlus"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                Width="25" Height="25"
                                                Foreground="{StaticResource PrimaryBrush}"/>
                    </Border>

                    <!--TITLE & GROUP INFO-->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Add Member to Group"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock x:Name="tbGroupName"
                                   Text="AI Fundamentals - Group A"
                                   FontSize="12"
                                   Foreground="White"
                                   Opacity="0.9"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!--CLOSE BUTTON-->
                    <Button Grid.Column="2"
                            Style="{StaticResource CloseButton}"
                            Name="btnClose"
                            Click="btnClose_Click"
                            VerticalAlignment="Center">
                        <Icons:PackIconMaterial Kind="Close"
                                                Width="20" Height="20"
                                                Foreground="White"/>
                    </Button>
                </Grid>
            </Border>

            <!--MAIN CONTENT-->
            <Grid Grid.Row="1" Margin="30,32,40,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="167*"/>
                    <RowDefinition Height="30*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!--LEFT SIDEBAR - STEPS-->
                <Border Grid.Column="0"
                        Background="{StaticResource PageBackgroundBrush}"
                        CornerRadius="16"
                        Padding="24"
                        Margin="0,0,24,0" Grid.RowSpan="2">
                    <StackPanel>
                        <TextBlock Text="ENROLLMENT STEPS"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   Margin="0,0,0,24"/>

                        <!--STEP 1-->
                        <StackPanel Margin="0 0 0 24">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="40" Height="40"
                                        x:Name="step1Border"
                                        CornerRadius="20"
                                        Margin="0,0,12,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="1"
                                               x:Name="step1Text"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Select Student"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Choose student"
                                               FontSize="11"
                                               Foreground="{StaticResource TextTertiaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!--STEP 2-->
                        <StackPanel Margin="0,0,0,24">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="step2Border"
                                        Width="40" Height="40"
                                        CornerRadius="20"
                                        Background="#E0E0E0"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="2"
                                               x:Name="step2Text"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Payment Plan"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Choose plan"
                                               FontSize="11"
                                               Foreground="{StaticResource TextTertiaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!--STEP 3-->
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="step3Border"
                                        Width="40" Height="40"
                                        CornerRadius="20"
                                        Background="#E0E0E0"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="3"
                                               x:Name="step3Text"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Confirmation"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Review And confirm"
                                               FontSize="11"
                                               Foreground="{StaticResource TextTertiaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--RIGHT CONTENT AREA-->
                <ScrollViewer Grid.Column="1"
                              VerticalScrollBarVisibility="Auto" Grid.RowSpan="2">
                    <Grid>
                        <!--STEP 1: SELECT STUDENT-->
                        <SelectroUC:StudentSelector x:Name="studentSelector" />

                        <!--STEP 2: PAYMENT PLAN-->
                        <StackPanel x:Name="step2Content" Visibility="Collapsed">
                            <TextBlock Text="Choose Payment Plan"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,24">
                                <Run Text="Enrolling:"/>
                                <Run x:Name="runSelectedStudent" 
                                     Text="John Doe" 
                                     FontWeight="SemiBold"/>
                            </TextBlock>

                            <!--PAYMENT PLANS-->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!--FULL PAYMENT-->
                                <Border Grid.Column="0"
                                        x:Name="planFullCard"
                                        Style="{StaticResource PlanCard}"
                                        MouseLeftButtonDown="planFullCard_MouseLeftButtonDown"
                                        Tag="Full">
                                    <StackPanel>
                                        <Border Background="{StaticResource SuccessLightBrush}"
                                                CornerRadius="10"
                                                Padding="12,8"
                                                HorizontalAlignment="Left"
                                                Margin="0,0,0,16">
                                            <TextBlock Text="💰 RECOMMENDED"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource SuccessBrush}"/>
                                        </Border>

                                        <TextBlock Text="Full Payment"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="0,0,0,8"/>

                                        <TextBlock Text="Pay entire amount upfront"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,20"/>

                                        <TextBlock FontSize="36"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="0,0,0,8">
                                            <Run Text="$"/>
                                            <Run x:Name="runFullAmount" Text="500"/>
                                        </TextBlock>

                                        <TextBlock Text="✓ 10% discount applied"
                                                   FontSize="13"
                                                   Foreground="{StaticResource SuccessBrush}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="✓ Certificate included"
                                                   FontSize="13"
                                                   Foreground="{StaticResource SuccessBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!--INSTALLMENT PAYMENT-->
                                <Border Grid.Column="1"
                                        x:Name="planInstallmentCard"
                                        Style="{StaticResource PlanCard}"
                                        Margin="0"
                                        MouseLeftButtonDown="planFullCard_MouseLeftButtonDown"
                                        Tag="Installment">
                                    <StackPanel>
                                        <Border Background="{StaticResource InfoLightBrush}"
                                                CornerRadius="10"
                                                Padding="12,8"
                                                HorizontalAlignment="Left"
                                                Margin="0,0,0,16">
                                            <TextBlock Text="📅 FLEXIBLE"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource InfoBrush}"/>
                                        </Border>

                                        <TextBlock Text="Installment Plan"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="0,0,0,8"/>

                                        <TextBlock Text="Pay in monthly installments"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,20"/>

                                        <TextBlock FontSize="36"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="0,0,0,8">
                                            <Run Text="$"/>
                                            <Run x:Name="runInstallmentAmount" Text="200"/>
                                            <Run Text="/mo" FontSize="16"/>
                                        </TextBlock>

                                        <TextBlock FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,0,0,4">
                                            <Run Text="3 payments of $"/>
                                            <Run Text="200"/>
                                        </TextBlock>
                                        <TextBlock Text="✓ Certificate included"
                                                   FontSize="13"
                                                   Foreground="{StaticResource SuccessBrush}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!--STEP 3: CONFIRMATION-->
                        <StackPanel x:Name="step3Content" Visibility="Collapsed">
                            <Border Background="{StaticResource SuccessLightBrush}"
                                    CornerRadius="16"
                                    Padding="24"
                                    Margin="0,0,0,24">
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Kind="CheckCircle"
                                                            Width="40" Height="40"
                                                            Foreground="{StaticResource SuccessBrush}"
                                                            VerticalAlignment="Top"
                                                            Margin="0,0,16,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Ready to Enroll"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource SuccessBrush}"/>
                                        <TextBlock Text="Please review the enrollment details below"
                                                   FontSize="14"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,8,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!--SUMMARY CARD-->
                            <Border Background="White"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="2"
                                    CornerRadius="16"
                                    Padding="32">
                                <StackPanel>
                                    <TextBlock Text="Enrollment Summary"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,0,0,24"/>

                                    <!--STUDENT INFO-->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="Student:"
                                                   FontSize="14"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Width="150"/>
                                        <TextBlock Grid.Column="1"
                                                   x:Name="tbSummaryStudent"
                                                   Text="John Doe (STU-001)"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </Grid>

                                    <!--GROUP INFO-->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="Group:"
                                                   FontSize="14"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Width="150"/>
                                        <TextBlock Grid.Column="1"
                                                   x:Name="tbSummaryGroup"
                                                   Text="AI Fundamentals - Group A"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </Grid>

                                    <!--PAYMENT PLAN-->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="Payment Plan:"
                                                   FontSize="14"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Width="150"/>
                                        <TextBlock Grid.Column="1"
                                                   x:Name="tbSummaryPlan"
                                                   Text="Full Payment ($500)"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </Grid>

                                    <!--START DATE-->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="Subscription Date:"
                                                   FontSize="14"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Width="150"/>
                                        <TextBlock Grid.Column="1"
                                                   x:Name="tbSummaryDate"
                                                   Text="December 21, 2025"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!--FOOTER-->
            <Border Grid.Row="2"
                    Background="{StaticResource PageBackgroundBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="40,20"
                    CornerRadius="0,0,18,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!--BACK BUTTON-->
                    <Button x:Name="btnBack"
                            Grid.Column="0"
                            Style="{StaticResource SecondaryButton}"
                            Content="← Back"
                            Click="btnBack_Click"
                            Padding="24,12"
                            MinWidth="120"
                            Visibility="Collapsed"/>

                    <!--PROGRESS TEXT-->
                    <TextBlock x:Name="tbProgress"
                               Grid.Column="1"
                               Text="Step 1 of 3"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <!--ACTION BUTTONS-->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal">
                        <Button Content="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                Click="btnClose_Click"
                                Padding="24,12"
                                MinWidth="120"
                                Margin="0,0,12,0"/>

                        <Button x:Name="btnNext"
                                Content="Next →"
                                Style="{StaticResource PrimaryButton}"
                                Click="btnNext_Click"
                                Padding="24,12"
                                MinWidth="140"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
