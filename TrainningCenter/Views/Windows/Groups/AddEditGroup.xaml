<Window x:Class="TrainningCenter.Views.Windows.Groups.AddEditGroup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrainningCenter.Views.Windows.Groups"
        xmlns:vm="clr-namespace:TrainningCenter.ViewModel"
        xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowStartupLocation="CenterOwner"
        Title="AddEditGroup" 
        ResizeMode="NoResize"
        Background="Transparent"
        Height="700" Width="900"
        AllowsTransparency="True"
        d:DataContext="{d:DesignInstance vm:GroupVM}">

    <Border CornerRadius="16"
            Background="{StaticResource PageBackgroundBrush}"
            BorderBrush="{StaticResource PrimaryBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!--
            ═══════════════════════════════════════════════════════════════════
                HEADER SECTION
            ═══════════════════════════════════════════════════════════════════
            -->
            <Border Grid.Row="0"
                    Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="16 16 0 0"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0 0 0 1"
                    Padding="32,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!--ICON-->
                    <Border Grid.Column="0"
                            Style="{StaticResource PurpleIconContainer}"
                            Width="48" Height="48"
                            Margin="0 0 16 0">
                        <Icons:PackIconMaterial x:Name="iconHeader"
                                                Kind="AccountGroupOutline"
                                                Width="24"
                                                Height="24"
                                                Foreground="{StaticResource PrimaryBrush}"/>
                    </Border>

                    <!--TITLE AND DESCRIPTION-->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="tbTitle"
                                   Text="Add New Group"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="tbDescription"
                                   Text="Create a new training group"
                                   FontSize="13"
                                   Margin="0,4,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <!--CLOSE BUTTON-->
                    <Button Grid.Column="2"
                            Style="{StaticResource CloseButton}"
                            Name="btnClose"
                            Click="btnClose_Click">
                        <Icons:PackIconMaterial Kind="Close"
                                              Width="16"
                                              Height="16"
                                              Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>
                </Grid>
            </Border>

            <!--
            ═══════════════════════════════════════════════════════════════════
                FORM CONTENT
            ═══════════════════════════════════════════════════════════════════
            -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="32,24,32,24">
                <StackPanel>

                    <!--BASIC INFORMATION SECTION-->
                    <TextBlock Text="Basic Information"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Foreground="{StaticResource PrimaryBrush}"
                              Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!--GROUP NAME-->
                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="Group Name *"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtGroupName"
                                     Style="{StaticResource ModernTextBox}"
                                     Tag="Enter group name..."
                                     Text="{Binding GroupName}"/>
                            <!--<TextBox Text="Can you see this text?" Name="txtGroupName" FontSize="16" />-->
                        </StackPanel>
                        
                        <!--CENTER-->
                        <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="Training Center *"
                                       Style="{StaticResource FormLabel}"/>
                            <ComboBox x:Name="cmbCenter"
                                      Style="{StaticResource ModernComboBox}"
                                      ItemsSource="{Binding CentersList}"
                                      SelectedValuePath="CenterID"
                                      SelectedValue="{Binding CenterID}">
                                <!-- THIS IS THE FIX -->
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <!-- This template explicitly binds to the TrainerName property -->
                                        <TextBlock Text="{Binding CenterName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        
                        <!--SPECIALIZATIONS-->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,16">
                            <TextBlock Text="Specialization *"
                                       Style="{StaticResource FormLabel}"/>
                            <ComboBox x:Name="cmbSpecialization"
                                      Style="{StaticResource ModernComboBox}"
                                      ItemsSource="{Binding SpecializationsList}"
                                      SelectedValuePath="SpecializationID"
                                      SelectedValue="{Binding SpecializationID}">
                                <!-- THIS IS THE FIX -->
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <!-- This template explicitly binds to the TrainerName property -->
                                        <TextBlock Text="{Binding SpecializationName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>

                            </ComboBox>
                        </StackPanel>
                        
                        <!--TRAINER-->
                        <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,0,0,16">
                            <TextBlock Text="Trainer *"
                                      Style="{StaticResource FormLabel}"/>

                            <ComboBox x:Name="cmbTrainer"
                                      Style="{StaticResource ModernComboBox}"
                                      ItemsSource="{Binding TrainersList}"
                                      SelectedValuePath="TrainerID"
                                      SelectedValue="{Binding TrainerID}">

                                <!-- THIS IS THE FIX -->
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <!-- This template explicitly binds to the TrainerName property -->
                                        <TextBlock Text="{Binding TrainerName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>

                            </ComboBox>


                        </StackPanel>
                        
                        <!--MAX TRAINEES-->
                        <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,0,0,16">
                            <TextBlock Text="Maximum Trainees *"
                                      Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtMaxTrainees"
                                     Style="{StaticResource ModernTextBox}"
                                     Tag="e.g., 25"
                                     Text="{Binding MaxTrainees}"/>
                        </StackPanel>
                        
                        <!--STATUS-->
                        <StackPanel Grid.Column="2" Grid.Row="2" Margin="0,0,0,16">
                            <TextBlock Text="Status"
                                        Style="{StaticResource FormLabel}"/>
                            <ComboBox x:Name="cmbStatus"
                                      Style="{StaticResource ModernComboBox}"
                                      Text="{Binding StatusName}">
                                <ComboBoxItem Content="Active" Style="{StaticResource ModernComboBoxItem}" IsSelected="True"/>
                                <ComboBoxItem Content="Suspended" Style="{StaticResource ModernComboBoxItem}"/>
                                <ComboBoxItem Content="Completed" Style="{StaticResource ModernComboBoxItem}"/>
                                <ComboBoxItem Content="Cancelled" Style="{StaticResource ModernComboBoxItem}"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!--SCHEDULE SECTION-->
                    <TextBlock Text="Schedule And Location"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource PrimaryBrush}"
                                    Margin="0,8,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!--START DATE-->
                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="Start Date *"
                                       Style="{StaticResource FormLabel}"/>
                            <DatePicker x:Name="dpStartDate"
                                        Style="{StaticResource FormDatePicker}"
                                        SelectedDate="{Binding StartDate}"/>
                        </StackPanel>

                        <!--END DATE-->
                        <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="End Date *"
                                       Style="{StaticResource FormLabel}"/>
                            <DatePicker x:Name="dpEndDate"
                                        Style="{StaticResource FormDatePicker}"
                                        SelectedDate="{Binding EndDate}"/>
                        </StackPanel>
                        
                        <!--SCHEDULE-->
                        <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,0,16">
                            <TextBlock Text="Schedule"
                                      Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtSchedule"
                                    Style="{StaticResource ModernTextBox}"
                                    Tag="e.g., Mon, Wed, Fri - 9:00 AM"
                                     Text="{Binding Schedule}"/>
                        </StackPanel>
                        
                        <!--ROOM-->
                        <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,0,0,16">
                            <TextBlock Text="Room"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtRoom"
                                     Style="{StaticResource ModernTextBox}"
                                     Tag="e.g., Room 101"
                                     Text="{Binding Room}"/>
                        </StackPanel>
                    </Grid>
                    
                    <!--ADDITIONAL INFORMATIONS SECTION-->
                    <TextBlock Text="Additional Information"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"
                               Margin="0,8,0,16"/>
                    
                    <!--DESCRIPTION-->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Description"
                                  Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="txtDescription"
                                Style="{StaticResource MultiLineTextBox}"
                                Height="100"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                VerticalScrollBarVisibility="Auto"
                                Tag="Enter group description..."
                                 Text="{Binding Description}"/>
                    </StackPanel>

                    <!--ACTIVE CHECK BOX-->
                    <CheckBox x:Name="chkIsActive"
                              Style="{StaticResource ModernCheckBox}"
                              Content="Group is Active"
                              IsChecked="{Binding IsActive}"
                              Margin="0,8,0,0"/>
                    
                    <!--INFO PANEL-->
                    <Border Style="{StaticResource InfoPanel}"
                            Margin="0 16 0 0">
                        <StackPanel Orientation="Horizontal">
                            <Icons:PackIconMaterial Kind="InformationOutline"
                                                  Width="16"
                                                  Height="16"
                                                  Foreground="{StaticResource PrimaryBrush}"
                                                  VerticalAlignment="Top"
                                                  Margin="0,2,12,0"/>
                            <TextBlock TextWrapping="Wrap"
                                      FontSize="13"
                                      Foreground="{StaticResource TextSecondaryBrush}">
                                <Run Text="Fields marked with"/>
                                <Run Text=" * " FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                                <Run Text="are required. Make sure all required information is filled before saving."/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!--
            ═══════════════════════════════════════════════════════════════════
                FOOTER - ACTION BUTTONS
            ═══════════════════════════════════════════════════════════════════
            -->
            <Border Grid.Row="2"
                    Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="0 0 16 16"
                    BorderThickness="0 1 0 0"
                    BorderBrush="{StaticResource BorderBrush}"
                    Padding="32 20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Side - Required Fields Note -->
                    <StackPanel Grid.Column="0" 
                               Orientation="Horizontal"
                               VerticalAlignment="Center">
                        <Icons:PackIconMaterial Kind="AlertCircleOutline"
                                              Width="16"
                                              Height="16"
                                              Foreground="{StaticResource TextTertiaryBrush}"
                                              Margin="0,0,8,0"/>
                        <TextBlock Text="* Required fields"
                                  FontSize="12"
                                  Foreground="{StaticResource TextTertiaryBrush}"
                                  VerticalAlignment="Center"/>
                    </StackPanel>

                    <!--RIGHT SIDE- ACTION BUTTONS-->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button x:Name="btnCancel"
                                Style="{StaticResource SecondaryButton}"
                                Content="Cancel"
                                Click="btnCancel_Click"
                                Width="120"
                                Margin="0 0 12 0"/>

                        <Button x:Name="btnSave"
                                Style="{StaticResource PrimaryButton}"
                                Content="Save Group"
                                Click="btnSave_Click"
                                Width="160">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Icons:PackIconMaterial Kind="ContentSave"
                                                              Width="16"
                                                              Height="16"
                                                              VerticalAlignment="Center"
                                                              Margin="0,0,8,0"/>
                                        <TextBlock Text="Save Group"
                                                  VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
