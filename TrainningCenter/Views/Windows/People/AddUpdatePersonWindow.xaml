<Window x:Class="TrainningCenter.Views.Windows.AddUpdatePersonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrainningCenter.Views.Windows"
        xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        Title="Add New Person" 
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        Height="750" Width="900">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Views/Styles/FormStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Enhanced Form Card Style -->
            <Style x:Key="FormCard" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="25"/>
                <Setter Property="Margin" Value="0,0,0,20"/>
                <Setter Property="BorderBrush" Value="#E8E4F3"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#000000" 
                                        BlurRadius="10" 
                                        ShadowDepth="2" 
                                        Opacity="0.05"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Section Header Style -->
            <Style x:Key="EnhancedSectionHeader" TargetType="TextBlock">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Foreground" Value="#202020"/>
                <Setter Property="Margin" Value="0,0,0,0"/>
            </Style>

            <!-- Validation Error Style -->
            <Style x:Key="ValidationError" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Foreground" Value="#F44336"/>
                <Setter Property="Margin" Value="0,4,0,0"/>
                <Setter Property="FontWeight" Value="Medium"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border BorderBrush="#8147E7"
            BorderThickness="2"
            CornerRadius="10"
            Background="#F5F7FA">
        <Border.Effect>
            <DropShadowEffect Color="#000000" 
                            BlurRadius="30" 
                            ShadowDepth="0" 
                            Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ==================== HEADER ==================== -->
            <Border Grid.Row="0"
                    Background="White"
                    Padding="30, 20"
                    CornerRadius="8,8,0,0"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,0,0,2">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#E8E4F3"
                                Width="50"
                                Height="50"
                                CornerRadius="25"
                                VerticalAlignment="Center">
                            <Icons:PackIconMaterial Kind="AccountPlus"
                                                    Width="28"
                                                    Height="28"
                                                    Foreground="#8147E7"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="tbWindowTitle"
                                       Text="Add New Person"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#202020"/>
                            <TextBlock Text="Fill in the information below"
                                       FontSize="13"
                                       Foreground="#666666"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <!-- Help Button -->
                        <Button Width="35"
                                Height="35"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Margin="0,0,10,0"
                                ToolTip="Help">
                            <Icons:PackIconMaterial Kind="HelpCircleOutline"
                                                    Width="20"
                                                    Height="20"
                                                    Foreground="#666666"/>
                        </Button>

                        <!-- Close Button -->
                        <Button Name="btnClose"
                                Width="35"
                                Height="35"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="btnClose_Click">
                            <Icons:PackIconMaterial Kind="Close"
                                                    Width="20"
                                                    Height="20"
                                                    Foreground="#666666"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== FORM CONTENT ==================== -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="30,20">
                <StackPanel MaxWidth="800">

                    <!-- Personal Information Card -->
                    <Border Style="{StaticResource FormCard}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Background="#E8E4F3"
                                        Width="32"
                                        Height="32"
                                        CornerRadius="6"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0">
                                    <Icons:PackIconMaterial Kind="CardAccountDetails"
                                                            Width="18"
                                                            Height="18"
                                                            Foreground="#8147E7"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Personal Information" 
                                           Style="{StaticResource EnhancedSectionHeader}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- First Name -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="First Name *" Style="{StaticResource FormLabel}" />
                                    <TextBox x:Name="txtFirstName" 
                                             Style="{StaticResource FormTextBox}"
                                             Tag="Required"/>
                                    <TextBlock x:Name="tbFirstNameError"
                                               Style="{StaticResource ValidationError}"
                                               Text="First name is required"
                                               Visibility="Collapsed"/>
                                </StackPanel>

                                <!-- Last Name -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Last Name *" Style="{StaticResource FormLabel}"/>
                                    <TextBox x:Name="txtLastName"
                                             Style="{StaticResource FormTextBox}"
                                             Tag="Required"/>
                                    <TextBlock x:Name="tbLastNameError"
                                               Style="{StaticResource ValidationError}"
                                               Text="Last name is required"
                                               Visibility="Collapsed"/>
                                </StackPanel>
                            </Grid>

                            <!-- National No -->
                            <StackPanel Margin="0, 15, 0, 0">
                                <TextBlock Text="National Number *" Style="{StaticResource FormLabel}" />
                                <TextBox x:Name="txtNationalNo"
                                         Style="{StaticResource FormTextBox}"
                                         MaxLength="20"
                                         Tag="Required"/>
                                <TextBlock x:Name="tbNationalNoError"
                                           Style="{StaticResource ValidationError}"
                                           Text="National number is required"
                                           Visibility="Collapsed"/>
                            </StackPanel>

                            <Grid Margin="0, 15, 0, 0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="20" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Date of Birth -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Date of Birth *" Style="{StaticResource FormLabel}" />
                                    <DatePicker Name="dpDateOfBirth" 
                                                Style="{StaticResource FormDatePicker}" />
                                </StackPanel>

                                <!-- Gender -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Gender *" Style="{StaticResource FormLabel}" />
                                    <ComboBox x:Name="cbGender"
                                              Style="{StaticResource ModernComboBox}"
                                              SelectedIndex="0">
                                        <ComboBoxItem Content="Male" Tag="M"/>
                                        <ComboBoxItem Content="Female" Tag="F"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>

                            <!-- Nationality -->
                            <StackPanel Margin="0, 15, 0, 0">
                                <TextBlock Text="Nationality" Style="{StaticResource FormLabel}" />
                                <ComboBox x:Name="cbNationality"
                                          Style="{StaticResource ModernComboBox}"
                                          IsEditable="True">
                                    <ComboBoxItem Content="Algerian" IsSelected="True"/>
                                    <ComboBoxItem Content="American"/>
                                    <ComboBoxItem Content="British"/>
                                    <ComboBoxItem Content="Canadian"/>
                                    <ComboBoxItem Content="Egyptian"/>
                                    <ComboBoxItem Content="French"/>
                                    <ComboBoxItem Content="German"/>
                                    <ComboBoxItem Content="Moroccan"/>
                                    <ComboBoxItem Content="Saudi"/>
                                    <ComboBoxItem Content="Tunisian"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Contact Information Card -->
                    <Border Style="{StaticResource FormCard}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Background="#E8E4F3"
                                        Width="32"
                                        Height="32"
                                        CornerRadius="6"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0">
                                    <Icons:PackIconMaterial Kind="Phone"
                                                            Width="18"
                                                            Height="18"
                                                            Foreground="#8147E7"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Contact Information" 
                                           Style="{StaticResource EnhancedSectionHeader}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Phone Number -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Phone Number *" Style="{StaticResource FormLabel}" />
                                    <TextBox x:Name="txtPhoneNumber" 
                                             Style="{StaticResource FormTextBox}"
                                             Tag="Required"/>
                                    <TextBlock x:Name="tbPhoneError"
                                               Style="{StaticResource ValidationError}"
                                               Text="Phone number is required"
                                               Visibility="Collapsed"/>
                                </StackPanel>

                                <!-- Email -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Email" Style="{StaticResource FormLabel}" />
                                    <TextBox x:Name="txtEmail" 
                                            Style="{StaticResource FormTextBox}" />
                                    <TextBlock x:Name="tbEmailError"
                                               Style="{StaticResource ValidationError}"
                                               Text="Invalid email format"
                                               Visibility="Collapsed"/>
                                </StackPanel>
                            </Grid>

                            <!-- Address -->
                            <StackPanel Margin="0, 15, 0, 0">
                                <TextBlock Text="Address" Style="{StaticResource FormLabel}" />
                                <TextBox x:Name="txtAddress"
                                         Style="{StaticResource FormTextBox}"
                                         Height="80"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalContentAlignment="Top"
                                         Padding="12, 12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Profile Image Card -->
                    <Border Style="{StaticResource FormCard}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                <Border Background="#E8E4F3"
                                        Width="32"
                                        Height="32"
                                        CornerRadius="6"
                                        VerticalAlignment="Center"
                                        Margin="0,0,10,0">
                                    <Icons:PackIconMaterial Kind="Image"
                                                            Width="18"
                                                            Height="18"
                                                            Foreground="#8147E7"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Profile Image" 
                                           Style="{StaticResource EnhancedSectionHeader}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Image Path -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Image Path (Optional)"
                                               Style="{StaticResource FormLabel}"/>
                                    <TextBox x:Name="txtImagePath"
                                             Style="{StaticResource FormTextBox}"
                                             IsReadOnly="True"
                                             Background="#F8F9FA"/>
                                </StackPanel>

                                <!-- Browse Button -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                    <Button Name="btnBrowseImage"
                                            Height="45"
                                            Width="140"
                                            Style="{StaticResource OutlineButton}"
                                            Click="btnBrowseImage_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <Icons:PackIconMaterial Kind="FolderImage"
                                                                    Width="16"
                                                                    Height="16"
                                                                    Margin="0,0,6,0"/>
                                            <TextBlock Text="Browse"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- Image Preview -->
                            <StackPanel Margin="0,20,0,0" HorizontalAlignment="Center">
                                <Border Width="150"
                                        Height="150"
                                        CornerRadius="75"
                                        BorderBrush="#8147E7"
                                        BorderThickness="3"
                                        Background="White">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#8147E7" 
                                                        BlurRadius="15" 
                                                        ShadowDepth="0" 
                                                        Opacity="0.2"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Image x:Name="imgPreview"
                                               Stretch="UniformToFill">
                                            <Image.Clip>
                                                <EllipseGeometry Center="75, 75" RadiusX="72" RadiusY="72"/>
                                            </Image.Clip>
                                        </Image>

                                        <Icons:PackIconMaterial Kind="Account"
                                                                Width="70"
                                                                Height="70"
                                                                Foreground="#CCCCCC"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                x:Name="iconPlaceHolder"/>
                                    </Grid>
                                </Border>

                                <!-- Remove Image Button -->
                                <Button x:Name="btnRemoveImage"
                                        Content="Remove Image"
                                        Margin="0,10,0,0"
                                        Padding="12,6"
                                        Background="Transparent"
                                        BorderBrush="#F44336"
                                        BorderThickness="1"
                                        Foreground="#F44336"
                                        FontSize="12"
                                        Cursor="Hand"
                                        Visibility="Collapsed"
                                        Click="btnRemoveImage_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="4"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F44336"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>

            </ScrollViewer>

            <!-- ==================== FOOTER BUTTONS ==================== -->
            <Border Grid.Row="2"
                    Background="White"
                    Padding="30, 20"
                    CornerRadius="0,0,8,8"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,2,0,0">
                <Grid>
                    <!-- Required Fields Note -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                        <Icons:PackIconMaterial Kind="InformationOutline"
                                                Width="16"
                                                Height="16"
                                                Foreground="#8147E7"
                                                Margin="0,0,6,0"/>
                        <TextBlock Text="Fields marked with * are required"
                                   FontSize="12"
                                   Foreground="#666666"/>
                    </StackPanel>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="Cancel"
                                Name="btnCancel"
                                Width="130" Height="45"
                                Style="{StaticResource OutlineButton}"
                                Click="btnCancel_Click"/>

                        <Button x:Name="btnSave"
                                Width="150" Height="45"
                                Style="{StaticResource PrimaryButton}"
                                Margin="15,0,0,0"
                                Click="btnSave_Click">
                            <StackPanel Orientation="Horizontal">
                                <Icons:PackIconMaterial Kind="ContentSave"
                                                        Width="18"
                                                        Height="18"
                                                        Margin="0,0,8,0"/>
                                <TextBlock Text="Save Person"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== LOADING OVERLAY ==================== -->
            <Border x:Name="LoadingOverlay"
                    Grid.RowSpan="3"
                    Background="#CC000000"
                    CornerRadius="10"
                    Visibility="Collapsed">
                <Border Background="White"
                        CornerRadius="10"
                        Padding="40,30"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <ProgressBar IsIndeterminate="True"
                                     Width="200"
                                     Height="4"
                                     Foreground="#8147E7"
                                     Background="#E8E4F3"/>
                        <TextBlock Text="Saving person information..." 
                                   Foreground="#202020"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,20,0,0"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Please wait" 
                                   Foreground="#666666"
                                   FontSize="12"
                                   Margin="0,5,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Border>

        </Grid>
    </Border>
</Window>