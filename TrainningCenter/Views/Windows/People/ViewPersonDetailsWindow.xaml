<Window x:Class="TrainningCenter.Views.Windows.ViewPersonDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:TrainningCenter.Views.Windows"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        Title="ViewPersonDetailsWindow" 
        Height="720" Width="550">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Views/Styles/FormStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Read-Only TextBox Style -->
            <Style x:Key="ReadOnlyTextBox" TargetType="TextBox" BasedOn="{StaticResource FormTextBox}">
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="Background" Value="#F8F9FA"/>
                <Setter Property="BorderBrush" Value="#E0E0E0"/>
                <Setter Property="Cursor" Value="Arrow"/>
            </Style>

            <!-- Info Label Style -->
            <Style x:Key="InfoLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#666666"/>
                <Setter Property="Margin" Value="0,0,0,6"/>
            </Style>

            <!-- Info Value Style -->
            <Style x:Key="InfoValue" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Foreground" Value="#202020"/>
                <Setter Property="Margin" Value="0,0,0,15"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border BorderBrush="#8147E7"
            BorderThickness="2"
            CornerRadius="8"
            Background="#FAFBFC">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ==================== HEADER ==================== -->
            <Border Grid.Row="0"
                    Background="White"
                    Padding="18, 8"
                    CornerRadius="6,6,0,0"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,0,0,2"
                    Name="Header"
                    MouseDown="Header_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#E8E4F3"
                                Width="45"
                                Height="45"
                                CornerRadius="25"
                                VerticalAlignment="Center">
                            <Icons:PackIconMaterial Kind="AccountDetails"
                                                    Width="23"
                                                    Height="23"
                                                    Foreground="#8147E7"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="tbWindowTitle"
                                       Text="Person Details"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="#202020"/>
                            <TextBlock x:Name="tbPersonID"
                                       Text="Person ID: #12345"
                                       FontSize="10"
                                       Foreground="#666666"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Button HorizontalAlignment="Right"
                            Name="btnClose"
                            VerticalAlignment="Center"
                            Width="30"
                            Height="30"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="btnClose_Click">
                        <Icons:PackIconMaterial Kind="Close"
                                                Width="16"
                                                Height="16"
                                                Foreground="#666666"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ==================== CONTENT ==================== -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="25,15">
                <StackPanel MaxWidth="500">

                    <!-- Profile Image Section -->
                    <Border Margin="0,0,0,20"
                            Width="120"
                            Height="120"
                            CornerRadius="60"
                            HorizontalAlignment="Center"
                            BorderBrush="#8147E7"
                            BorderThickness="3"
                            Background="White">
                        <Grid>
                            <Image x:Name="imgProfile"
                                   Stretch="UniformToFill">
                                <Image.Clip>
                                    <EllipseGeometry Center="60, 60" RadiusX="57" RadiusY="57" />
                                </Image.Clip>
                            </Image>

                            <Icons:PackIconMaterial Kind="Account"
                                                    Width="60"
                                                    Height="60"
                                                    Foreground="#CCCCCC"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    x:Name="iconPlaceHolder"/>
                        </Grid>
                    </Border>

                    <!-- Personal Information Section -->
                    <Border Background="White"
                            CornerRadius="8"
                            Padding="20"
                            Margin="0,0,0,15"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1">

                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <Icons:PackIconMaterial Kind="CardAccountDetails"
                                                        Width="18"
                                                        Height="18"
                                                        Foreground="#8147E7"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0"/>
                                <TextBlock Text="Personal Information"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#202020"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left Column -->
                                <StackPanel Grid.Column="0">
                                    <!-- First Name -->
                                    <TextBlock Text="First Name" Style="{StaticResource InfoLabel}" />
                                    <TextBlock x:Name="tbFirstName" Text="John" Style="{StaticResource InfoValue}" />

                                    <!-- National Number -->
                                    <TextBlock Text="National Number" Style="{StaticResource InfoLabel}"/>
                                    <TextBlock x:Name="tbNationalNo" Text="123456789" Style="{StaticResource InfoValue}"/>

                                    <!-- Date of Birth -->
                                    <TextBlock Text="Date of Birth" Style="{StaticResource InfoLabel}"/>
                                    <TextBlock x:Name="tbDateOfBirth" Text="01/15/1990" Style="{StaticResource InfoValue}"/>

                                    <!-- Nationality -->
                                    <TextBlock Text="Nationality" Style="{StaticResource InfoLabel}"/>
                                    <TextBlock x:Name="tbNationality" Text="Algerian" Style="{StaticResource InfoValue}"/>
                                </StackPanel>

                                <!-- Right Column -->
                                <StackPanel Grid.Column="2">
                                    <!-- Last Name -->
                                    <TextBlock Text="Last Name" Style="{StaticResource InfoLabel}"/>
                                    <TextBlock x:Name="tbLastName" Text="Doe" Style="{StaticResource InfoValue}"/>

                                    <!-- Full Name -->
                                    <TextBlock Text="Full Name" Style="{StaticResource InfoLabel}"/>
                                    <TextBlock x:Name="tbFullName" 
                                               Text="John Doe" 
                                               Style="{StaticResource InfoValue}"
                                               FontWeight="Bold"
                                               Foreground="#8147E7"/>

                                    <!-- Gender -->
                                    <TextBlock Text="Gender" Style="{StaticResource InfoLabel}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <Icons:PackIconMaterial x:Name="iconGender"
                                                                Kind="GenderMale"
                                                                Width="18"
                                                                Height="18"
                                                                Foreground="#4A90E2"
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,6,0"/>
                                        <TextBlock x:Name="tbGender" 
                                                   Text="Male" 
                                                   FontSize="12"
                                                   FontWeight="Medium"
                                                   Foreground="#202020"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Age -->
                                    <TextBlock Text="Age" Style="{StaticResource InfoLabel}"/>
                                    <TextBlock x:Name="tbAge" Text="34 years old" Style="{StaticResource InfoValue}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Contact Information Section -->
                    <Border Background="White"
                            CornerRadius="8"
                            Padding="20"
                            Margin="0,0,0,15"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1">

                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <Icons:PackIconMaterial Kind="Phone"
                                                        Width="18"
                                                        Height="18"
                                                        Foreground="#8147E7"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0"/>
                                <TextBlock Text="Contact Information"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#202020"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Phone Number -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Phone Number" Style="{StaticResource InfoLabel}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <Icons:PackIconMaterial Kind="Cellphone"
                                                                Width="16"
                                                                Height="16"
                                                                Foreground="#4CAF50"
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,6,0"/>
                                        <TextBlock x:Name="tbPhoneNumber"
                                                   Text="+213 555 123 456"
                                                   FontSize="12"
                                                   FontWeight="Medium"
                                                   Foreground="#202020"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Email -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Email Address" Style="{StaticResource InfoLabel}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                        <Icons:PackIconMaterial Kind="Email"
                                                                Width="16"
                                                                Height="16"
                                                                Foreground="#FF9800"
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,6,0"/>
                                        <TextBlock x:Name="tbEmail" 
                                                   Text="john.doe@example.com" 
                                                   FontSize="12"
                                                   FontWeight="Medium"
                                                   Foreground="#202020"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Address -->
                            <TextBlock Text="Address" Style="{StaticResource InfoLabel}"/>
                            <Border Background="#F8F9FA"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12"
                                    Margin="0,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Kind="MapMarker"
                                                            Width="16"
                                                            Height="16"
                                                            Foreground="#F44336"
                                                            VerticalAlignment="Top"
                                                            Margin="0,1,8,0"/>
                                    <TextBlock x:Name="tbAddress"
                                               Text="123 Main Street, Oran, Algeria"
                                               FontSize="12"
                                               FontWeight="Medium"
                                               Foreground="#202020"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Additional Information Section -->
                    <Border Background="White"
                            CornerRadius="8"
                            Padding="20"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <Icons:PackIconMaterial Kind="InformationOutline"
                                                        Width="18"
                                                        Height="18"
                                                        Foreground="#8147E7"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0"/>

                                <TextBlock Text="Additional Information"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="#202020"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Created Date -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Created Date" Style="{StaticResource InfoLabel}"/>
                                    <TextBlock x:Name="tbCreatedDate" 
                                               Text="10/17/2025 10:30 AM" 
                                               Style="{StaticResource InfoValue}"/>
                                </StackPanel>

                                <!-- Last Modified -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Last Modified" Style="{StaticResource InfoLabel}"/>
                                    <TextBlock x:Name="tbLastModified" 
                                               Text="10/17/2025 2:45 PM" 
                                               Style="{StaticResource InfoValue}"/>
                                </StackPanel>

                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- ==================== FOOTER BUTTONS ==================== -->
            <Border Grid.Row="2"
                    Background="White"
                    CornerRadius="0,0,6,6"
                    Padding="25, 15"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,2,0,0">

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Name="btnEdit"
                            Width="130" Height="40"
                            Style="{StaticResource PrimaryButton}"
                            Click="btnEdit_Click">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <Icons:PackIconMaterial Kind="Pencil"
                                    Width="14"
                                    Height="14"
                                    VerticalAlignment="Center"
                                    Margin="0,0,6,0"/>
                                <TextBlock Text="Edit Person" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <Button Name="btnDelete"
                            Width="110" Height="40"
                            Margin="12,0,0,0"
                            Click="btnDelete_Click">

                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource OutlineButton}">
                                <Setter Property="BorderBrush" Value="#F44336"/>
                                <Setter Property="Foreground" Value="#F44336"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F44336"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <Icons:PackIconMaterial Kind="Delete"
                                                        Width="14"
                                                        Height="14"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,6,0"/>
                                <TextBlock Text="Delete" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <Button Content="Close"
                            Name="btnCloseFooter"
                            Width="110" Height="40"
                            Style="{StaticResource OutlineButton}"
                            Margin="12,0,0,0"
                            Click="btnClose_Click"/>

                </StackPanel>

            </Border>

        </Grid>
    </Border>
</Window>