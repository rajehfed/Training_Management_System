<Window x:Class="TrainningCenter.Views.Windows.Trainers.TrainerInformationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrainningCenter.Views.Windows.Trainers"
        xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        Title="Trainer Information"
        Height="650"
        Width="550"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True">
    <Border Style="{StaticResource ModalCard}"
            BorderThickness="2"
            BorderBrush="{StaticResource SuccessGradient}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!--
            ═══════════════════════════════════════════════════════════════════════════
                    HEADER SECTION
                        Avatar,
                        Name & Info,
                        Close Button
            ═══════════════════════════════════════════════════════════════════════════
            -->
            <Border Grid.Row="0"
                    Background="{StaticResource SuccessBrush}"
                    CornerRadius="15,15,0,0"
                    Padding="24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!--AVATAR-->
                    <Border Grid.Column="0"
                            Width="70"
                            Height="70"
                            CornerRadius="35"
                            Background="White"
                            Margin="0 0 16 0">
                        <TextBlock x:Name="tbInitials"
                                   Text="{Binding Initials}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource SuccessGradient}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!--NAME & INFO-->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="tbFullName"
                                   Text="{Binding FullName}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock x:Name="tbSpecialization"
                                   Text="{Binding Specialization}"
                                   FontSize="14"
                                   Foreground="{StaticResource BorderBrush}"
                                   Margin="0,4,0,0"/>

                        <!--RATING-->
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Icons:PackIconMaterial Kind="Star"
                                                    Width="16"
                                                    Height="16"
                                                    Foreground="#FFD700"
                                                    VerticalAlignment="Center"/>
                            <TextBlock x:Name="tbRating"
                                       Text="{Binding Rating}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Margin="4,0,8,0"
                                       VerticalAlignment="Center"/>
                            <Border x:Name="statusBadge"
                                    CornerRadius="10"
                                    Padding="8,4"
                                    Background="#E7F6EC">
                                <TextBlock x:Name="tbStatus"
                                           Text="ACTIVE"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Foreground="#28A745"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!--CLOSE BUTTON-->
                    <Button Grid.Column="2"
                            Name="btnClose"
                            Style="{StaticResource CloseButton}"
                            Click="btnClose_Click"
                            VerticalAlignment="Top">
                        <Icons:PackIconMaterial Kind="Close"
                                                Width="18"
                                                Height="18"
                                                Foreground="White"/>
                    </Button>
                </Grid>
            </Border>

            <!--
            ═══════════════════════════════════════════════════════════════════════════
                    CONTENT SECTION
                        STATISTICS CARDS,
                        CONTACT INFORMATION,
                        PROFESSIONAL DETAILS,
                        CENTER, BIOGRAPHY
            ═══════════════════════════════════════════════════════════════════════════
            -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="32,24">
                <StackPanel>
                    <!--STATISTICS CARDS-->
                    <Grid Margin="0 0 0 24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!--EXPERIENCE-->
                        <Border Grid.Column="0" Style="{StaticResource StatCard}" Margin="0 0 6 0">
                            <StackPanel>
                                <Icons:PackIconMaterial Kind="BriefcaseOutline"
                                                        Width="24"
                                                        Height="24"
                                                        Foreground="{StaticResource PrimaryBrush}"
                                                        Margin="0,0,0,8"/>
                                <TextBlock x:Name="tbExperience"
                                           Text="{Binding ExperienceText}"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Experience"
                                           FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!--GROUPS-->
                        <Border Grid.Column="1" Style="{StaticResource StatCard}" Margin="6,0">
                            <StackPanel>
                                <Icons:PackIconMaterial Kind="AccountGroup"
                                                        Width="24"
                                                        Height="24"
                                                        Foreground="{StaticResource SuccessBrush}"
                                                        Margin="0,0,0,8"/>
                                <TextBlock x:Name="tbGroupsCount"
                                           Text="3"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Groups"
                                           FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!--SALARY-->
                        <Border Grid.Column="2" Style="{StaticResource StatCard}" Margin="6,0,0,0">
                            <StackPanel>
                                <Icons:PackIconMaterial Kind="CurrencyUsd"
                                                        Width="24"
                                                        Height="24"
                                                        Foreground="{StaticResource WarningBrush}"
                                                        Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="$"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock x:Name="tbSalary"
                                               Text="{Binding Salary}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock Text="Monthly"
                                           FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!--CONTACT INFORMATION-->
                    <TextBlock Text="Contact Information"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,16"/>

                    <!--EMAIL-->
                    <Grid Margin="0 0 16 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="40"
                                Height="40"
                                CornerRadius="10"
                                Background="{StaticResource InfoLightBrush}"
                                Margin="0 0 12 0">
                            <Icons:PackIconMaterial Kind="Email"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    Width="20"
                                                    Height="20"
                                                    Foreground="{StaticResource InfoBrush}"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Email Address"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                            <TextBlock x:Name="tbEmail"
                                       Text="{Binding Email}"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!--PHONE-->
                    <Grid Margin="0 16 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="40" 
                                Height="40"
                                CornerRadius="10"
                                Background="{StaticResource SuccessLightBrush}"
                                Margin="0 0 12 0">
                            <Icons:PackIconMaterial Kind="Phone"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    Width="20"
                                                    Height="20"
                                                    Foreground="{StaticResource SuccessBrush}"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Phone Number"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                            <TextBlock x:Name="tbPhone"
                                       Text="{Binding Phone}"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!--ADDRESS-->
                    <Grid Margin="0,16,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="40"
                                Height="40"
                                CornerRadius="10"
                                Background="{StaticResource WarningLightBrush}"
                                Margin="0,0,12,0">
                            <Icons:PackIconMaterial Kind="MapMarker"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Width="20"
                                                    Height="20"
                                                    Foreground="{StaticResource WarningBrush}"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Address"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                            <TextBlock x:Name="tbAddress"
                                       Text="{Binding Address}"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!--PROFESSIONAL DETAILS-->
                    <TextBlock Text="Professional Details"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!--QUALIFICATIONS-->
                        <StackPanel Grid.Column="0" Margin="0,0,8,16">
                            <TextBlock Text="Qualifications"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                            <TextBlock x:Name="tbQualifications"
                                       Text="{Binding Qualifications}"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <!--HIRE DATE-->
                        <StackPanel Grid.Column="1" Margin="8,0,0,16">
                            <TextBlock Text="Hire Date"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                            <TextBlock x:Name="tbHireDate"
                                       Text="{Binding FormattedHireDate}"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!--CENTER-->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Training Center"
                                   FontSize="11"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="tbCenter"
                                   Text="{Binding CenterName}"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!--BIOGRAPHY-->
                    <StackPanel>
                        <TextBlock Text="Biography"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,12"/>
                        <Border Background="{StaticResource PageBackgroundBrush}"
                                CornerRadius="10"
                                Padding="16">
                            <TextBlock x:Name="tbBiography"
                                       Text="{Binding Biography}"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       LineHeight="20"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!--
            ═══════════════════════════════════════════════════════════════════════════
                    FOOTER SECTION
                        Avatar,
                        Name & Info,
                        Close Button
            ═══════════════════════════════════════════════════════════════════════════
            -->
            <Border Grid.Row="2"
                    Background="{StaticResource PageBackgroundBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0 1 0 0"
                    Padding="32,20"
                    CornerRadius="0 0 18 18">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Edit Trainer"
                            Style="{StaticResource SuccessButton}"
                            Name="btnEditTrainer"
                            Click="btnEditTrainer_Click"
                            Padding="24,12"
                            Margin="0 0 12 0">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Kind="Pencil"
                                                            Width="16"
                                                            Height="16"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,8,0"/>
                                    <TextBlock Text="Edit Trainer"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>

                    <Button Content="Close"
                            Style="{StaticResource SecondaryButton}"
                            Click="btnClose_Click"
                            Padding="24,12"
                            MinWidth="100"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
