<Window x:Class="TrainningCenter.Views.Windows.Centers.ViewCenterInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrainningCenter.Views.Windows.Centers"
        xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        Title="Training Center Details"
        Height="700"
        Width="900"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True">

    <Window.Resources>
        <Style x:Key="InfoCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MiniStatCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="0" Opacity="0.06"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border Background="White"
            CornerRadius="24"
            BorderBrush="{StaticResource PrimaryBrush}"
            BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!--HERO HEADER WITH GRADIENT-->
            <Border Grid.Row="0"
                    MouseLeftButtonDown="Border_MouseLeftButtonDown"
                    Height="200"
                    CornerRadius="22,22,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#8147E7" Offset="0"/>
                        <GradientStop Color="#A980F5" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid Margin="40,23">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!--LARGE ICON CIRCLE-->
                    <Border Grid.Column="0"
                            Width="110"
                            Height="110"
                            CornerRadius="55"
                            Background="White"
                            VerticalAlignment="Center"
                            Margin="0,0,24,0">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.15"/>
                        </Border.Effect>
                        <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Icons:PackIconMaterial Kind="OfficeBuilding"
                                                    Width="50"
                                                    Height="50"
                                                    Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock x:Name="tbInitials"
                                       Text="{Binding Initials, UpdateSourceTrigger=PropertyChanged, TargetNullValue='MC', FallbackValue='MC'}"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </Grid>
                    </Border>

                    <!--CENTER INFO-->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="tbCenterName"
                                   Text="{Binding CenterName, UpdateSourceTrigger=PropertyChanged, TargetNullValue='Main Campus', FallbackValue='Main Campus'}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Icons:PackIconMaterial Kind="MapMarker"
                                                    Width="18" Height="18"
                                                    Foreground="White"
                                                    Opacity="0.9"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,8,0"/>
                            <TextBlock x:Name="tbLocation"
                                       Text="{Binding DisplayLocation}"
                                       FontSize="16"
                                       Foreground="White"
                                       Opacity="0.95"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Border x:Name="statusBadge"
                                CornerRadius="12"
                                Padding="12,6"
                                Background="{StaticResource SuccessLightBrush}"
                                HorizontalAlignment="Left"
                                Margin="0,16,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="8" Height="8"
                                         x:Name="statusDot"
                                         Fill="{Binding StatusColor}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0"/>
                                <TextBlock x:Name="tbStatus"
                                           Text="{Binding StatusText}"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="{Binding StatusColor}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!--CLOSE BUTTON-->
                    <Button Grid.Column="2"
                            Style="{StaticResource CloseButton}"
                            Click="Button_Click"
                            VerticalAlignment="Top">
                        <Icons:PackIconMaterial Kind="Close"
                                                Width="20" Height="20"
                                                Foreground="White"/>
                    </Button>
                </Grid>
            </Border>

            <!--MAIN CONTENT-->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="40,32,40,24">
                <StackPanel>
                    <!--QUICK STATS CARDS-->
                    <Grid Margin="0 0 0 32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!--CAPACITY-->
                        <Border Grid.Column="0" Style="{StaticResource MiniStatCard}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#F0EDFF" Offset="0"/>
                                    <GradientStop Color="#E0DAFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <StackPanel>
                                <Icons:PackIconMaterial Kind="AccountGroup"
                                                        Width="28" Height="28"
                                                        Foreground="{StaticResource PrimaryBrush}"
                                                        Margin="0,0,0,12"/>
                                <TextBlock x:Name="tbCapacity"
                                           Text="{Binding Capacity}"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Student Capacity"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!--GROUPS (Placeholder)-->
                        <Border Grid.Column="1" Style="{StaticResource MiniStatCard}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#E7F6EC" Offset="0"/>
                                    <GradientStop Color="#D4F4DD" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <StackPanel>
                                <Icons:PackIconMaterial Kind="AccountGroupOutline"
                                                        Width="28" Height="28"
                                                        Foreground="{StaticResource SuccessBrush}"
                                                        Margin="0,0,0,12"/>
                                <TextBlock Text="{Binding GroupsCount}"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Active Groups"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!--UTILIZATION-->
                        <Border Grid.Column="2" Style="{StaticResource MiniStatCard}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFF3E0" Offset="0"/>
                                    <GradientStop Color="#FFE5CC" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <StackPanel>
                                <Icons:PackIconMaterial Kind="ChartLine"
                                                        Width="28" Height="28"
                                                        Foreground="{StaticResource WarningBrush}"
                                                        Margin="0,0,0,12"/>
                                <TextBlock Text="0%"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Utilization Rate"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!--CONTACT INFORMATION-->
                    <TextBlock Text="Contact Information"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,16"/>

                    <Border Style="{StaticResource InfoCard}" Margin="0 0 0 24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!--EMAIL-->
                            <StackPanel Grid.Row="0"
                                        Grid.Column="0"
                                        Margin="0 0 24 20">
                                <StackPanel Orientation="Horizontal" Margin="0 0 0 8">
                                    <Border Width="40" Height="40"
                                            CornerRadius="10"
                                            Background="{StaticResource InfoLightBrush}"
                                            Margin="0 0 12 0">
                                        <Icons:PackIconMaterial Kind="Email"
                                                                VerticalAlignment="Center"
                                                                HorizontalAlignment="Center"
                                                                Width="20" Height="20"
                                                                Foreground="{StaticResource InfoBrush}"/>
                                    </Border>

                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Email Address"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                                        <TextBlock x:Name="tbEmail"
                                                   Text="{Binding Email}"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!--PHONE-->
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="24,0,0,20">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Width="40" Height="40"
                                            CornerRadius="10"
                                            Background="{StaticResource SuccessLightBrush}"
                                            Margin="0,0,12,0">
                                        <Icons:PackIconMaterial Kind="Phone"
                                                                VerticalAlignment="Center"
                                                                HorizontalAlignment="Center"
                                                                Width="20" Height="20"
                                                                Foreground="{StaticResource SuccessBrush}"/>
                                    </Border>

                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Phone Number"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                                        <TextBlock x:Name="tbPhone"
                                                   Text="{Binding Phone}"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!--ADDRESS-->
                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="40" Height="40"
                                            CornerRadius="10"
                                            Background="{StaticResource WarningLightBrush}"
                                            Margin="0,0,12,0">
                                        <Icons:PackIconMaterial Kind="MapMarkerRadius"
                                                                VerticalAlignment="Center"
                                                                HorizontalAlignment="Center"
                                                                Width="20" Height="20"
                                                                Foreground="{StaticResource WarningBrush}"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Full Address"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                                        <TextBlock x:Name="tbAddress"
                                                   Text="{Binding Address}"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!--MANAGEMENT-->
                    <TextBlock Text="Management"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,16"/>

                    <Border Style="{StaticResource InfoCard}" Margin="0,0,0,24">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="60" Height="60"
                                    CornerRadius="30"
                                    Background="{StaticResource PrimaryPaleBrush}"
                                    Margin="0,0,20,0">
                                <Icons:PackIconMaterial Kind="AccountTie"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center"
                                                        Width="30" Height="30"
                                                        Foreground="{StaticResource PrimaryBrush}"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Center Manager / Director"
                                           FontSize="12"
                                           Foreground="{StaticResource TextTertiaryBrush}"/>
                                <TextBlock x:Name="tbManager"
                                           Text="{Binding Manager}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!--FACILITIES & EQUIPMENT-->
                    <TextBlock Text="Facilities/Equipment"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,16"/>

                    <Border Style="{StaticResource InfoCard}">
                        <StackPanel>
                            <Border Background="{StaticResource PrimaryPaleBrush}"
                                    CornerRadius="10"
                                    Padding="16"
                                    Margin="0,0,0,16">
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Kind="InformationOutline"
                                                            Width="20" Height="20"
                                                            Foreground="{StaticResource PrimaryBrush}"
                                                            VerticalAlignment="Top"
                                                            Margin="0,0,12,0"/>
                                    <TextBlock x:Name="tbFacilities"
                                               Text="{Binding Facilities}"
                                               FontSize="14"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"
                                               LineHeight="22"/>
                                </StackPanel>
                            </Border>

                            <!--FACILITY TAGS-->
                            <WrapPanel x:Name="facilitiesTagsPanel">
                                <!--Tags will be added dynamically-->
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!--FOOTER-->
            <Border Grid.Row="2"
                    Background="{StaticResource PageBackgroundBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="40,20"
                    CornerRadius="0,0,22,22">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Edit Center"
                            Name="btnEditCenter"
                            Style="{StaticResource PrimaryButton}"
                            Click="btnEditCenter_Click"
                            Padding="24,12"
                            Margin="0,0,12,0">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Kind="Pencil"
                                                            Width="16" Height="16"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,8,0"/>
                                    <TextBlock Text="Edit Center"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>

                    <Button Content="Delete Center"
                            Name="btnDeleteCenter"
                            Click="btnDeleteCenter_Click"
                            Style="{StaticResource SecondaryButton}"
                            Padding="24,12"
                            MinWidth="120"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
