<Window x:Class="TrainningCenter.Views.Windows.Assessments.AddEditAssessmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrainningCenter.Views.Windows.Assessments"
        xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:VM="clr-namespace:TrainningCenter.ViewModel"
        mc:Ignorable="d"
        Title="Create Assessment" 
        Height="720" Width="1000"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        Loaded="Window_Loaded">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Step Indicator Style -->
        <Style x:Key="StepCircle" TargetType="Border">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Assessment Type Card -->
        <Style x:Key="TypeCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#8147E7" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryUltraLightBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                    <Setter Property="BorderThickness" Value="3"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <VM:AssessmentViewModel />
    </Window.DataContext>

    <Border Background="White"
            Margin="30"
            CornerRadius="24"
            BorderBrush="{StaticResource PrimaryBrush}"
            BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect Color="#8147E7" BlurRadius="15" ShadowDepth="0" Opacity="0.4"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
                    CornerRadius="22,22,0,0"
                    Padding="40,32"
                    Background="{StaticResource PrimaryGradient}">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon -->
                    <Border Grid.Column="0"
                            Width="70" Height="70"
                            CornerRadius="35"
                            Background="White"
                            Margin="0,0,24,0">
                        <Icons:PackIconMaterial Kind="ClipboardPlusOutline"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                Width="35" Height="35"
                                                Foreground="{StaticResource PrimaryBrush}"/>
                    </Border>
                    <!-- Title -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Create New Assessment"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock x:Name="tbHeaderSubtitle"
                                   Text="Step 1: Choose Assessment Type"
                                   FontSize="15"
                                   Foreground="White"
                                   Opacity="0.9"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Close Button -->
                    <Button Grid.Column="2"
                            x:Name="btnClose"
                            Click="btnClose_Click"
                            Style="{StaticResource CloseButton}"
                            VerticalAlignment="Top">
                        <Icons:PackIconMaterial Kind="Close"
                                                Width="20" Height="20"
                                                Foreground="White"/>
                    </Button>
                </Grid>
            </Border>

            <!-- MAIN CONTENT -->
            <Grid Grid.Row="1" Margin="40,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDEBAR - STEP INDICATORS -->
                <Border Grid.Column="0"
                        Background="{StaticResource PageBackgroundBrush}"
                        CornerRadius="16"
                        Padding="16"
                        Margin="0,0,24,0">
                    <StackPanel>
                        <TextBlock Text="STEPS"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   Margin="0,0,0,24"/>

                        <!-- Step 1 -->
                        <StackPanel x:Name="step1Indicator" Margin="0,0,0,32">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="48" Height="48"
                                        CornerRadius="24"
                                        Background="White"
                                        BorderBrush="{StaticResource PrimaryBrush}"
                                        BorderThickness="3"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="1"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Assessment Type"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Choose type"
                                               FontSize="11"
                                               Foreground="{StaticResource TextTertiaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Step 2 -->
                        <StackPanel x:Name="step2Indicator" Margin="0,0,0,32">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="step2Circle"
                                        Width="48" Height="48"
                                        CornerRadius="24"
                                        Background="#E0E0E0"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="2"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Basic Info"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Name and details"
                                               FontSize="11"
                                               Foreground="{StaticResource TextTertiaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                        <!-- Step 3 -->
                        <StackPanel x:Name="step3Indicator" Margin="0,0,0,32">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="step3Circle"
                                        Width="48" Height="48"
                                        CornerRadius="24"
                                        Background="#E0E0E0"
                                        Margin="0,0,12,0">
                                    <TextBlock Text="3"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Configuration"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Marks and duration"
                                               FontSize="11"
                                               Foreground="{StaticResource TextTertiaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- RIGHT CONTENT AREA -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <!-- STEP 1: ASSESSMENT TYPE SELECTION -->
                        <StackPanel x:Name="step1Content" Visibility="{Binding IsStep1, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Choose Assessment Type"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Select the type that best matches your assessment needs"
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,32"/>

                            <!-- Type Cards Grid -->
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Quiz Card -->
                                <Border Grid.Row="0" Grid.Column="0"
                                        x:Name="quizCard"
                                        Style="{StaticResource TypeCard}"
                                        MouseLeftButtonDown="TypeCard_Click"
                                        Tag="Quiz">
                                    <StackPanel>
                                        <Border Background="#E3F2FD"
                                                CornerRadius="12"
                                                Width="60" Height="60"
                                                Margin="0 0 0 16">
                                            <Icons:PackIconMaterial Kind="HelpCircleOutline"
                                                                    Width="32" Height="32"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Center"
                                                                    Foreground="#1976D2"/>
                                        </Border>
                                        <TextBlock Text="Quiz"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Short, quick knowledge check"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   LineHeight="18"/>
                                    </StackPanel>
                                </Border>

                                <!-- Theory Exam Card -->
                                <Border Grid.Row="0" Grid.Column="1"
                                        x:Name="theoryExamCard"
                                        Style="{StaticResource TypeCard}"
                                        MouseLeftButtonDown="TypeCard_Click"
                                        Tag="Theory Exam">
                                    <StackPanel>
                                        <Border Background="#FFF3E0"
                                                CornerRadius="12"
                                                Width="60" Height="60"
                                                Margin="0,0,0,16">
                                            <Icons:PackIconMaterial Kind="BookOpenPageVariant"
                                                                    Width="32" Height="32"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Center"
                                                                    Foreground="#F57C00"/>
                                        </Border>
                                        <TextBlock Text="Theory Exam"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Comprehensive written test"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   LineHeight="18"/>
                                    </StackPanel>
                                </Border>

                                <!-- Practical Exam Card -->
                                <Border Grid.Row="0" Grid.Column="2"
                                        x:Name="practicalExamCard"
                                        Style="{StaticResource TypeCard}"
                                        MouseLeftButtonDown="TypeCard_Click"
                                        Tag="Practical Test">
                                    <StackPanel>
                                        <Border Background="#E8F5E9"
                                                CornerRadius="12"
                                                Width="60" Height="60"
                                                Margin="0,0,0,16">
                                            <Icons:PackIconMaterial Kind="CodeTags"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Center"
                                                                    Width="32" Height="32"
                                                                    Foreground="#388E3C"/>
                                        </Border>
                                        <TextBlock Text="Practical Exam"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Hands-on skills evaluation"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   LineHeight="18"/>
                                    </StackPanel>
                                </Border>

                                <!-- Project Card -->
                                <Border Grid.Row="1" Grid.Column="0"
                                        x:Name="projectCard"
                                        Style="{StaticResource TypeCard}"
                                        MouseLeftButtonDown="TypeCard_Click"
                                        Tag="Project">
                                    <StackPanel>
                                        <Border Background="#F3E5F5"
                                                CornerRadius="12"
                                                Width="60" Height="60"
                                                Margin="0,0,0,16">
                                            <Icons:PackIconMaterial Kind="FolderMultiple"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Center"
                                                                    Width="32" Height="32"
                                                                    Foreground="#7B1FA2"/>
                                        </Border>
                                        <TextBlock Text="Project"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Long-term application work"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   LineHeight="18"/>
                                    </StackPanel>
                                </Border>

                                <!-- Assignment Card -->
                                <Border Grid.Row="1" Grid.Column="1"
                                        x:Name="assignmentCard"
                                        Style="{StaticResource TypeCard}"
                                        MouseLeftButtonDown="TypeCard_Click"
                                        Tag="Assignment">
                                    <StackPanel>
                                        <Border Background="#FFF9C4"
                                                CornerRadius="12"
                                                Width="60" Height="60"
                                                Margin="0,0,0,16">
                                            <Icons:PackIconMaterial Kind="ClipboardText"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Center"
                                                                    Width="32" Height="32"
                                                                    Foreground="#F9A825"/>
                                        </Border>
                                        <TextBlock Text="Assignment"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Homework or take-home task"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   LineHeight="18"/>
                                    </StackPanel>
                                </Border>

                                <!-- Presentation Card -->
                                <Border Grid.Row="1" Grid.Column="2"
                                        x:Name="presentationCard"
                                        Style="{StaticResource TypeCard}"
                                        MouseLeftButtonDown="TypeCard_Click"
                                        Tag="Presentation">
                                    <StackPanel>
                                        <Border Background="#E1F5FE"
                                                CornerRadius="12"
                                                Width="60" Height="60"
                                                Margin="0,0,0,16">
                                            <Icons:PackIconMaterial Kind="Presentation"
                                                                    VerticalAlignment="Center"
                                                                    HorizontalAlignment="Center"
                                                                    Width="32" Height="32"
                                                                    Foreground="#0277BD"/>
                                        </Border>
                                        <TextBlock Text="Presentation"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="Oral presentation assessment"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   LineHeight="18"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- STEP 2: BASIC INFO -->
                        <StackPanel x:Name="step2Content" 
                                    Visibility="{Binding IsStep2, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                            <TextBlock Text="Basic Information"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Enter the essential details for this assessment"
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,32"/>

                            <!-- Selected Type Display -->
                            <Border Background="{StaticResource PrimaryUltraLightBrush}"
                                    CornerRadius="12"
                                    Padding="16"
                                    Margin="0,0,0,24">
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial x:Name="selectedTypeIcon"
                                                            Kind="HelpCircleOutline"
                                                            Width="24" Height="24"
                                                            Foreground="{StaticResource PrimaryBrush}"
                                                            Margin="0,0,12,0"/>
                                    <StackPanel>
                                        <TextBlock Text="Selected Type"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                                        <TextBlock x:Name="tbSelectedType"
                                                   Text="Quiz"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource PrimaryBrush}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Assessment Name -->
                            <TextBlock Text="Assessment Name *"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <Border Background="{StaticResource InputBackgroundBrush}"
                                    CornerRadius="12"
                                    Padding="16,12"
                                    Margin="0,0,0,24">
                                <TextBox x:Name="txtAssessmentName"
                                         Style="{StaticResource ModernTextBox}"
                                         Text="{Binding AssessmentName, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="15"
                                         Tag="E.g., Introduction to Neural Networks"/>
                            </Border>

                            <!-- Specialization -->
                            <TextBlock Text="Specialization *"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <Border Background="{StaticResource InputBackgroundBrush}"
                                    CornerRadius="12"
                                    Padding="12,8"
                                    Margin="0,0,0,24">
                                <ComboBox x:Name="cmbSpecialization"
                                          Style="{StaticResource ModernComboBox}"
                                          ItemsSource="{Binding SpecializationsList}"
                                          SelectedValuePath="SpecializationID"
                                          SelectedValue="{Binding SpecializationID}"
                                          FontSize="15"
                                          Padding="10"
                                          BorderThickness="2"
                                          Background="White">
                                    <!-- THIS IS THE FIX -->
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <!-- This template explicitly binds to the TrainerName property -->
                                            <TextBlock Text="{Binding SpecializationName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>

                                </ComboBox>
                            </Border>

                            <!-- Instructions -->
                            <TextBlock Text="Instructions"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <Border Background="{StaticResource InputBackgroundBrush}"
                                    CornerRadius="12"
                                    Padding="16,12"
                                    Margin="0,0,0,0">
                                <TextBox x:Name="txtInstructions"
                                         Style="{StaticResource ModernTextBox}"
                                         Text="{Binding Instructions}"
                                         FontSize="14"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         Height="120"
                                         VerticalScrollBarVisibility="Auto"
                                         Tag="Enter assessment instructions and guidelines..."/>
                            </Border>
                        </StackPanel>

                        <!-- STEP 3: CONFIGURATION -->
                        <StackPanel x:Name="step3Content" Visibility="{Binding IsStep3, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}">
                            <TextBlock Text="Assessment Configuration"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Set up marks, duration, and other parameters"
                                       FontSize="14"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,32"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left Column -->
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <!-- Total Marks -->
                                    <TextBlock Text="Total Marks *"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,0,0,8"/>
                                    <Border Background="{StaticResource InputBackgroundBrush}"
                                            CornerRadius="12"
                                            Padding="16,12"
                                            Margin="0,0,0,24">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="txtTotalMarks"
                                                     Style="{StaticResource ModernTextBox}"
                                                     Text="{Binding SelectedAssessment.TotalMark, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="15"
                                                     Tag="100"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="marks"
                                                       FontSize="14"
                                                       Foreground="{StaticResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0,0,0"/>
                                        </Grid>
                                    </Border>

                                    <!-- Passing Marks -->
                                    <TextBlock Text="Passing Marks *"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,0,0,8"/>
                                    <Border Background="{StaticResource InputBackgroundBrush}"
                                            CornerRadius="12"
                                            Padding="16,12"
                                            Margin="0,0,0,24">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="txtPassingMarks"
                                                     Style="{StaticResource ModernTextBox}"
                                                     Text="{Binding SelectedAssessment.PassingMark, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="15"
                                                     Tag="70"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="marks"
                                                       FontSize="14"
                                                       Foreground="{StaticResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0,0,0"/>
                                        </Grid>
                                    </Border>

                                    <!-- Passing Percentage Display -->
                                    <Border Background="{StaticResource SuccessLightBrush}"
                                            CornerRadius="10"
                                            Padding="16,12"
                                            Margin="0,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Icons:PackIconMaterial Kind="CheckCircle"
                                                                    Width="20" Height="20"
                                                                    Foreground="{StaticResource SuccessBrush}"
                                                                    Margin="0,0,8,0"/>
                                            <TextBlock FontSize="13"
                                                       Foreground="{StaticResource SuccessBrush}">
                                                <Run Text="Pass requirement:"/>
                                                <Run x:Name="runPassPercentage" Text="70%" FontWeight="Bold"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Right Column -->
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <!-- Duration -->
                                    <TextBlock Text="Duration *"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               Margin="0,0,0,8"/>

                                    <Grid Margin="0,0,0,24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Hours -->
                                        <Border Grid.Column="0"
                                                Background="{StaticResource InputBackgroundBrush}"
                                                CornerRadius="12"
                                                Padding="16,12"
                                                Margin="0,0,6,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="txtHours"
                                                         Style="{StaticResource ModernTextBox}"
                                                         Text="{}"
                                                         FontSize="15"
                                                         Tag="0"
                                                         TextAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="hrs"
                                                           FontSize="14"
                                                           Foreground="{StaticResource TextTertiaryBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="4,0,0,0"/>
                                            </Grid>
                                        </Border>

                                        <!-- Minutes -->
                                        <Border Grid.Column="1"
                                                Background="{StaticResource InputBackgroundBrush}"
                                                CornerRadius="12"
                                                Padding="16,12"
                                                Margin="6,0,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="txtMinutes"
                                                         Style="{StaticResource ModernTextBox}"
                                                         FontSize="15"
                                                         Tag="45"
                                                         TextAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="min"
                                                           FontSize="14"
                                                           Foreground="{StaticResource TextTertiaryBrush}"
                                                           VerticalAlignment="Center"
                                                           Margin="4,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <!-- Quick Duration Buttons -->
                                    <TextBlock Text="Quick Select"
                                               FontSize="11"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               Margin="0,0,0,8"/>
                                    <UniformGrid Columns="3" Rows="2">
                                        <Button Content="30 min"
                                                Style="{StaticResource IconButton}"
                                                Background="{StaticResource PrimaryPaleBrush}"
                                                Width="100"
                                                Padding="6,6"
                                                FontSize="12"
                                                Margin="0,0,4,4"
                                                Click="QuickDuration_Click"
                                                Tag="30"/>
                                        <Button Content="45 min"
                                                Style="{StaticResource IconButton}"
                                                Background="{StaticResource PrimaryPaleBrush}"
                                                Width="100"
                                                Padding="8,6"
                                                FontSize="12"
                                                Margin="2,0,2,4"
                                                Click="QuickDuration_Click"
                                                Tag="45"/>
                                        <Button Content="1 hr"
                                                Style="{StaticResource IconButton}"
                                                Background="{StaticResource PrimaryPaleBrush}"
                                                Width="100"
                                                Padding="8,6"
                                                FontSize="12"
                                                Margin="4,0,0,4"
                                                Click="QuickDuration_Click"
                                                Tag="60"/>
                                        <Button Content="2 hrs"
                                                Style="{StaticResource IconButton}"
                                                Background="{StaticResource PrimaryPaleBrush}"
                                                Width="100"
                                                Padding="8,6"
                                                FontSize="12"
                                                Margin="0,4,4,0"
                                                Click="QuickDuration_Click"
                                                Tag="120"/>
                                        <Button Content="3 hrs"
                                                Style="{StaticResource IconButton}"
                                                Background="{StaticResource PrimaryPaleBrush}"
                                                Width="100"
                                                Padding="8,6"
                                                FontSize="12"
                                                Margin="2,4,2,0"
                                                Click="QuickDuration_Click"
                                                Tag="180"/>
                                        <Button Content="Custom"
                                                Style="{StaticResource IconButton}"
                                                Background="{StaticResource PrimaryPaleBrush}"
                                                Width="100"
                                                Padding="8,6"
                                                FontSize="12"
                                                Margin="4,4,0,0"/>
                                    </UniformGrid>

                                </StackPanel>
                            </Grid>
                            
                            <!-- Active Toggle -->
                            <Border Background="{StaticResource PageBackgroundBrush}"
                                    CornerRadius="12"
                                    Padding="20"
                                    Margin="0,32,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Icons:PackIconMaterial Grid.Column="0"
                                                            Kind="CheckCircleOutline"
                                                            Width="24" Height="24"
                                                            Foreground="{StaticResource SuccessBrush}"
                                                            Margin="0,0,16,0"/>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Activate Assessment"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Make this assessment available immediately after creation"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <CheckBox Grid.Column="2"
                                              x:Name="chkIsActive"
                                              IsChecked="True"
                                              VerticalAlignment="Center"
                                              Style="{StaticResource ModernCheckBox}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- FOOTER -->
            <Border Grid.Row="2"
                    Background="{StaticResource PageBackgroundBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="40,10"
                    CornerRadius="0,0,22,22">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Back Button -->
                    <Button x:Name="btnBack"
                            Grid.Column="0"
                            Content="← Back"
                            Style="{StaticResource SecondaryButton}"
                            Click="btnBack_Click"
                            Padding="24,12"
                            MinWidth="120"
                            Visibility="Collapsed"/>

                    <!-- Progress Text -->
                    <TextBlock x:Name="tbProgress"
                               Grid.Column="1"
                               Text="Step 1 of 3"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                Click="btnClose_Click"
                                Padding="24,12"
                                MinWidth="120"
                                Margin="0,0,12,0"/>

                        <Button x:Name="btnNext"
                                Content="Next →"
                                Style="{StaticResource PrimaryButton}"
                                Click="btnNext_Click"
                                Padding="24,12"
                                MinWidth="140"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
