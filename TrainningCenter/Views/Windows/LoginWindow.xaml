<Window x:Class="TrainningCenter.Views.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrainningCenter.Views.Windows"
        xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        Title="LoginWindow" 
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        Height="650" Width="1100">

    <Window.Resources>
        <!-- Modern Button Style -->
        <Style x:Key="LoginButton" TargetType="Button">
            <Setter Property="Background" Value="#8147E7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6C38C7"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="45,14,14,14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#202020"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#8147E7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- PasswordBox Style -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="45,14,45,14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#202020"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                        Padding="{TemplateBinding Padding}"
                                        VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#8147E7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Link Button Style -->
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8147E7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#6C38C7"/>
                    <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="White"
            CornerRadius="15"
            BorderBrush="#8147E7"
            BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect Color="#000000"
                              BlurRadius="30"
                              ShadowDepth="0"
                              Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <!-- ==================== LEFT SIDE - BRANDING ==================== -->
            <Border Grid.Column="0"
                    CornerRadius="13 0 0 13">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#8147E7" Offset="0"/>
                        <GradientStop Color="#A980F5" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo and Title -->
                    <StackPanel Grid.Row="0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">
                        <!-- Logo Circle -->
                        <Border Width="120"
                                Height="120"
                                Background="White"
                                CornerRadius="60"
                                Margin="0,0,0,30">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" 
                                                BlurRadius="20" 
                                                ShadowDepth="0" 
                                                Opacity="0.2"/>
                            </Border.Effect>
                            <Icons:PackIconMaterial Kind="SchoolOutline"
                                                    Width="70"
                                                    Height="70"
                                                    Foreground="#8147E7"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                        </Border>

                        <!-- App Title -->
                        <TextBlock Text="Training Center"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="Management System"
                                   FontSize="16"
                                   FontWeight="Medium"
                                   Foreground="#E0D4F7"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,40"/>

                        <!-- Features List -->
                        <StackPanel Margin="40,0">
                            <StackPanel Margin="0,0,0,15" Orientation="Horizontal">
                                <Icons:PackIconMaterial Kind="CheckCircle"
                                                        Width="20"
                                                        Height="20"
                                                        Foreground="White"
                                                        Margin="0,0,10,0"/>
                                <TextBlock Text="Manage Students and Trainers"
                                           FontSize="14"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <Icons:PackIconMaterial Kind="CheckCircle"
                                                        Width="20"
                                                        Height="20"
                                                        Foreground="White"
                                                        Margin="0,0,10,0"/>
                                <TextBlock Text="Track Attendance and Sessions"
                                           FontSize="14"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <Icons:PackIconMaterial Kind="CheckCircle"
                                                        Width="20"
                                                        Height="20"
                                                        Foreground="White"
                                                        Margin="0,0,10,0"/>
                                <TextBlock Text="Generate Reports and Certificates"
                                           FontSize="14"
                                           Foreground="White"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Footer -->
                    <StackPanel Grid.Row="1"
                                Margin="30,0,30,30">
                        <TextBlock Text="© 2025 Training Center"
                                   FontSize="12"
                                   Foreground="#E0D4F7"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,5"/>
                        <TextBlock Text="Version 1.3 Beta"
                                   FontSize="11"
                                   Foreground="#D0C4E7"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ==================== RIGHT SIDE - LOGIN FORM ==================== -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Close Button -->
                <Button Grid.Row="0"
                        Name="btnClose"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Width="40" Height="40"
                        Margin="20"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="btnClose_Click">
                    <Icons:PackIconMaterial Kind="Close"
                                            Width="20"
                                            Height="20"
                                            Foreground="#666666"/>
                </Button>

                <!-- Login Form -->
                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center"
                            Margin="60,0">

                    <!-- Welcome Text -->
                    <TextBlock Text="Welcome Back!"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#202020"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Please login to your account"
                               FontSize="14"
                               Foreground="#666666"
                               Margin="0,0,0,40"/>

                    <!-- Username Field -->
                    <TextBlock Text="Username"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#202020"
                               Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,20">
                        <TextBox Name="txtUsername"
                                 Style="{StaticResource ModernTextBox}"
                                 KeyDown="txtUsername_KeyDown"/>
                        <Icons:PackIconMaterial Kind="Account"
                                                Width="20"
                                                Height="20"
                                                Foreground="#999999"
                                                Margin="15,0,0,0"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left"
                                                IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Password Field -->
                    <TextBlock Text="Password"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#202020"
                               Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,10">
                        <PasswordBox x:Name="txtPassword"
                                     Style="{StaticResource ModernPasswordBox}"
                                     KeyDown="txtPassword_KeyDown"/>
                        <Icons:PackIconMaterial Kind="Lock"
                                                Width="20"
                                                Height="20"
                                                Foreground="#999999"
                                                Margin="15,0,0,0"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left"
                                                IsHitTestVisible="False"/>

                        <!-- Show/Hide Password Button -->
                        <Button x:Name="btnTogglePassword"
                                Width="40"
                                Height="40"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,5,0"
                                Click="btnTogglePassword_Click"
                                ToolTip="Show/Hide Password">
                            <Icons:PackIconMaterial x:Name="iconPasswordVisibility"
                                                    Kind="EyeOff"
                                                    Width="20"
                                                    Height="20"
                                                    Foreground="#999999"/>
                        </Button>
                    </Grid>

                    <!-- Remember Me & Forgot Password -->
                    <Grid Margin="0,0,0,30">
                        <CheckBox x:Name="chkRememberMe"
                                  Content="Remember me"
                                  FontSize="13"
                                  Foreground="#666"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Left"/>

                        <Button Content="Forgot Password?" Style="{StaticResource LinkButton}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Click="Button_Click" Margin="374,0,0,0"/>
                    </Grid>

                    <!-- Error Message -->
                    <Border x:Name="ErrorMessage"
                            Background="#FFEBEE"
                            BorderBrush="#F44336"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,20"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <Icons:PackIconMaterial Kind="AlertCircle"
                                                    Width="18"
                                                    Height="18"
                                                    Foreground="#F44336"
                                                    Margin="0,0,10,0"
                                                    VerticalAlignment="Center"/>

                            <TextBlock x:Name="tbErrorMessage"
                                       Text="Invalid username or password"
                                       FontSize="13"
                                       Foreground="#F44336"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Login Button -->
                    <Button Name="btnLogin" 
                            Content="Login"
                            Style="{StaticResource LoginButton}"
                            Click="btnLogin_Click"/>

                    <!-- Divider -->
                    <Grid Margin="0,30,0,20">
                        <Separator Height="1" Background="#E0E0E0"/>
                        <Border Background="White"
                                Padding="10,0"
                                HorizontalAlignment="Center">
                            <TextBlock Text="OR"
                                       FontSize="12"
                                       Foreground="#999999"/>
                        </Border>
                    </Grid>

                    <!-- Quick Login Options -->
                    <TextBlock Text="Quick Login (Demo)"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#666"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="Admin"
                                Grid.Column="0"
                                Height="40"
                                Background="#F5F7FA"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                Foreground="#666"
                                FontSize="13"
                                FontWeight="Medium"
                                Cursor="Hand"
                                Click="btnQuickAdmin_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E8E4F3"/>
                                            <Setter Property="BorderBrush" Value="#8147E7"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Content="User"
                                Grid.Column="2"
                                Height="40"
                                Background="#F5F7FA"
                                BorderBrush="#E0E0E0"
                                BorderThickness="1"
                                Foreground="#666666"
                                FontSize="13"
                                FontWeight="Medium"
                                Cursor="Hand"
                                Click="btnQuickUser_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E8E4F3"/>
                                            <Setter Property="BorderBrush" Value="#8147E7"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </StackPanel>

                <!-- ==================== LOADING OVERLAY ==================== -->
                <Border x:Name="LoadingOverlay"
                        Grid.ColumnSpan="2"
                        Background="#CC000000"
                        CornerRadius="15"
                        Visibility="Collapsed">
                    <Border Background="White"
                            CornerRadius="10"
                            Padding="40,30"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <StackPanel>
                            <ProgressBar IsIndeterminate="True" 
                                         Width="200"
                                         Height="4"
                                         Foreground="#8147E7"
                                         Background="#E8E4F3"/>
                            <TextBlock Text="Logging in..." 
                                   Foreground="#202020"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,20,0,0"
                                   HorizontalAlignment="Center"/>
                            <TextBlock Text="Please wait" 
                                   Foreground="#666666"
                                   FontSize="12"
                                   Margin="0,5,0,0"
                                   HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </Border>

            </Grid>

        </Grid>
    </Border>
</Window>
