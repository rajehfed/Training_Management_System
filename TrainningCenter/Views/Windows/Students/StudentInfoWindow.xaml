<Window x:Class="TrainningCenter.Views.Windows.Students.StudentInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrainningCenter.Views.Windows.Students"
        xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        Title="StudentInfoWindow" 
        Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True">
    
    <Border Background="White"
            CornerRadius="20"
            BorderThickness="2"
            BorderBrush="{StaticResource PrimaryBrush}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!--
            ═══════════════════════════════════════════════════════════════════════════
                HEADER SECTION
                    Avatar,
                    Student Full Name & StudentNo, 
                    Icon and Close Button
            ═══════════════════════════════════════════════════════════════════════════
            -->

            <Border Grid.Row="0"
                    MouseLeftButtonDown="Border_MouseLeftButtonDown"
                    Background="{StaticResource PrimaryBrush}"
                    CornerRadius="18 18 0 0"
                    Padding="24 14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!--AVATAR-->
                    <Border Grid.Column="0"
                            Width="44" Height="44"
                            CornerRadius="32"
                            Background="White"
                            Margin="0 0 16 0">
                        <TextBlock x:Name="tbInitials"
                                   Text="{Binding Initials}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    
                    <!--NAME AND STATUS-->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="tbFullName"
                                   Text="{Binding FullName}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock x:Name="tbStudentNumber"
                                   Text="{Binding StudentNumber}"
                                   FontSize="13"
                                   Foreground="#E0E0E0"
                                   Margin="0,4,0,0"/>

                        <Border x:Name="statusBadge"
                                CornerRadius="10"
                                Padding="8,4"
                                Background="{StaticResource SuccessLightBrush}"
                                HorizontalAlignment="Left"
                                Margin="0 4 0 0">
                            <TextBlock x:Name="tbStatus"
                                       Text="{Binding DisplayStatus}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource SuccessBrush}"/>
                        </Border>
                    </StackPanel>

                    <!--CLOSE BUTTON-->
                    <Button Grid.Column="2"
                            Style="{StaticResource CloseButton}"
                            Name="btnClose"
                            Click="btnClose_Click"
                            VerticalAlignment="Center">
                        <Icons:PackIconMaterial Kind="Close"
                                                Width="18"
                                                Height="18"
                                                Foreground="White"/>
                    </Button>
                </Grid>
            </Border>

            <!--
            ═══════════════════════════════════════════════════════════════════════════
                CONTENT SECTION
                    Contact Information,
                    Academic Information, 
                    Person Information
            ═══════════════════════════════════════════════════════════════════════════
            -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="32 24">
                <StackPanel>
                    
                    <!--CONTACT INFORMATION-->
                    <TextBlock Text="{Binding Email}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0 0 0 16"/>
                    
                    <!--EMAIL-->
                    <Grid Margin="0 0 0 16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="40" Height="40"
                                CornerRadius="10"
                                Background="{StaticResource InfoLightBrush}"
                                Margin="0 0 12 0">
                            <Icons:PackIconMaterial Kind="Email"
                                                    Width="20"
                                                    Height="20"
                                                    Foreground="{StaticResource InfoBrush}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Email Address"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                            <TextBlock x:Name="tbEmail"
                                       Text="john.doe@example.com"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                    
                    <!--PHONE-->
                    <Grid Margin="0 0 0 16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="40"
                                Height="40"
                                CornerRadius="10"
                                Background="{StaticResource SuccessLightBrush}"
                                Margin="0,0,12,0">
                            <Icons:PackIconMaterial Kind="Phone"
                                                    Width="20"
                                                    Height="20"
                                                    Foreground="{StaticResource SuccessBrush}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Phone}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                            <TextBlock x:Name="tbPhone"
                                       Text="(555) 123-4567"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!--ADDRESS-->
                    <Grid Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="40"
                                Height="40"
                                CornerRadius="10"
                                Background="{StaticResource WarningLightBrush}"
                                Margin="0,0,12,0">
                            <Icons:PackIconMaterial Kind="MapMarker"
                                                    Width="20"
                                                    Height="20"
                                                    Foreground="{StaticResource WarningBrush}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Address"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                            <TextBlock x:Name="tbAddress"
                                       Text="{Binding Address}"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!--ACADEMIC INFORMATION-->
                    <TextBlock Text="Academic Information"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,16"/>

                    <!--ADMISSION DATE-->
                    <Grid Margin="0 0 0 16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="40"
                                Height="40"
                                CornerRadius="10"
                                Background="{StaticResource PrimaryPaleBrush}"
                                Margin="0,0,12,0">
                            <Icons:PackIconMaterial Kind="Calendar"
                                                    Width="20"
                                                    Height="20"
                                                    Foreground="{StaticResource PrimaryBrush}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Admission Date"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                            <TextBlock x:Name="tbAdmissionDate"
                                       Text="{Binding AdmissionDate}"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,2,0,0"/>
                            <TextBlock x:Name="tbEnrollmentDuration"
                                       Text="2 months ago"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!--EMERGENCY CONTACT-->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="40"
                                Height="40"
                                CornerRadius="10"
                                Background="{StaticResource DangerLightBrush}"
                                Margin="0,0,12,0">
                            <Icons:PackIconMaterial Kind="Phone"
                                                    Width="20"
                                                    Height="20"
                                                    Foreground="{StaticResource DangerBrush}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Emergency Contact"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                            <TextBlock x:Name="tbEmergencyContact"
                                       Text="{Binding EmergencyContact}"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!--PERSONAL INFO-->
                    <TextBlock Text="Personal Information"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,8,0,16"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!--DATE OF BIRTH-->
                        <StackPanel Grid.Column="0" Margin="0 0 8 0">
                            <TextBlock Text="Date of Birth"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                            <TextBlock x:Name="tbDateOfBirth"
                                       Text="{Binding DateOfBirth}"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0 4 0 0"/>
                        </StackPanel>

                        <!--GENDER-->
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Gender"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                            <TextBlock x:Name="tbGender"
                                       Text="{Binding Gender}"
                                       FontSize="13"
                                       FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!--
            ═══════════════════════════════════════════════════════════════════════════
                FOOTER SECTION
                    Edit Student Button,
                    Close Button
            ═══════════════════════════════════════════════════════════════════════════
            -->
            <Border Grid.Row="2"
                    Background="{StaticResource PageBackgroundBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="32,20"
                    CornerRadius="0,0,18,18">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Edit Student"
                            Style="{StaticResource PrimaryButton}"
                            Name="btnEdit"
                            Click="btnEdit_Click"
                            Padding="24 12"
                            Margin="0 0 12 0">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Kind="Pencil"
                                                            Width="16"
                                                            Height="16"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,8,0"/>
                                    <TextBlock Text="Edit Student"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>

                    <Button Click="btnClose_Click"
                            Content="Cancel"
                            Style="{StaticResource SecondaryButton}"
                            Padding="24,12"
                            MinWidth="100"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
