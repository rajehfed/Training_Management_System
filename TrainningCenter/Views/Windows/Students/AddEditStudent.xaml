<Window x:Class="TrainningCenter.Views.Windows.AddEditStudent"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrainningCenter.Views.Windows"
        xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:UC="clr-namespace:TrainningCenter.UserControles"
        mc:Ignorable="d"
        Title="Add New Student"
        Height="760"
        Width="600"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Error Message Style -->
        <Style x:Key="ErrorText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="Visibility" Value="Collapsed"/>
        </Style>
    </Window.Resources>
    <Border Background="White"
            CornerRadius="20"
            BorderBrush="{StaticResource PrimaryBrush}"
            BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!--
            ═══════════════════════════════════════════════════════════════════════════
                HEADER SECTION
                    Page Title,
                    Subtitle, 
                    Icon and Close Button
            ═══════════════════════════════════════════════════════════════════════════
            -->
            <Border Grid.Row="0"
                    MouseLeftButtonDown="Border_MouseLeftButtonDown"
                    Background="{StaticResource PrimaryBrush}"
                    CornerRadius="18 18 0 0"
                    Padding="32,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!--ICON-->
                    <Border Grid.Column="0"
                            Background="White"
                            Width="48"
                            Height="48"
                            CornerRadius="24"
                            Margin="0 0 16 0">
                        <Icons:PackIconMaterial x:Name="iconHeader"
                                                Kind="AccountPlus"
                                                Width="24"
                                                Height="24"
                                                Foreground="{StaticResource PrimaryBrush}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"/>
                    </Border>

                    <!--TITLE-->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="tbTitle"
                                   Text="Add New Student"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock x:Name="tbSubtitle"
                                   Text="Fill in the student information below"
                                   FontSize="13"
                                   Foreground="#E0E0E0"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!--CLOSE BUTTON-->
                    <Button Grid.Column="2"
                            Style="{StaticResource CloseButton}"
                            x:Name="btnClose"
                            Click="btnClose_Click">
                        <Icons:PackIconMaterial Kind="Close"
                                                Width="18"
                                                Height="18"
                                                Foreground="White"/>
                    </Button>
                </Grid>
            </Border>

            <!--
            ═══════════════════════════════════════════════════════════════════════════
                FORM CONTENT:
                    1- Personal Information Section,
                    2- Academic Information Section
                        Student Number,
                        Admission Date,
                        Student Status,
                        Emergency Contact,
                        Active Status Checkbox
            ═══════════════════════════════════════════════════════════════════════════
            -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Padding="32,24">
                <StackPanel>

                    <!--PERSONAL INFORMATION SECTION-->
                    <TextBlock Text="Personal Information"
                               Style="{StaticResource SectionHeader}"/>
                    <!--Person Selector-->
                    <UC:PersonSelector x:Name="personSelector"
                                       PersonSelectionChanged="personSelector_PersonSelectionChanged" />

                    <Separator Background="{StaticResource PrimaryPaleBrush}" Margin="0,16,0,0"/>

                    <!-- Academic Information Section -->
                    <TextBlock Text="Academic Information"
                               Style="{StaticResource SectionHeader}"
                               Margin="0,24,0,0"/>
                    <Grid Margin="0 16 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!--Student Number-->
                        <StackPanel Grid.ColumnSpan="3" Grid.Row="0">
                            <TextBlock Text="Student Number *"
                                       Style="{StaticResource FormLabel}"/>
                            <TextBox x:Name="txtStudentNumber"
                                     Text="{Binding StudentNumber}"
                                     Style="{StaticResource ModernTextBox}"
                                     Tag="e.g., STU-2024-001"/>
                            <TextBlock x:Name="errorStudentNumber"
                                       Text="Student number is required"
                                       Style="{StaticResource ErrorText}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="0" Grid.Row="2">
                            <TextBlock Text="Admission Date *"
                                       Style="{StaticResource FormLabel}"/>
                            <DatePicker x:Name="dpAdmissionDate"
                                        SelectedDate="{Binding AdmissionDate}"
                                        Style="{StaticResource FormDatePicker}"/>
                            <TextBlock x:Name="errorAdmissionDate"
                                       Text="Admission date is required"
                                       Style="{StaticResource ErrorText}"/>
                        </StackPanel>

                        <!-- Student Status -->
                        <StackPanel Grid.Column="2" Grid.Row="2">
                            <TextBlock Text="Student Status *"
                                       Style="{StaticResource FormLabel}"/>
                            <ComboBox x:Name="cmbStatus"
                                      SelectedItem="{Binding StudentStatus}"
                                      Style="{StaticResource ModernComboBox}">
                                <ComboBoxItem Content="Active" 
                                              Style="{StaticResource ModernComboBoxItem}" 
                                              IsSelected="True"/>
                                <ComboBoxItem Content="Inactive" Style="{StaticResource ModernComboBoxItem}"/>
                                <ComboBoxItem Content="Suspended" Style="{StaticResource ModernComboBoxItem}"/>
                                <ComboBoxItem Content="Graduated" Style="{StaticResource ModernComboBoxItem}"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Emergency Contact -->
                    <StackPanel Margin="0,16,0,0">
                        <TextBlock Text="Emergency Contact"
                                   Style="{StaticResource FormLabel}"/>
                        <TextBox x:Name="txtEmergencyContact"
                                 Text="{Binding EmergencyContact}"
                                 Style="{StaticResource ModernTextBox}"
                                 Tag="Name and phone number"/>
                    </StackPanel>

                    <!-- Active Status Checkbox -->
                    <CheckBox x:Name="chkIsActive"
                              IsChecked="{Binding IsActive}"
                              Content="Student is currently active"
                              Style="{StaticResource ModernCheckBox}"
                              Margin="0,20,0,0"/>
                    
                    <!--info panel-->
                    <Border Style="{StaticResource InfoPanel}"
                            Margin="0 20 0 0">
                        <StackPanel Orientation="Horizontal">
                            <Icons:PackIconMaterial Kind="InformationOutline"
                                                    Width="20"
                                                    Height="20"
                                                    Foreground="{StaticResource PrimaryBrush}"
                                                    VerticalAlignment="Top"
                                                    Margin="0,0,12,0"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12">
                                <Run Text="Fields marked with"/>
                                <Run Text="*" FontWeight="Bold" Foreground="{StaticResource DangerBrush}"/>
                                <Run Text="are required. Make sure all information is accurate before saving."/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                </StackPanel>


            </ScrollViewer>

            <!--
            ═══════════════════════════════════════════════════════════════════════════
                FOOTER - ACTION BUTTONS
                    Left Side: SAVE BUTTON,
                               CANCEL BUTTON,
                    Right Side: DELETE BUTTON (ONLY IN EDIT MODE)
            ═══════════════════════════════════════════════════════════════════════════
            -->
            <Border Grid.Row="2"
                    Background="{StaticResource PageBackgroundBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0 1 0 0"
                    Padding="32,20"
                    CornerRadius="0 0 18 18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Side - Delete Button (Only in Edit Mode) -->
                    <Button x:Name="btnDelete"
                            Grid.Column="0"
                            Style="{StaticResource DangerButton}"
                            Content="Delete Student"
                            HorizontalAlignment="Left"
                            Visibility="Collapsed"
                            Click="btnDelete_Click"
                            Padding="20,12">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Kind="Delete"
                                                            Width="16"
                                                            Height="16"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,8,0"/>
                                    <TextBlock Text="Delete Student"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>

                    <!-- Right Side - Cancel & Save Buttons -->
                    <StackPanel Orientation="Horizontal" Grid.Column="1"
                                HorizontalAlignment="Right">
                        <Button Content="Cancel"
                                Name="btnCancel"
                                Style="{StaticResource SecondaryButton}"
                                Click="btnCancel_Click"
                                Padding="24,12"
                                MinWidth="120"
                                Margin="0 0 12 0"/>

                        <Button x:Name="btnSave"
                                Content="Save Student"
                                Style="{StaticResource PrimaryButton}"
                                Click="btnSave_Click"
                                Padding="24,12"
                                MinWidth="120">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Icons:PackIconMaterial x:Name="iconSave"
                                                                Kind="ContentSave"
                                                                Width="16"
                                                                Height="16"
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,8,0"/>
                                        <TextBlock x:Name="textSave"
                                                   Text="Save Student"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
