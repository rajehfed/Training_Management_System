<Window x:Class="TrainningCenter.Views.Windows.ExportConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrainningCenter.Views.Windows"
        xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
        mc:Ignorable="d"
        Title="Export Data"
        Height="650"
        Width="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        Margin="20">

    <Window.Resources>
        <!-- Format Option Card Style -->
        <Style x:Key="FormatCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#8147E7"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="White"
            CornerRadius="20"
            BorderThickness="2"
            BorderBrush="{StaticResource PrimaryBrush}">
        <Border.Effect>
            <DropShadowEffect Color="#8147E7" BlurRadius="40" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
                    CornerRadius="18,18,0,0"
                    Padding="32,24">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#8147E7" Offset="0"/>
                        <GradientStop Color="#A980F5" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Icon -->
                    <Border Grid.Column="0"
                            Width="56" Height="56"
                            CornerRadius="28"
                            Background="White"
                            Margin="0,0,16,0">
                        <Icons:PackIconMaterial Kind="ExportVariant"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                Width="28" Height="28"
                                                Foreground="{StaticResource PrimaryBrush}"/>
                    </Border>

                    <!-- Title -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Export Data"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Choose format and configure options"
                                   FontSize="13"
                                   Foreground="White"
                                   Opacity="0.9"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Close Button -->
                    <Button x:Name="btnClose"
                            Click="btnClose_Click"
                            Style="{StaticResource CloseButton}"
                            Grid.Column="2"
                            VerticalAlignment="Top">
                        <Icons:PackIconMaterial Kind="Close"
                                                Width="18" Height="18"
                                                Foreground="White"/>
                    </Button>
                </Grid>
            </Border>

            <!-- CONTENT -->
            <ScrollViewer Grid.Row="1" 
                          VerticalScrollBarVisibility="Auto"
                          Padding="32,24">
                <StackPanel>
                    <!-- EXPORT FORMAT SELECTION -->
                    <TextBlock Text="Select Export Format"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,0,16"/>

                    <!-- Excel Format -->
                    <Border x:Name="excelCard"
                            Style="{StaticResource FormatCard}"
                            MouseLeftButtonDown="excelCard_MouseLeftButtonDown"
                            Tag="Excel">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon -->
                            <Border Grid.Column="0"
                                    Width="48" Height="48"
                                    CornerRadius="10"
                                    Background="#E8F5E9"
                                    Margin="0,0,16,0">
                                <Icons:PackIconMaterial Kind="FileExcel"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Width="24" Height="24"
                                                        Foreground="#28A745"/>
                            </Border>

                            <!-- Info -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Excel Spreadsheet (.xlsx)"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Best for data analysis and manipulation"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Radio -->
                            <RadioButton x:Name="rbExcel"
                                         Grid.Column="2"
                                         GroupName="ExportFormat"
                                         IsChecked="True"
                                         VerticalAlignment="Center"
                                         Style="{StaticResource ModernRadioButton}"/>
                        </Grid>
                    </Border>

                    <!-- PDF Format -->
                    <Border x:Name="pdfCard"
                            Style="{StaticResource FormatCard}"
                            MouseLeftButtonDown="pdfCard_MouseLeftButtonDown"
                            Tag="PDF">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon -->
                            <Border Grid.Column="0"
                                    Width="48" Height="48"
                                    CornerRadius="10"
                                    Background="#FFEBEE"
                                    Margin="0,0,16,0">
                                <Icons:PackIconMaterial Kind="FilePdfBox"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center"
                                                        Width="24" Height="24"
                                                        Foreground="#DC3545"/>
                            </Border>

                            <!-- Info -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="PDF Document (.pdf)"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Best for printing and sharing reports"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Radio -->
                            <RadioButton x:Name="rbPdf"
                                         Grid.Column="2"
                                         GroupName="ExportFormat"
                                         VerticalAlignment="Center"
                                         Style="{StaticResource ModernRadioButton}"/>
                        </Grid>
                    </Border>

                    <!-- EXCEL-SPECIFIC OPTIONS (Visible when Excel selected) -->
                    <StackPanel x:Name="excelOptions" Margin="0,24,0,0">
                        <TextBlock Text="Excel Options"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,16"/>

                        <!-- Sheet Name -->
                        <Border Background="{StaticResource InputBackgroundBrush}"
                                CornerRadius="12"
                                Padding="16,12"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Sheet Name"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,8"/>
                                <TextBox x:Name="txtSheetName"
                                         Style="{StaticResource ModernTextBox}"
                                         Text="Data Export"
                                         FontSize="14"
                                         BorderThickness="0"
                                         Background="Transparent"/>
                            </StackPanel>
                        </Border>

                        <!-- Auto-fit Columns -->
                        <CheckBox x:Name="chkAutoFit"
                                  Content="Auto-fit column widths"
                                  IsChecked="True"
                                  Style="{StaticResource ModernCheckBox}"
                                  Margin="0,0,0,12"/>

                        <!-- Include Headers -->
                        <CheckBox x:Name="chkIncludeHeaders"
                                  Content="Include column headers"
                                  IsChecked="True"
                                  Style="{StaticResource ModernCheckBox}"/>
                    </StackPanel>

                    <!-- PDF-SPECIFIC OPTIONS (Visible when PDF selected) -->
                    <StackPanel x:Name="pdfOptions" 
                                Visibility="Collapsed"
                                Margin="0,24,0,0">
                        <TextBlock Text="PDF Options"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,16"/>

                        <!-- Document Title -->
                        <Border Background="{StaticResource InputBackgroundBrush}"
                                CornerRadius="12"
                                Padding="16,12"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Document Title"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,8"/>
                                <TextBox x:Name="txtDocumentTitle"
                                         Style="{StaticResource ModernTextBox}"
                                         Text="Data Report"
                                         FontSize="14"
                                         BorderThickness="0"
                                         Background="Transparent"/>
                            </StackPanel>
                        </Border>

                        <!-- Include Page Numbers -->
                        <CheckBox x:Name="chkPageNumbers"
                                  Content="Include page numbers"
                                  IsChecked="True"
                                  Style="{StaticResource ModernCheckBox}"
                                  Margin="0,0,0,12"/>

                        <!-- Include Date/Time -->
                        <CheckBox x:Name="chkDateTime"
                                  Content="Include date and time"
                                  IsChecked="True"
                                  Style="{StaticResource ModernCheckBox}"/>
                    </StackPanel>

                    <!-- FILE LOCATION -->
                    <StackPanel Margin="0,24,0,0">
                        <TextBlock Text="Save Location"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,16"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="{StaticResource InputBackgroundBrush}"
                                    CornerRadius="12"
                                    Padding="16,12"
                                    Margin="0,0,12,0">
                                <TextBox x:Name="txtFilePath"
                                         Style="{StaticResource ModernTextBox}"
                                         Text="C:\Exports\"
                                         IsReadOnly="True"
                                         FontSize="13"
                                         BorderThickness="0"
                                         Background="Transparent"/>
                            </Border>

                            <Button Grid.Column="1"
                                    Content="Browse"
                                    Style="{StaticResource SecondaryButton}"
                                    x:Name="btnBrowse"
                                    Click="btnBrowse_Click"
                                    Padding="20,12"
                                    MinWidth="100"/>
                        </Grid>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- FOOTER -->
            <Border Grid.Row="2"
                    Background="{StaticResource PageBackgroundBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="32,20"
                    CornerRadius="0,0,18,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Info -->
                    <StackPanel Grid.Column="0" 
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Icons:PackIconMaterial Kind="Information"
                                                Width="16" Height="16"
                                                Foreground="{StaticResource InfoBrush}"
                                                Margin="0,0,8,0"/>
                        <TextBlock x:Name="tbRecordCount"
                                   Text="Ready to export 247 records"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <!-- Action Buttons -->
                    <StackPanel Grid.Column="1" 
                                Orientation="Horizontal">

                        <Button Content="Cancel"
                                Style="{StaticResource SecondaryButton}"
                                Click="btnClose_Click"
                                Padding="24,12"
                                MinWidth="100"
                                Margin="0,0,12,0"/>

                        <Button x:Name="btnExport"
                                Content="Export"
                                Style="{StaticResource PrimaryButton}"
                                Click="btnExport_Click"
                                Padding="24,12"
                                MinWidth="120">
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Icons:PackIconMaterial Kind="FileExport"
                                                                Width="16" Height="16"
                                                                Foreground="White"
                                                                Margin="0,0,8,0"/>
                                        <TextBlock Text="Export" 
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
