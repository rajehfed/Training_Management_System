<Application x:Class="TrainningCenter.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TrainningCenter"
             xmlns:Convert="clr-namespace:TrainningCenter.Converters"
             StartupUri="Views/Windows/LoginWindow.xaml">
    <Application.Resources>

        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--
                ═══════════════════════════════════════════════════════════════
                    IMPORTANT: Colors must be loaded FIRST
                ═══════════════════════════════════════════════════════════════
                -->
                <ResourceDictionary Source="/Views/Styles/Colors.xaml"/>

                <!--
                ═══════════════════════════════════════════════════════════════
                    COMPONENT STYLES
                    Load in logical order based on dependencies
                ═══════════════════════════════════════════════════════════════
                -->
                <ResourceDictionary Source="/Views/Styles/CardsStyles.xaml"/>
                <ResourceDictionary Source="/Views/Styles/ButtonsStyle.xaml"/>
                <ResourceDictionary Source="/Views/Styles/TextBoxStyles.xaml"/>
                <ResourceDictionary Source="/Views/Styles/ComboBoxesStyles.xaml"/>
                <ResourceDictionary Source="/Views/Styles/CheckBoxesStyles.xaml"/>
                <ResourceDictionary Source="/Views/Styles/FormStyles.xaml"/>
                <ResourceDictionary Source="/Views/Styles/DataGridStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Convert:UpperCaseConverter x:Key="UpperCaseConverter"/>
            <Convert:AttendanceStatusToBooleanConverter x:Key="AttendanceStatusToBool" />
            <Convert:AttendanceStatusToBrushConverter x:Key="AttendanceStatusToBrush" />
            <Convert:AttendanceStatusToIconConverter x:Key="AttendanceStatusToIcon" />
            <Convert:AttendanceStatusToVisibilityConverter x:Key="AttendanceStatusToVis" />
            <Convert:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <Convert:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <Convert:StatusToColorConverter x:Key="StatusToColor"/>
            <Convert:StringToVisibilityConverter x:Key="StringToVis"/>
            <Convert:ColorToLightBrushConverter x:Key="ColorToLighConv" />

            <!--
            ═══════════════════════════════════════════════════════════════════
                MENU BUTTON STYLES (MainWindow Sidebar)
                These are specific to the sidebar menu navigation
            ═══════════════════════════════════════════════════════════════════
            -->

            <!-- Regular Menu Button -->
            <Style x:Key="menuButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="#202020" />
                <Setter Property="Margin" Value="5 0 0 5" />
                <Setter Property="Height" Value="45" />
                <Setter Property="Width" Value="220" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="8" 
                                    BorderThickness="4 0 0 0" 
                                    BorderBrush="Transparent">
                                <ContentPresenter HorizontalAlignment="Stretch" 
                                                VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#EEEEEE" />
                        <Setter Property="Foreground" Value="#8147E7" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Active Menu Button -->
            <Style x:Key="menuButtonActive" TargetType="Button">
                <Setter Property="Background" Value="#F8F5FF" />
                <Setter Property="Foreground" Value="#8147E7" />
                <Setter Property="Margin" Value="5 0 0 5" />
                <Setter Property="Height" Value="45" />
                <Setter Property="Width" Value="220" />
                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border CornerRadius="8" 
                                    Background="{TemplateBinding Background}" 
                                    BorderThickness="4 0 0 0" 
                                    BorderBrush="Transparent">
                                <ContentPresenter HorizontalAlignment="Stretch" 
                                                VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Menu Button Icon -->
            <Style x:Key="menuButtonIcon" TargetType="Icons:PackIconMaterial">
                <Setter Property="Width" Value="23" />
                <Setter Property="Height" Value="23" />
                <Setter Property="Margin" Value="35 0 20 0" />
                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            </Style>

            <!-- Menu Button Icon Active -->
            <Style x:Key="menuButtonIconActive" TargetType="Icons:PackIconMaterial">
                <Setter Property="Width" Value="23" />
                <Setter Property="Height" Value="23" />
                <Setter Property="Margin" Value="35 0 20 0" />
                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            </Style>

            <!-- Menu Button Text -->
            <Style x:Key="menuButtonText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            </Style>

            <!-- Menu Button Text Active -->
            <Style x:Key="menuButtonTextActive" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
            </Style>

        </ResourceDictionary>

    </Application.Resources>
</Application>