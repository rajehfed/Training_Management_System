<UserControl x:Class="TrainningCenter.UserControles.Students.StudentSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TrainningCenter.UserControles.Students"
             xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Height="600"
             Padding="20">

    <UserControl.Resources>
        <!-- Shimmer Animation for Loading State -->
        <Storyboard x:Key="ShimmerAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="shimmerTransform"
                           Storyboard.TargetProperty="X"
                           From="-200" To="600"
                           Duration="0:0:1.5"/>
        </Storyboard>

        <!-- Fade In Animation -->
        <Storyboard x:Key="FadeInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1"
                           Duration="0:0:0.3"/>
        </Storyboard>

        <!-- Student Card Style with Hover Animation -->
        <Style x:Key="StudentCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1.02" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1.02" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)"
                                               To="1" Duration="0:0:0.2"/>
                                <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)"
                                               To="1" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                    <Setter Property="BorderBrush" Value="#8147E7"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#8147E7" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="BorderBrush" Value="#8147E7"/>
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#F8F5FF" Offset="0"/>
                                <GradientStop Color="#F0EDFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#8147E7" BlurRadius="25" ShadowDepth="0" Opacity="0.4"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Empty State Style -->
        <Style x:Key="EmptyStateCard" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <!--<Setter Property="BorderStyle" Value="Dashed"/>-->
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="40"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Main Content -->
        <Grid x:Name="mainContent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header with Stats -->
            <Border Grid.Row="0"
                    Background="White"
                    CornerRadius="16"
                    Padding="24,20"
                    Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="0" Opacity="0.06"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Title & Subtitle -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Select Student"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="tbSubtitle"
                                   Text="Choose a student from the list below"
                                   FontSize="14"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Stats Badge -->
                    <Border Grid.Column="1"
                            Background="{StaticResource PrimaryPaleBrush}"
                            CornerRadius="12"
                            Padding="16,10"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Icons:PackIconMaterial Kind="AccountGroup"
                                                    Width="20" Height="20"
                                                    Foreground="{StaticResource PrimaryBrush}"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,8,0"/>
                            <TextBlock x:Name="tbStudentCount"
                                       Text="0 Students"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Search Box with Advanced Features -->
            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="14"
                    Padding="0"
                    Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="0" Opacity="0.06"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search Icon -->
                    <Border Grid.Column="0"
                            Background="{StaticResource PrimaryPaleBrush}"
                            CornerRadius="14,0,0,14"
                            Padding="18,14">
                        <Icons:PackIconMaterial Kind="Magnify"
                                                Width="22" Height="22"
                                                Foreground="{StaticResource PrimaryBrush}"/>
                    </Border>

                    <!-- Search TextBox -->
                    <TextBox x:Name="txtSearch"
                             Grid.Column="1"
                             Style="{StaticResource SearchTextBox}"
                             FontSize="15"
                             Padding="16,14"
                             TextChanged="txtSearch_TextChanged"
                             Tag="Search by name, number, email..."/>

                    <!-- Clear Button -->
                    <Button x:Name="btnClearSearch"
                            Grid.Column="2"
                            Style="{StaticResource IconButton}"
                            Width="40" Height="40"
                            Margin="0,0,8,0"
                            Click="btnClearSearch_Click"
                            Visibility="Collapsed">
                        <Icons:PackIconMaterial Kind="Close"
                                                Width="18" Height="18"
                                                Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Filter Chips -->
            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        Margin="0,0,0,16"
                        x:Name="filterChips">
                <!-- All Students Chip -->
                <Border Background="{StaticResource PrimaryBrush}"
                        CornerRadius="10"
                        Padding="16,8"
                        Margin="0,0,8,0"
                        Cursor="Hand"
                        Tag="All"
                        MouseLeftButtonDown="FilterChip_Click">
                    <TextBlock Text="All Students"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="White"/>
                </Border>

                <!-- Active Chip -->
                <Border Background="White"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="2"
                        CornerRadius="10"
                        Padding="16,8"
                        Margin="0,0,8,0"
                        Cursor="Hand"
                        Tag="Active"
                        MouseLeftButtonDown="FilterChip_Click">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8"
                                 Fill="{StaticResource SuccessBrush}"
                                 Margin="0,0,6,0"/>
                        <TextBlock Text="Active"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Inactive Chip -->
                <Border Background="White"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="2"
                        CornerRadius="10"
                        Padding="16,8"
                        Margin="0,0,8,0"
                        Cursor="Hand"
                        Tag="Inactive"
                        MouseLeftButtonDown="FilterChip_Click">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8"
                                 Fill="{StaticResource DangerBrush}"
                                 Margin="0,0,6,0"/>
                        <TextBlock Text="Inactive"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Students List with Virtualization -->
            <ScrollViewer Grid.Row="3"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="studentsListControl" Padding="50">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource StudentCard}"
                                    Name="StudentCard"
                                    MouseLeftButtonDown="StudentCard_MouseLeftButtonDown"
                                    Tag="{Binding StudentID}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Avatar with Status Indicator -->
                                    <Grid Grid.Column="0" Margin="0,0,20,0">

                                        <!-- Avatar Background -->
                                        <Border Width="60" Height="60"
                                                CornerRadius="30">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#8147E7" Offset="0"/>
                                                    <GradientStop Color="#A980F5" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="{Binding Initials}"
                                                       FontSize="22"
                                                       FontWeight="Bold"
                                                       Foreground="White"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Status Indicator -->
                                        <Border Width="18" Height="18"
                                                CornerRadius="9"
                                                Background="{Binding StatusColor}"
                                                BorderBrush="White"
                                                BorderThickness="3"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"/>
                                    </Grid>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <!-- Name -->
                                        <TextBlock Text="{Binding FullName}"
                                                   FontSize="17"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                                        <!-- Student Number -->
                                        <TextBlock Text="{Binding StudentNumber}"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,4,0,0"/>

                                        <!-- Email & Phone -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                            <Icons:PackIconMaterial Kind="Email"
                                                                    Width="14" Height="14"
                                                                    Foreground="{StaticResource TextTertiaryBrush}"
                                                                    VerticalAlignment="Center"
                                                                    Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding Email}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,16,0"/>

                                            <Icons:PackIconMaterial Kind="Phone"
                                                                    Width="14" Height="14"
                                                                    Foreground="{StaticResource TextTertiaryBrush}"
                                                                    VerticalAlignment="Center"
                                                                    Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding FormattedPhone}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextTertiaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Status Badge -->
                                        <Border Background="{Binding StatusColor}"
                                                CornerRadius="6"
                                                Padding="8,4"
                                                HorizontalAlignment="Left"
                                                Margin="0,8,0,0"
                                                Opacity="0.15">
                                            <TextBlock Text="{Binding DisplayStatus}"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding StatusColor}"/>
                                        </Border>
                                    </StackPanel>

                                    <!-- Selection Indicator & Quick Info -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="16,0,0,0">
                                        <!-- Enrollment Duration -->
                                        <Border Background="{StaticResource InfoLightBrush}"
                                                CornerRadius="8"
                                                Padding="10,6"
                                                Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="ENROLLED"
                                                           FontSize="9"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource InfoBrush}"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="{Binding EnrollmentDuration}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource InfoBrush}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Selection Checkmark (Appears when selected) -->
                                        <Border Width="40" Height="40"
                                                CornerRadius="20"
                                                Background="{StaticResource SuccessBrush}"
                                                Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}">
                                            <Icons:PackIconMaterial Kind="Check"
                                                                    Width="24" Height="24"
                                                                    Foreground="White"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Arrow Icon (When not selected) -->
                                        <Icons:PackIconMaterial Kind="ChevronRight"
                                                                Width="28" Height="28"
                                                                Foreground="{StaticResource TextTertiaryBrush}"
                                                                Visibility="{Binding IsSelected, Converter={StaticResource InverseBoolToVis}}"/>

                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty State -->
            <Border Grid.Row="3"
                    x:Name="emptyState"
                    Style="{StaticResource EmptyStateCard}"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <Icons:PackIconMaterial Kind="AccountSearch"
                                            Width="80" Height="80"
                                            Foreground="{StaticResource TextTertiaryBrush}"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,20"/>
                    <TextBlock Text="No Students Found"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Try adjusting your search or filters"
                               FontSize="14"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Selected Student Footer -->
            <Border Grid.Row="4"
                    x:Name="selectedFooter"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,2,0,0"
                    Padding="24,16"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Selected Student Info -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Icons:PackIconMaterial Kind="CheckCircle"
                                                Width="24" Height="24"
                                                Foreground="{StaticResource SuccessBrush}"
                                                VerticalAlignment="Center"
                                                Margin="0,0,12,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Selected Student"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                            <TextBlock x:Name="tbSelectedStudent"
                                       Text="John Doe (STU-001)"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Clear Selection Button -->
                    <Button Grid.Column="2"
                            Name="btnClearSelection"
                            Content="Clear Selection"
                            Style="{StaticResource SecondaryButton}"
                            Padding="20,10" 
                            Click="btnClearSelection_Click"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Loading Overlay with Shimmer Effect -->
        <Border x:Name="loadingOverlay"
                Background="White"
                CornerRadius="16"
                Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Width="400" Height="80"
                        Background="#F5F5F5"
                        CornerRadius="12"
                        Margin="0,0,0,16"
                        ClipToBounds="True">
                    <Border.OpacityMask>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="White" Offset="0.3"/>
                            <GradientStop Color="White" Offset="0.7"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.OpacityMask>
                    <Border Background="White" Opacity="0.6">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="shimmerTransform" X="-200"/>
                        </Border.RenderTransform>
                    </Border>
                </Border>
                <TextBlock Text="Loading students..."
                           FontSize="16"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
