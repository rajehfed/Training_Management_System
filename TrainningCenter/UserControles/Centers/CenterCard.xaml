<UserControl x:Class="TrainningCenter.UserControles.Centers.CenterCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TrainningCenter.UserControles.Centers"
             xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignWidth="400"
             x:Name="root">
    <!--CENTER CARD-->
    <Border Background="White"
            Name="CenterCardBorder"
            CornerRadius="16"
            Width="380"
            Margin="0 0 20 20"
            Cursor="Hand"
            MouseLeftButtonDown="CenterCardBorder_MouseLeftButtonDown">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#000000" 
                                BlurRadius="20" 
                                ShadowDepth="0" 
                                Opacity="0.08"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#8147E7" 
                                        BlurRadius="25" 
                                        ShadowDepth="0" 
                                        Opacity="0.3"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!--HEADER WITH GRADIENT-->
            <Border Grid.Row="0"
                    Height="120"
                    CornerRadius="16 16 0 0"
                    Background="{StaticResource PrimaryGradient}">
                <Grid Margin="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!--CENTER ICON-->
                    <Border Grid.Column="0"
                            Width="60" Height="60"
                            CornerRadius="30"
                            Background="White"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                        <Icons:PackIconMaterial Kind="OfficeBuilding"
                                                Width="32" 
                                                Height="32"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource PrimaryBrush}"/>
                    </Border>

                    <!--STATUS BADGE-->
                    <Border Grid.Column="1"
                            CornerRadius="12"
                            Padding="12,6"
                            Background="White"
                            VerticalAlignment="Top">
                        <TextBlock FontSize="10" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <!-- Bind to the Center object in the DataContext -->
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="Foreground" Value="#28A745"/>
                                            <Setter Property="Text" Value="ACTIVE"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                            <Setter Property="Foreground" Value="#DC3545"/>
                                            <Setter Property="Text" Value="INACTIVE"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>

            <!--CONTENT-->
            <Border Grid.Row="1" Padding="24 20">
                <StackPanel>
                    <TextBlock Text="{Binding CenterName}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"/>

                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Icons:PackIconMaterial Kind="MapMarker"
                                                Width="16" Height="16"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                VerticalAlignment="Center"
                                                Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding City}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="{Binding Address}"
                               FontSize="12"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               TextWrapping="Wrap"
                               MaxHeight="40"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,8,0,0"/>
                    
                    <Grid Margin="0 16 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Capacity" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                <Icons:PackIconMaterial Kind="AccountGroup"
                                                    Width="16" Height="16"
                                                    Foreground="{StaticResource PrimaryBrush}"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding Capacity}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Manager" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
                            <TextBlock Text="{Binding Manager}"
                                   FontSize="12"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!--FOOTER ACTIONS-->
            <Border Grid.Row="2"
                    Background="{StaticResource PageBackgroundBrush}"
                    BorderBrush="{StaticResource BorderLightBrush}"
                    BorderThickness="0 1 0 0"
                    Padding="16,12"
                    CornerRadius="0 0 16 16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Icons:PackIconMaterial Kind="Phone"
                                                Width="14" Height="14"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                VerticalAlignment="Center"
                                                Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding Phone}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <!-- We use Commands or Click Events routed up to the UserControl -->
                        <Button Style="{StaticResource IconButtonEdit}"
                                ToolTip="Edit Center"
                                x:Name="btnEditCenter"
                                Click="btnEditCenter_Click"
                                Margin="0 0 4 0">
                            <Icons:PackIconMaterial Kind="Pencil" Width="14" Height="14" Foreground="{StaticResource PrimaryBrush}"/>
                        </Button>

                        <Button x:Name="btnDelete"
                                Style="{StaticResource IconButtonDelete}"
                                ToolTip="Delete Center"
                                Click="btnDelete_Click">
                            <Icons:PackIconMaterial Kind="Delete" Width="14" Height="14" Foreground="{StaticResource DangerBrush}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
