<UserControl x:Class="TrainningCenter.UserControles.Centers.CenterListItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TrainningCenter.UserControles.Centers"             
             xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="80" d:DesignWidth="1200">

    <Border Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource BorderLightBrush}"
            BorderThickness="0 0 0 1"
            Padding="24,16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Center Info -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Border Width="40" Height="40" CornerRadius="20" Background="{StaticResource PrimaryPaleBrush}">
                    <TextBlock Text="{Binding Initials}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="{Binding CenterName}" Style="{StaticResource DataGridTextBold}"/>
                    <TextBlock Text="{Binding City}" Style="{StaticResource DataGridTextMuted}" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Email -->
            <TextBlock Grid.Column="1" Text="{Binding Email}" Style="{StaticResource DataGridTextRegular}" VerticalAlignment="Center"/>

            <!-- Phone -->
            <TextBlock Grid.Column="2" Text="{Binding Phone}" Style="{StaticResource DataGridTextRegular}" VerticalAlignment="Center"/>

            <!-- Status -->
            <Border Grid.Column="3" CornerRadius="12" Padding="10,5" HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock FontSize="10" FontWeight="SemiBold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                    <Setter Property="Text" Value="ACTIVE"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsActive}" Value="False">
                                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                    <Setter Property="Text" Value="INACTIVE"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <!-- Actions -->
            <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource IconButtonEdit}" 
                        ToolTip="Edit Center" 
                        Name="btnEdit" 
                        Click="btnEdit_Click" 
                        Margin="0 0 4 0">
                    <Icons:PackIconMaterial Kind="Pencil" 
                                            Width="14" 
                                            Height="14" 
                                            Foreground="{StaticResource PrimaryBrush}"/>
                </Button>

                <Button Style="{StaticResource IconButtonDelete}"
                        ToolTip="Delete Center"
                        Name="btnDelete"
                        Click="btnDelete_Click">
                    <Icons:PackIconMaterial Kind="Delete" 
                                            Width="14" 
                                            Height="14" 
                                            Foreground="{StaticResource DangerBrush}"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
