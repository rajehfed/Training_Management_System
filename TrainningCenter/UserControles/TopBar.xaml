<UserControl x:Class="TrainningCenter.UserControles.TopBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:TrainningCenter.UserControles"
             mc:Ignorable="d" 
             d:DesignHeight="80" d:DesignWidth="1030" Background="White">
    <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="30,0">

        <Grid Height="80">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />        <!-- Welcome Section -->
                <ColumnDefinition Width="*" />           <!-- Search Box -->
                <ColumnDefinition Width="Auto" />        <!-- Notifications -->
            </Grid.ColumnDefinitions>

            <!--Welcome Section-->
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0, 0, 40, 0">
                <TextBlock x:Name="WelcomeText"
                           Text="Welcome Pooran" 
                           FontSize="20" 
                           FontWeight="SemiBold" 
                           Foreground="#202020"/>
                <TextBlock x:Name="SubtitleText"
                           Text="Senior Admin - TIPSG Education Pvt. Ltd." 
                           FontSize="12" 
                           Foreground="#7F8C8D"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Search Box -->
            <Border Grid.Column="1"
                    Height="45"
                    MaxWidth="800"
                    HorizontalAlignment="Left"
                    Background="White"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="0 0 5 0"
                    Margin="0,0,20,0">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search Icon -->
                    <Path Grid.Column="0" 
                          Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                          Fill="#999999"
                          Stretch="Uniform"
                          Width="18"
                          Height="18"
                          VerticalAlignment="Center"
                          Margin="12,0,8,0"/>

                    <!--Text Box Search-->
                    <TextBox x:Name="txtSearchBox" Grid.Column="1" Style="{StaticResource SearchTextBox}" />
                </Grid>
            </Border>
            
            
            <!-- Filter By Combo box -->
            <ComboBox Name="cbFilter" 
                      FontSize="14" 
                      SelectedIndex="0" 
                      Width="200" 
                      Height="40" 
                      Grid.Column="2" 
                      Style="{StaticResource CompactComboBox}">

                <ComboBoxItem Content="None"/>
                <ComboBoxItem Content="ID"/>
                <ComboBoxItem Content="National No"/>
                <ComboBoxItem Content="First Name"/>
                <ComboBoxItem Content="Last Name"/>
                <ComboBoxItem Content="Phone Number"/>
                
            </ComboBox>

        </Grid>
        
    </Border>
</UserControl>
