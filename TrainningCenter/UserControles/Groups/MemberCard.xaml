<UserControl x:Class="TrainningCenter.UserControles.Groups.MemberCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TrainningCenter.UserControles.Groups"
             xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
             x:Name="memberCardRoot"
             mc:Ignorable="d" >
    <Border Style="{StaticResource CompactCard}">
        
        <Grid DataContext="{Binding Member, ElementName=memberCardRoot}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!--AVATAR-->
            <Border Grid.Column="0"
                    Width="48" Height="48"
                    CornerRadius="24"
                    Background="{StaticResource PrimaryBrush}"
                    Margin="0 0 16 0">
                <TextBlock x:Name="tbInitials" 
                           Text="{Binding Initials}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
            
            <!--MEMBER INFO-->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="tbNameText"
                           Text="{Binding MemberName}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock x:Name="tbEmailText" 
                           Text="{Binding Email}"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,2,0,0"/>
            </StackPanel>
            
            <!--STATUS BADGE-->
            <Border Grid.Column="2"
                    Style="{StaticResource PrimaryBadge}"
                    Margin="0 0 12 0"
                    VerticalAlignment="Center">
                <TextBlock x:Name="tbSubscriptionStatus"
                           Text="{Binding Status}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource PrimaryBrush}"/>
            </Border>
            
            <!--ACTIONS-->
            <StackPanel Grid.Column="3"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Style="{StaticResource IconButtonEdit}"
                        ToolTip="Edit Member"
                        Name="btnEditMember"
                        Click="btnEditMember_Click"
                        Margin="0 0 4 0">
                    <Icons:PackIconMaterial Kind="Pencil"
                                          Width="14"
                                          Height="14"
                                          Foreground="{StaticResource PrimaryBrush}"/>
                </Button>

                <Button Style="{StaticResource IconButtonDelete}"
                        ToolTip="Delete Member"
                        Name="btDeleteMember"
                        Click="btDeleteMember_Click">
                    <Icons:PackIconMaterial Kind="Close"
                                          Width="14"
                                          Height="14"
                                          Foreground="{StaticResource DangerBrush}"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
