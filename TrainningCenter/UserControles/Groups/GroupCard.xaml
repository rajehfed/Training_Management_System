<UserControl x:Class="TrainningCenter.UserControles.Groups.GroupCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TrainningCenter.UserControles.Groups"
             xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d">
    <Grid>
        <Border Style="{StaticResource HoverCard}"
                Padding="16"
                Cursor="Hand"
                Name="border"
                MouseLeftButtonDown="border_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!--GROUPS ICON-->
                <Border Grid.Column="0"
                        Style="{StaticResource PurpleIconContainer}"
                        Width="44" Height="44"
                        Margin="0,0,12,0">
                    <Icons:PackIconMaterial Kind="AccountGroup"
                                            Width="20"
                                            Height="20"
                                            Foreground="{StaticResource PrimaryBrush}"/>
                </Border>

                <!-- Group Info -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="tbGroupNameText"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="tbMemberCountText"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Status Badge -->
                <Border x:Name="ActiveBadge"
                        Grid.Column="2"
                        Style="{StaticResource ActiveBadge}"
                        VerticalAlignment="Top"
                        Visibility="Collapsed">
                    <TextBlock Text="ACTIVE"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource SuccessBrush}"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
