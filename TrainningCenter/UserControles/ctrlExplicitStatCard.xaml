<UserControl x:Class="TrainningCenter.UserControles.ctrlExplicitStatCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TrainningCenter.UserControles"
             xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d"
             d:DesignHeight="200" d:DesignWidth="300"
             Name="root">
    <Border Background="White"
            MouseLeftButtonDown="Border_MouseLeftButtonDown"
            Cursor="Hand"
            CacheMode="BitmapCache">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="20"/>
                <Setter Property="Padding" Value="28"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#8147E7" BlurRadius="25" ShadowDepth="0" Opacity="0.25"/>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="RenderTransform">
                            <Setter.Value>
                                <TranslateTransform Y="-4"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                    <Trigger Property="IsMouseOver" Value="False">
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect RenderingBias="Performance" Color="#000000" BlurRadius="20" ShadowDepth="0" Opacity="0.08"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Width="64" Height="64"
                    CornerRadius="16"
                    Background="{Binding AccentBrush, ElementName=root}"
                    HorizontalAlignment="Left"
                    Margin="0 0 0 20">
                <Icons:PackIconMaterial Kind="{Binding IconKind, ElementName=root}"
                                        Width="32" Height="32"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{Binding IconForeground, ElementName=root}"/>
            </Border>

            <StackPanel Grid.Row="1" Margin="0 16 0 0">
                <TextBlock Text="{Binding Title, ElementName=root}"
                           FontSize="11"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           Margin="0,0,0,8"
                           TextWrapping="Wrap"/>

                <TextBlock Text="{Binding Value, ElementName=root}"
                           FontSize="40"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Row="2" 
                        Orientation="Horizontal" 
                        Margin="0,12,0,0">
                <Border CornerRadius="6"
                        Padding="8,4">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{Binding StatusBrush.(SolidColorBrush.Color), ElementName=root}" Opacity="0.15"/>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <Icons:PackIconMaterial Kind="{Binding StatusKind, ElementName=root}"
                                                Width="14" Height="14"
                                                Foreground="{Binding StatusBrush, ElementName=root}"
                                                Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding StatusText, ElementName=root}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{Binding StatusBrush, ElementName=root}"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding AdditionalText, ElementName=root}"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0">
                    <!-- FIX 4: Show only if AdditionalText is not empty -->
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding AdditionalText, ElementName=root}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding AdditionalText, ElementName=root}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
