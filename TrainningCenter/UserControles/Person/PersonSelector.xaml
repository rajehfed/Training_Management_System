<UserControl x:Class="TrainningCenter.UserControles.PersonSelector"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TrainningCenter.UserControles"
             xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
             mc:Ignorable="d" 
             d:DesignHeight="450" 
             d:DesignWidth="800">

    <UserControl.Resources>
        <!-- Boolean to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- THIS IS THE NEW, REUSABLE TEMPLATE FOR A PERSON -->
        <DataTemplate x:Key="PersonItemTemplate">
            <StackPanel Orientation="Horizontal" Margin="4">
                <Border Width="34" Height="34" CornerRadius="8" Margin="0,0,12,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#8147E7" Offset="0" />
                            <GradientStop Color="#A980F5" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="{Binding Initials}" 
                           Foreground="White" FontWeight="Bold" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding FullName}" 
                           FontWeight="SemiBold" FontSize="14" Foreground="#202020"/>
                    <TextBlock Text="{Binding Phone}" 
                           FontSize="11" Foreground="#999999" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!--CARD STYLE-->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="0" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!--PRIMARY BUTTON-->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#8147E7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#9A5FF0"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--SECONDARY BUTTON-->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--MODERN COMBOX-->
        <Style x:Key="ModernComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="65"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      Margin="{TemplateBinding Padding}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"/>
                                    <ToggleButton Grid.Column="1"
                                                   Background="Transparent"
                                                   BorderThickness="0"
                                                   Width="30"
                                                   Focusable="False"
                                                   IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                   ClickMode="Press">
                                        <Icons:PackIconMaterial Kind="ChevronDown" 
                                                                 Width="18" 
                                                                 Height="18"
                                                                 Foreground="#666666"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               AllowsTransparency="True">
                                <Border Background="White"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Margin="0,5,0,0"
                                    MinWidth="{TemplateBinding ActualWidth}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="0" Opacity="0.1"/>
                                    </Border.Effect>
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#8147E7"/>
                    <Setter Property="Background" Value="White"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#B8A3E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <StackPanel>
        <StackPanel Margin="0,0,0,18">
            <TextBlock Text="Select Person" 
               FontWeight="SemiBold" 
               FontSize="13"
               Foreground="#202020" 
               Margin="0,0,0,8"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox Name="cmbPerson"
                          Grid.Column="0"
                          Style="{StaticResource ModernComboBox}"
                          ItemTemplate="{StaticResource PersonItemTemplate}"
                          SelectionChanged="cmbPerson_SelectionChanged">
                </ComboBox>

                <Button Grid.Column="1"
                Name="btnRefreshPersons"
                Style="{StaticResource SecondaryButton}"
                Padding="12"
                Margin="10,0,0,0"
                ToolTip="Refresh person list"
                Click="btnRefreshPersons_Click">
                    <Icons:PackIconMaterial Kind="Refresh" 
                                  Width="18" 
                                  Height="18"/>
                </Button>
            </Grid>

            <TextBlock Text="Only people without user accounts are shown" 
               FontSize="11" 
               Foreground="#999999" 
               Margin="4,6,0,0"/>
        </StackPanel>

        <!--SELECTED PERSON INFO (READ-ONLY)-->
        <Border x:Name="pnlPersonInfo"
                Background="#F0EDFF"
                CornerRadius="8"
                Padding="15"
                Margin="0 0 0 18"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="50" Height="50"
                CornerRadius="10"
                Grid.Column="0"
                Margin="0 0 15 0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#8147E7" Offset="0"/>
                            <GradientStop Color="#A980F5" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock x:Name="tbPersonInitials"
                       Foreground="White" 
                       FontWeight="Bold" 
                       FontSize="18"
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="tbPersonName"
                       FontWeight="SemiBold"
                       FontSize="15"
                       Foreground="#202020"
                       Margin="0 0 0 4"/>
                    <StackPanel Orientation="Horizontal">
                        <Icons:PackIconMaterial Kind="Phone" 
                                      Width="14" 
                                      Height="14"
                                      Foreground="#8147E7"
                                      Margin="0,0,6,0"
                                      VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtPersonPhone"
                           FontSize="13" 
                           Foreground="#666666"
                           VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
