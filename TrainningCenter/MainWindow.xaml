<Window x:Class="TrainningCenter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrainningCenter"
        xmlns:Icons="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:Page="clr-namespace:TrainningCenter.Pages"
        mc:Ignorable="d"
        Height="740" Width="1280" 
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True" 
        Background="Transparent">

    <Window.Resources>
        <!-- Enhanced Menu Button Animations -->
        <Storyboard x:Key="MenuButtonHoverStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                           From="0" To="5" Duration="0:0:0.2"/>
        </Storyboard>
        <Storyboard x:Key="MenuButtonLeaveStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                           From="5" To="0" Duration="0:0:0.2"/>
        </Storyboard>
    </Window.Resources>

    <Border Background="#F5F7FA" 
            CornerRadius="10"
            BorderBrush="#8147E7"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" 
                            BlurRadius="30" 
                            ShadowDepth="0" 
                            Opacity="0.3"/>
        </Border.Effect>

        <Grid Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Background="White" 
                    CornerRadius="10,0,0,10"
                    BorderBrush="#E0E0E0"
                    BorderThickness="0,0,1,0">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" 
                                    BlurRadius="10" 
                                    ShadowDepth="2" 
                                    Opacity="0.05"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- User Profile Section -->
                    <StackPanel Grid.Row="0">
                        <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center"
                                    Margin="0,35,0,0">

                            <Border CornerRadius="10" 
                                    Width="50" 
                                    Height="50"
                                    BorderBrush="#8147E7"
                                    BorderThickness="2">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#8147E7" Offset="0" />
                                        <GradientStop Color="#A980F5" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>

                                <TextBlock Text="RF" 
                                           x:Name="tbInitials"
                                           Foreground="White" 
                                           FontSize="20" 
                                           FontWeight="Bold" 
                                           TextAlignment="Center" 
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Border>

                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Rajeh Fedili" 
                                           x:Name="tbUsername"
                                           FontSize="15" 
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4" 
                                           Foreground="#202020" />
                                <Border Background="#E8E4F3"
                                        CornerRadius="10"
                                        Padding="6,2">
                                    <TextBlock Text="Beta 1.3" 
                                               x:Name="tbRole"
                                               FontSize="10" 
                                               FontWeight="Medium"
                                               Foreground="#8147E7" 
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Separator Height="1" 
                                   Margin="20,25,20,20" 
                                   Background="#E0E0E0" />
                    </StackPanel>

                    <!-- Menu Buttons Section -->
                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="0,0,0,10">
                        <StackPanel>
                            <Button Style="{StaticResource menuButtonActive}" x:Name="btnDashboard" Click="btnDashboard_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Style="{StaticResource menuButtonIcon}" 
                                                            Name="DashboardIcon" 
                                                            Kind="MonitorDashboard" 
                                                            Width="20" Height="20" />
                                    <TextBlock Style="{StaticResource menuButtonTextActive}" 
                                               Text="Dashboard" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource menuButton}" Name="btnPeople" Click="btnPeople_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Style="{StaticResource menuButtonIconActive}" 
                                                            Name="HomeIcon" 
                                                            Kind="AccountMultiple" 
                                                            Width="20" Height="20" />
                                    <TextBlock Style="{StaticResource menuButtonText}" 
                                               Text="People" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource menuButton}" Name="btnStudents" Click="btnStudents_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Style="{StaticResource menuButtonIcon}" 
                                            Kind="AccountSchool" 
                                            Width="20" Height="20" />
                                    <TextBlock Style="{StaticResource menuButtonText}" 
                                               Text="Students" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource menuButton}" Name="btnTrainers" Click="btnTrainers_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Style="{StaticResource menuButtonIcon}" 
                                            Kind="HumanMaleBoard" 
                                            Width="20" Height="20" />
                                    <TextBlock Style="{StaticResource menuButtonText}" 
                                               Text="Trainers" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource menuButton}" Name="btnSpecialization" Click="btnSpecialization_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Style="{StaticResource menuButtonIcon}" 
                                            Kind="FolderStarMultiple" 
                                            Width="20" Height="20" />
                                    <TextBlock Style="{StaticResource menuButtonText}" 
                                               Text="Specializations" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource menuButton}" Name="btnGroups" Click="btnGroups_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Style="{StaticResource menuButtonIcon}" 
                                            Kind="GoogleClassroom" 
                                            Width="20" Height="20" />
                                    <TextBlock Style="{StaticResource menuButtonText}" 
                                               Text="Training Groups" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource menuButton}" Name="btnCenters" Click="btnCenters_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Style="{StaticResource menuButtonIcon}" 
                                                            Kind="OfficeBuildingOutline" 
                                                            Width="20" Height="20" />
                                    <TextBlock Style="{StaticResource menuButtonText}" 
                                               Text="Centers" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource menuButton}" Name="btnSessions" Click="btnSessions_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Style="{StaticResource menuButtonIcon}" 
                                            Kind="TimelineClock" 
                                            Width="20" Height="20" />
                                    <TextBlock Style="{StaticResource menuButtonText}" 
                                               Text="Sessions"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource menuButton}" Name="btnAssessments" Click="btnAssessments_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Style="{StaticResource menuButtonIcon}" 
                                            Kind="ClipboardTextOutline" 
                                            Width="20" Height="20" />
                                    <TextBlock Style="{StaticResource menuButtonText}" 
                                               Text="Assessments" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource menuButton}" Name="btnGradesBook"
                                    Click="btnGradesBook_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Style="{StaticResource menuButtonIcon}" 
                                            Kind="NotebookEdit" 
                                            Width="20" Height="20" />
                                    <TextBlock Style="{StaticResource menuButtonText}" 
                                               Text="Grades Book" />
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource menuButton}">
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Style="{StaticResource menuButtonIcon}" 
                                            Kind="Certificate" 
                                            Width="20" Height="20" />
                                    <TextBlock Style="{StaticResource menuButtonText}" 
                                               Text="Certificates" />
                                </StackPanel>
                            </Button>

                            <!--<Button Style="{StaticResource menuButton}">
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Style="{StaticResource menuButtonIcon}" 
                                            Kind="AlertBox" 
                                            Width="20" Height="20" />
                                    <TextBlock Style="{StaticResource menuButtonText}" 
                                               Text="Reports" />
                                </StackPanel>
                            </Button>-->

                            <Button Style="{StaticResource menuButton}" Name="btnUsers" Click="btnUsers_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Style="{StaticResource menuButtonIcon}"
                                                            Kind="AccountSupervisor"
                                                            Width="20" Height="20"/>
                                    <TextBlock Style="{StaticResource menuButtonText}"
                                               Text="Users"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer Section -->
                    <Border Grid.Row="2" 
                            Background="#F8F9FA"
                            CornerRadius="0,0,0,10"
                            Padding="15,12"
                            BorderBrush="#E0E0E0"
                            BorderThickness="0,1,0,0">
                        <StackPanel>
                            <Button Style="{StaticResource menuButton}"
                                    Margin="0">
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Kind="Cog" 
                                                            Width="18" 
                                                            Height="18"
                                                            Foreground="#666666"
                                                            Margin="0,0,10,0"/>
                                    <TextBlock Text="Settings" 
                                               FontSize="13"
                                               Foreground="#666666"/>
                                </StackPanel>
                            </Button>

                            <Button Style="{StaticResource menuButton}"
                                    Margin="0,5,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Icons:PackIconMaterial Kind="Logout" 
                                                            Width="18" 
                                                            Height="18"
                                                            Foreground="#F44336"
                                                            Margin="0,0,10,0"/>
                                    <TextBlock Text="Logout" 
                                               FontSize="13"
                                               Foreground="#F44336"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>

            </Border>

            <!-- Main Content Section -->
            <Border Background="#F5F7FA" 
                    Grid.Column="1" 
                    CornerRadius="0,10,10,0"
                    MouseDown="Border_MouseDown">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top Bar with Window Controls -->
                    <Border Grid.Row="0" 
                            Background="White"
                            CornerRadius="0,10,0,0"
                            BorderBrush="#E0E0E0"
                            BorderThickness="0,0,0,1"
                            Padding="20,0">
                        <Grid>
                            <TextBlock Text="Training Center Management System" 
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#202020"
                                       VerticalAlignment="Center"/>

                            <StackPanel Orientation="Horizontal" 
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">

                                <!-- Minimize Button -->
                                <Button Width="40" 
                                        Height="40"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Margin="0,0,5,0"
                                        Click="MinimizeButton_Click">
                                    <Icons:PackIconMaterial Kind="WindowMinimize"
                                                            Width="18"
                                                            Height="18"
                                                            Foreground="#666666"/>
                                </Button>

                                <!-- Maximize Button -->
                                <Button Width="40" 
                                        Height="40"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Margin="0,0,5,0"
                                        Click="MaximizeButton_Click">
                                    <Icons:PackIconMaterial Kind="WindowMaximize"
                                                            Width="18"
                                                            Height="18"
                                                            Foreground="#666666"/>
                                </Button>

                                <!-- Close Button -->
                                <Button Width="40" 
                                        Height="40"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Click="CloseButton_Click">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="5">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F44336"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Icons:PackIconMaterial Kind="Close"
                                                            Width="18"
                                                            Height="18">
                                        <Icons:PackIconMaterial.Style>
                                            <Style TargetType="Icons:PackIconMaterial">
                                                <Setter Property="Foreground" Value="#666666"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Icons:PackIconMaterial.Style>
                                    </Icons:PackIconMaterial>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border CornerRadius="0 0 10 0" Grid.Row="1" Background="Transparent">
                        <!-- Frame Content -->
                        <Frame x:Name="MainFrame" 
                               ClipToBounds="True"
                               NavigationUIVisibility="Hidden" 
                               Source="Views/Pages/DashboardPage.xaml"/>
                    </Border>
                </Grid>

            </Border>

        </Grid>
    </Border>
</Window>